@@ -56,6 +57,7 @@ type MutantExecutorDealer struct {
 	execContext       execContext
 	mod               gomodule.GoModule
 	buildTags         string
+	testCmd           string
 	testExecutionTime time.Duration
 	dryRun            bool
 	integrationMode   bool
@@ -81,6 +83,7 @@ func NewExecutorDealer(mod gomodule.GoModule, wdd workdir.Dealer, elapsed time.D
 	integrationMode := configuration.Get[bool](configuration.UnleashIntegrationMode)
 	testCPU := configuration.Get[int](configuration.UnleashTestCPUKey)
 	tCoefficient := configuration.Get[int](configuration.UnleashTimeoutCoefficientKey)
+	testCmd := configuration.Get[string](configuration.UnleashTestCmdKey)
 
 	coefficient := DefaultTimeoutCoefficient
 	if tCoefficient != 0 {
@@ -95,6 +98,7 @@ func NewExecutorDealer(mod gomodule.GoModule, wdd workdir.Dealer, elapsed time.D
 		mod:               mod,
 		wdDealer:          wdd,
 		buildTags:         buildTags,
+		testCmd:           testCmd,
 		dryRun:            dryRun,
 		integrationMode:   integrationMode,
 		testCPU:           testCPU,
@@ -123,6 +127,7 @@ func (m MutantExecutorDealer) NewExecutor(mut mutator.Mutator, outCh chan<- muta
 		dryRun:            m.dryRun,
 		integrationMode:   m.integrationMode,
 		buildTags:         m.buildTags,
+		testCmd:           m.testCmd,
 		execContext:       m.execContext,
 		testCPU:           m.testCPU,
 		testExecutionTime: m.testExecutionTime,
@@ -141,6 +146,7 @@ type mutantExecutor struct {
 	execContext       execContext
 	module            gomodule.GoModule
 	buildTags         string
+	testCmd           string
 	testExecutionTime time.Duration
 	dryRun            bool
 	integrationMode   bool
@@ -195,10 +201,17 @@ func (m *mutantExecutor) runTests(rootDir, pkg string) mutator.Status {
 	ctx, cancel := context.WithTimeout(context.Background(), m.testExecutionTime)
 	defer cancel()
 
-	cmd := m.execContext(ctx, "go", m.getTestArgs(pkg)...)
-	cmd.Dir = m.mutant.Workdir()
-	if m.integrationMode {
+	var cmd *exec.Cmd
+	if m.testCmd != "" {
+		parts := strings.Fields(m.testCmd)
+		cmd = m.execContext(ctx, parts[0], parts[1:]...)
 		cmd.Dir = rootDir
+	} else {
+		cmd = m.execContext(ctx, "go", m.getTestArgs(pkg)...)
+		cmd.Dir = m.mutant.Workdir()
+		if m.integrationMode {
+			cmd.Dir = rootDir
+		}
 	}
 	cmd.Env = append(cmd.Env, os.Environ()...)
 	cmd.Env = append(cmd.Env, fmt.Sprintf("GOTMPDIR=%s", m.wdDealer.WorkDir()))
diff --git a/internal/engine/workdir/workdir.go b/internal/engine/workdir/workdir.go
index 6f479c5..44e0bfd 100644
--- a/internal/engine/workdir/workdir.go
+++ b/internal/engine/workdir/workdir.go
@@ -154,6 +154,22 @@ func copyPath(srcPath, dstPath string, info fs.FileInfo) error {
 	return nil
 }
 
+// PassthroughDealer returns original source paths without copying. Mutations
+// are applied in-place, which is required for build systems like Bazel that
+// need source changes in the workspace to trigger a rebuild.
+type PassthroughDealer struct {
+	srcDir string
+}
+
+// NewPassthroughDealer creates a dealer that operates on original source files.
+func NewPassthroughDealer(srcDir string) *PassthroughDealer {
+	return &PassthroughDealer{srcDir: srcDir}
+}
+
+func (d *PassthroughDealer) Get(_ string) (string, error) { return d.srcDir, nil }
+func (d *PassthroughDealer) Clean()                        {}
+func (d *PassthroughDealer) WorkDir() string               { return d.srcDir }
+
 func doCopy(srcPath, dstPath string, fileMode fs.FileMode) error {
 	//nolint:gosec // srcPath is internally controlled, not user input
 	s, err := os.Open(srcPath)
