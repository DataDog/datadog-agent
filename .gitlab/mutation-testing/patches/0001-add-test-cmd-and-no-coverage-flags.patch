From 3b638ce7d7c0a5e507d16da27d060d6ca4995dc3 Mon Sep 17 00:00:00 2001
From: Phil Lee <philip.lee@datadoghq.com>
Date: Fri, 1 May 2026 14:26:44 -0400
Subject: [PATCH] feat: add --test-cmd and --no-coverage flags for Bazel
 support

When --test-cmd is set, gremlins uses the provided command instead of
'go test' for mutation execution, and applies mutations directly to
the source files (PassthroughDealer) instead of temporary copies.
This is required for build systems like Bazel that need source changes
in the workspace to trigger a rebuild.

When --no-coverage is set, gremlins skips the 'go test -cover' step
and treats all mutation sites as testable. Required when --test-cmd
is set since the coverage command also hardcodes 'go test'.
---
 cmd/unleash.go                          | 40 +++++++++++++++++++------
 internal/configuration/configuration.go |  3 ++
 internal/engine/engine.go               |  2 +-
 internal/engine/executor.go             | 19 ++++++++++--
 internal/engine/workdir/workdir.go      | 16 ++++++++++
 5 files changed, 67 insertions(+), 13 deletions(-)

diff --git a/cmd/unleash.go b/cmd/unleash.go
index d7eddb2..4a9cd8a 100644
--- a/cmd/unleash.go
+++ b/cmd/unleash.go
@@ -22,6 +22,7 @@ import (
 	"os"
 	"strings"
 	"sync"
+	"time"
 
 	"github.com/MakeNowJust/heredoc"
 	"github.com/spf13/cobra"
@@ -59,6 +60,8 @@ const (
 	paramTestCPU            = "test-cpu"
 	paramWorkers            = "workers"
 	paramTimeoutCoefficient = "timeout-coefficient"
+	paramTestCmd            = "test-cmd"
+	paramNoCoverage         = "no-coverage"
 
 	// Thresholds.
 	paramThresholdEfficacy  = "threshold-efficacy"
@@ -159,30 +162,47 @@ func cleanUp(wd string) {
 }
 
 func run(ctx context.Context, mod gomodule.GoModule, workDir string) (report.Results, error) {
+	noCoverage := configuration.Get[bool](configuration.UnleashNoCoverageKey)
+	testCmd := configuration.Get[string](configuration.UnleashTestCmdKey)
+
 	fDiff, err := diff.New()
 	if err != nil {
 		return report.Results{}, err
 	}
 
-	c := coverage.New(workDir, mod)
-
 	exclude, err := exclusion.New()
 	if err != nil {
 		return report.Results{}, err
 	}
 
-	cProfile, err := c.Run()
-	if err != nil {
-		return report.Results{}, fmt.Errorf("failed to gather coverage: %w", err)
+	var covProfile coverage.Profile
+	var elapsed time.Duration
+
+	if noCoverage {
+		elapsed = 30 * time.Second
+	} else {
+		c := coverage.New(workDir, mod)
+		cProfile, err := c.Run()
+		if err != nil {
+			return report.Results{}, fmt.Errorf("failed to gather coverage: %w", err)
+		}
+		covProfile = cProfile.Profile
+		elapsed = cProfile.Elapsed
 	}
 
-	wdDealer := workdir.NewCachedDealer(workDir, mod.Root)
-	defer wdDealer.Clean()
+	var wdDealer workdir.Dealer
+	if testCmd != "" {
+		wdDealer = workdir.NewPassthroughDealer(mod.Root)
+	} else {
+		cached := workdir.NewCachedDealer(workDir, mod.Root)
+		defer cached.Clean()
+		wdDealer = cached
+	}
 
-	jDealer := engine.NewExecutorDealer(mod, wdDealer, cProfile.Elapsed)
+	jDealer := engine.NewExecutorDealer(mod, wdDealer, elapsed)
 
 	codeData := engine.CodeData{
-		Cov:       cProfile.Profile,
+		Cov:       covProfile,
 		Diff:      fDiff,
 		Exclusion: exclude,
 	}
@@ -219,6 +239,8 @@ func setFlagsOnCmd(cmd *cobra.Command) error {
 		{Name: paramWorkers, CfgKey: configuration.UnleashWorkersKey, DefaultV: 0, Usage: "the number of workers to use in mutation testing"},
 		{Name: paramTestCPU, CfgKey: configuration.UnleashTestCPUKey, DefaultV: 0, Usage: "the number of CPUs to allow each test run to use"},
 		{Name: paramTimeoutCoefficient, CfgKey: configuration.UnleashTimeoutCoefficientKey, DefaultV: 0, Usage: "the coefficient by which the timeout is increased"},
+		{Name: paramTestCmd, CfgKey: configuration.UnleashTestCmdKey, DefaultV: "", Usage: "custom test command replacing 'go test' (e.g. 'bazel test //pkg:target')"},
+		{Name: paramNoCoverage, CfgKey: configuration.UnleashNoCoverageKey, DefaultV: false, Usage: "skip coverage gathering; mutate all sites (required with --test-cmd)"},
 	}
 
 	for _, f := range fls {
diff --git a/internal/configuration/configuration.go b/internal/configuration/configuration.go
index be4a411..3c55d2b 100644
--- a/internal/configuration/configuration.go
+++ b/internal/configuration/configuration.go
@@ -47,6 +47,9 @@ const (
 	UnleashDiffRef               = "unleash.diff"
 	UnleashThresholdEfficacyKey  = "unleash.threshold.efficacy"
 	UnleashThresholdMCoverageKey = "unleash.threshold.mutant-coverage"
+
+	UnleashTestCmdKey    = "unleash.test-cmd"
+	UnleashNoCoverageKey = "unleash.no-coverage"
 )
 
 const (
diff --git a/internal/engine/engine.go b/internal/engine/engine.go
index df452f4..2cebd08 100644
--- a/internal/engine/engine.go
+++ b/internal/engine/engine.go
@@ -188,7 +188,7 @@ func normalisePkgPath(pkg string) string {
 func (mu *Engine) mutationStatus(pos token.Position) mutator.Status {
 	var status mutator.Status
 
-	if mu.codeData.Cov.IsCovered(pos) {
+	if mu.codeData.Cov == nil || mu.codeData.Cov.IsCovered(pos) {
 		status = mutator.Runnable
 	}
 
diff --git a/internal/engine/executor.go b/internal/engine/executor.go
index 1f182ad..7fd6cce 100644
--- a/internal/engine/executor.go
+++ b/internal/engine/executor.go
@@ -23,6 +23,7 @@ import (
 	"os"
