crate = use_extension("@rules_rs//rs:extensions.bzl", "crate")
crate.from_cargo(
    name = "crates",
    cargo_lock = "//:Cargo.lock",
    cargo_toml = "//:Cargo.toml",
    platform_triples = [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
    ],
    validate_lockfile = True,
)
crate.annotation(
    crate = "protoc-gen-prost",
    gen_binaries = ["protoc-gen-prost"],
)
crate.annotation(
    crate = "protoc-gen-tonic",
    gen_binaries = ["protoc-gen-tonic"],
)

# par-control's ureq native-tls backend pulls openssl-sys. Link it against the
# agent's own OpenSSL (@openssl, built from source via foreign_cc) — "same as the
# rest of the agent" — instead of the system libs or a Rust-vendored copy. The
# openssl-sys build script is pointed at the foreign_cc install tree via OPENSSL_DIR.
crate.annotation(
    build_script_data = ["@openssl//:gen_dir"],
    build_script_env = {
        "OPENSSL_NO_VENDOR": "1",
        "OPENSSL_DIR": "$(execpath @openssl//:gen_dir)",
    },
    crate = "openssl-sys",
    data = ["@openssl"],
    deps = ["@openssl"],
)

# Make the @openssl repo visible inside the crate extension so the openssl-sys
# annotation above can reference it.
inject_repo(crate, "openssl")

use_repo(crate, "crates")
