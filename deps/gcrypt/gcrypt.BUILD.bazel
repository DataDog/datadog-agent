    name = "copy_mpi-asm-defs_h",
    src = select({
        "@@//:linux_x86_64": "mpi/amd64/mpi-asm-defs.h",
        "@@//:linux_arm64": "mpi/aarch64/mpi-asm-defs.h",
    }),
    out = "mpi/mpi-asm-defs.h",
)

