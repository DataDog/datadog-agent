"""MODULE wrapper to download security-agent-policies using variables from release.json.

This loads 'dependencies' from release.json and uses that to construct the
GitHub archive download URL based on SECURITY_AGENT_POLICIES_VERSION.

Usage:
  get_security_agent_policies_using_release_constants = use_repo_rule(
      ":module_utils.bzl", "get_security_agent_policies_using_release_constants")

  get_security_agent_policies_using_release_constants(
      name = "security_agent_policies",
  )
"""

load("@bazel_tools//tools/build_defs/repo:cache.bzl", "DEFAULT_CANONICAL_ID_ENV", "get_default_canonical_id")
load("@bazel_tools//tools/build_defs/repo:utils.bzl", "get_auth")

_get_security_agent_policies_attrs = {
    "canonical_id": attr.string(),
    "_release_info": attr.label(default = "//:release.json", allow_single_file = True),
}

def _get_security_agent_policies_impl(rctx):
    """Implementation of the get_security_agent_policies_using_release_constants rule."""
    release_info = json.decode(rctx.read(rctx.path(rctx.attr._release_info)))
    vars = release_info["dependencies"]

    version = vars["SECURITY_AGENT_POLICIES_VERSION"]  # e.g. "v0.77.0"
    sha256 = vars.get("SECURITY_AGENT_POLICIES_SHA256", "")

    # Strip the leading 'v' to get the bare version number used in the strip prefix
    version_num = version.lstrip("v")

    url = "https://github.com/DataDog/security-agent-policies/archive/refs/tags/{version}.tar.gz".format(
        version = version,
    )

    rctx.download_and_extract(
        url = [url],
        sha256 = sha256,
        stripPrefix = "security-agent-policies-{version}".format(version = version_num),
        canonical_id = rctx.attr.canonical_id or get_default_canonical_id(rctx, [url]),
        auth = get_auth(rctx, [url]),
    )

    rctx.file("MODULE.bazel", "module(name = \"{name}\")\n".format(name = rctx.name))

    rctx.file(
        "version.bzl",
        content = """\
\"\"\"Auto-generated version information for security-agent-policies.
Generated by deps/security_agent_policies/module_utils.bzl from release.json.
Do not edit manually.
\"\"\"

VERSION = "{version}"
DOWNLOAD_URL = "{url}"
""".format(version = version_num, url = url),
    )

    rctx.template(
        "BUILD.bazel",
        Label("//deps/security_agent_policies:security_agent_policies.BUILD.bazel"),
        substitutions = {},
    )

    return rctx.repo_metadata(reproducible = True)

get_security_agent_policies_using_release_constants = repository_rule(
    implementation = _get_security_agent_policies_impl,
    attrs = _get_security_agent_policies_attrs,
    environ = [DEFAULT_CANONICAL_ID_ENV],
)
