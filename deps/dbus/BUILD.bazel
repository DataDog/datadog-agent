load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

configure_make(
    name="dbus",
    lib_source = "@dbus//:all",
    configure_options = [
        "--disable-static",
        "--disable-doxygen-docs",
        "--disable-ducktype-docs",
        "--disable-xml-docs",
        "--disable-stats",
        "--disable-tests",
        "--without-x",
    ],
    out_shared_libs = select({
        "@platforms//os:linux": [
            "libdbus.so",
        ],
    }),
    visibility = ["//visibility:public"],
)

