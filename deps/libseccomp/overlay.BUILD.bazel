load("@rules_cc//cc:defs.bzl", "cc_library")

package(default_visibility = ["//visibility:public"])

LIBSECCOMP_SRCS = [
    "src/api.c",
    "src/arch.c",
    "src/arch-aarch64.c",
    "src/arch-arm.c",
    "src/arch-loongarch64.c",
    "src/arch-m68k.c",
    "src/arch-mips.c",
    "src/arch-mips64.c",
    "src/arch-mips64n32.c",
    "src/arch-parisc.c",
    "src/arch-parisc64.c",
    "src/arch-ppc.c",
    "src/arch-ppc64.c",
    "src/arch-riscv64.c",
    "src/arch-s390.c",
    "src/arch-s390x.c",
    "src/arch-sh.c",
    "src/arch-x32.c",
    "src/arch-x86.c",
    "src/arch-x86_64.c",
    "src/db.c",
    "src/gen_bpf.c",
    "src/gen_pfc.c",
    "src/hash.c",
    "src/helper.c",
    "src/syscalls.c",
    "src/syscalls.perf.c",
    "src/system.c",
]

LIBSECCOMP_INTERNAL_HDRS = glob(["src/*.h"])

cc_library(
    name = "libseccomp",
    srcs = LIBSECCOMP_SRCS + LIBSECCOMP_INTERNAL_HDRS,
    hdrs = [
        "include/seccomp.h",
        "include/seccomp-syscalls.h",
    ],
    copts = [
        "-Wall",
        "-Umips",
        "-O2",
        "-fPIC",
        "-DPIC",
        "-fvisibility=hidden",
        "-ffunction-sections",
        "-fdata-sections",
    ],
    linkopts = ["-Wl,--gc-sections"],
    includes = [
        "include",
        "src",
    ],
    linkstatic = True,
    deps = ["@linux_headers//:linux_headers"],
)
