        "src/rust/cryptography-openssl/BUILD.bazel": "//deps/agent_integrations/cryptography:overlay/src/rust/cryptography-openssl/BUILD.bazel",
        "src/rust/cryptography-openssl/cargo_toml_env_vars.env": "//deps/agent_integrations/cryptography:overlay/src/rust/cryptography-openssl/cargo_toml_env_vars.env",
