integration_cryptography_source = use_repo_rule(
    "//deps/agent_integrations/cryptography:source.bzl",
    "integration_cryptography_source",
)

integration_cryptography_source(name = "cryptography_src")

cryptography_crate = use_extension("@rules_rs//rs:extensions.bzl", "crate")
cryptography_crate.annotation(
    build_script_data = ["@@//deps/agent_integrations/cryptography:openssl_install_dir"],
    build_script_env = {
        "OPENSSL_DIR": "$(execpath @@//deps/agent_integrations/cryptography:openssl_install_dir)",
        "OPENSSL_NO_VENDOR": "1",
        "OPENSSL_STATIC": "0",
    },
    crate = "openssl-sys",
    repositories = ["cryptography_crates"],
)
cryptography_crate.annotation(
    crate = "pyo3",
    crate_features = [
        "abi3-py39",
        "extension-module",
    ],
    repositories = ["cryptography_crates"],
)
cryptography_crate.from_cargo(
    name = "cryptography_crates",
    cargo_lock = "@cryptography_src//:Cargo.lock",
    cargo_toml = "@cryptography_src//:Cargo.toml",
    platform_triples = [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
    ],
    validate_lockfile = True,
)
use_repo(cryptography_crate, "cryptography_crates")
