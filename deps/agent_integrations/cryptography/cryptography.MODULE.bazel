integration_cryptography_source = use_repo_rule(
    "//deps/agent_integrations/cryptography:source.bzl",
    "csrc",
)

integration_cryptography_source(name = "cs")

cryptography_crate = use_extension("@rules_rs//rs:extensions.bzl", "crate")

inject_repo(
    cryptography_crate,
    winlibs_mingw64 = "winlibs_mingw64",
)

cryptography_crate.annotation(
    build_script_data = ["@@//deps/agent_integrations/cryptography:openssl_install_dir"],
    build_script_env = {
        "OPENSSL_DIR": "$(execpath @@//deps/agent_integrations/cryptography:openssl_install_dir)",
        "OPENSSL_NO_VENDOR": "1",
        "OPENSSL_STATIC": "0",
    },
    crate = "openssl-sys",
    repositories = ["cryptography_crates"],
)
cryptography_crate.annotation(
    build_script_env = {
        "PYO3_MINGW_DLLTOOL": "$(execpath @@//deps/agent_integrations/cryptography:mingw_dlltool_wrapper)",
        "PYO3_NO_PYTHON": "1",
        "PYO3_REAL_MINGW_DLLTOOL": "$(execpath @winlibs_mingw64//:dlltool)",
    },
    build_script_tools = [
        "@@//deps/agent_integrations/cryptography:mingw_dlltool_wrapper",
        "@winlibs_mingw64//:dlltool",
    ],
    crate = "pyo3-build-config",
    crate_features = ["generate-import-lib"],
    repositories = ["cryptography_crates"],
)
cryptography_crate.annotation(
    crate = "pyo3",
    crate_features = [
        "abi3-py39",
        "extension-module",
    ],
    repositories = ["cryptography_crates"],
)
cryptography_crate.from_cargo(
    name = "cryptography_crates",
    cargo_lock = "@cs//:Cargo.lock",
    cargo_toml = "@cs//:Cargo.toml",
    platform_triples = [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "x86_64-apple-darwin",
        "x86_64-pc-windows-msvc",
        "x86_64-unknown-linux-gnu",
    ],
    validate_lockfile = True,
)
use_repo(cryptography_crate, "cryptography_crates")
