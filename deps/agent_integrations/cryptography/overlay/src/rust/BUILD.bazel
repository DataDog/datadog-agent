load("@cryptography_crates//:defs.bzl", "RESOLVED_PLATFORMS", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_shared_library")

OPENSSL_CFGS = [
    "--cfg=CRYPTOGRAPHY_OPENSSL_309_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OPENSSL_320_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OPENSSL_330_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OPENSSL_350_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OSSLCONF=\"OPENSSL_NO_IDEA\"",
]

MACOS_PYO3_LINK_FLAGS = select({
    "@platforms//os:macos": [
        "-C",
        "link-arg=-undefined",
        "-C",
        "link-arg=dynamic_lookup",
        "-C",
        "link-arg=-Wl,-headerpad_max_install_names",
        # Required due to: https://github.com/PyO3/pyo3/issues/5035
        "--codegen=link-arg=-Wl,-no_fixup_chains",
    ],
    "//conditions:default": [],
})

_ALIASES = dict(aliases(package_name = "src/rust"))
_ALIASES.update({
    "//src/rust/cryptography-cffi": "cryptography_cffi",
    "//src/rust/cryptography-crypto": "cryptography_crypto",
    "//src/rust/cryptography-keepalive": "cryptography_keepalive",
    "//src/rust/cryptography-key-parsing": "cryptography_key_parsing",
    "//src/rust/cryptography-openssl": "cryptography_openssl",
    "//src/rust/cryptography-x509": "cryptography_x509",
    "//src/rust/cryptography-x509-verification": "cryptography_x509_verification",
})

rust_shared_library(
    name = "cryptography_rust",
    srcs = glob(["src/**/*.rs"]),
    aliases = _ALIASES,
    compile_data = glob(
        ["**"],
        exclude = [
            "BUILD",
            "BUILD.bazel",
            "Cargo.toml.orig",
            "WORKSPACE",
            "WORKSPACE.bazel",
        ],
    ),
    crate_features = [],
    crate_name = "cryptography_rust",
    crate_root = "src/lib.rs",
    deps = all_crate_deps(
        normal = True,
        package_name = "src/rust",
    ),
    edition = "2021",
    proc_macro_deps = all_crate_deps(
        package_name = "src/rust",
        proc_macro = True,
    ),
    rustc_flags = OPENSSL_CFGS + MACOS_PYO3_LINK_FLAGS,
    target_compatible_with = RESOLVED_PLATFORMS,
)
