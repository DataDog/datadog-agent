load("@cryptography_crates//:defs.bzl", "RESOLVED_PLATFORMS", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_shared_library")

_IS_CHECKED_IN_OVERLAY = package_name().startswith("deps/agent_integrations/cryptography/overlay/")

_TARGET_COMPATIBLE_WITH = ["@platforms//:incompatible"] if _IS_CHECKED_IN_OVERLAY else RESOLVED_PLATFORMS

package(default_visibility = ["//visibility:public"])

OPENSSL_CFGS = [
    "--cfg=CRYPTOGRAPHY_OPENSSL_309_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OPENSSL_320_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OPENSSL_330_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OPENSSL_350_OR_GREATER",
    "--cfg=CRYPTOGRAPHY_OSSLCONF=\"OPENSSL_NO_IDEA\"",
]

MACOS_PYO3_LINK_FLAGS = select({
    "@platforms//os:macos": [
        "-C",
        "link-arg=-undefined",
        "-C",
        "link-arg=dynamic_lookup",
        "-C",
        "link-arg=-Wl,-headerpad_max_install_names",
        # Required due to: https://github.com/PyO3/pyo3/issues/5035
        "--codegen=link-arg=-Wl,-no_fixup_chains",
    ],
    "//conditions:default": [],
})

_SRC_RUST = "//" + package_name()

_CRYPTOGRAPHY_CFFI = _SRC_RUST + "/cryptography-cffi"

_CRYPTOGRAPHY_CRYPTO = _SRC_RUST + "/cryptography-crypto"

_CRYPTOGRAPHY_KEEPALIVE = _SRC_RUST + "/cryptography-keepalive"

_CRYPTOGRAPHY_KEY_PARSING = _SRC_RUST + "/cryptography-key-parsing"

_CRYPTOGRAPHY_OPENSSL = _SRC_RUST + "/cryptography-openssl"

_CRYPTOGRAPHY_X509 = _SRC_RUST + "/cryptography-x509"

_CRYPTOGRAPHY_X509_VERIFICATION = _SRC_RUST + "/cryptography-x509-verification"

_LOCAL_DEPS = [
    _CRYPTOGRAPHY_CFFI,
    _CRYPTOGRAPHY_CRYPTO,
    _CRYPTOGRAPHY_KEEPALIVE,
    _CRYPTOGRAPHY_KEY_PARSING,
    _CRYPTOGRAPHY_OPENSSL,
    _CRYPTOGRAPHY_X509,
    _CRYPTOGRAPHY_X509_VERIFICATION,
]

_ALIASES = {
    label: crate_name
    for label, crate_name in aliases(package_name = "src/rust").items()
    if not label.startswith("//src/rust/")
}

_ALIASES.update({
    _CRYPTOGRAPHY_CFFI: "cryptography_cffi",
    _CRYPTOGRAPHY_CRYPTO: "cryptography_crypto",
    _CRYPTOGRAPHY_KEEPALIVE: "cryptography_keepalive",
    _CRYPTOGRAPHY_KEY_PARSING: "cryptography_key_parsing",
    _CRYPTOGRAPHY_OPENSSL: "cryptography_openssl",
    _CRYPTOGRAPHY_X509: "cryptography_x509",
    _CRYPTOGRAPHY_X509_VERIFICATION: "cryptography_x509_verification",
})

_ALIASES = {} if _IS_CHECKED_IN_OVERLAY else _ALIASES

rust_shared_library(
    name = "cryptography_rust",
    srcs = glob(
        ["src/**/*.rs"],
        allow_empty = True,
    ),
    aliases = _ALIASES,
    compile_data = glob(
        ["**"],
        allow_empty = True,
        exclude = [
            "BUILD",
            "BUILD.bazel",
            "Cargo.toml.orig",
            "WORKSPACE",
            "WORKSPACE.bazel",
        ],
    ),
    crate_features = [],
    crate_name = "cryptography_rust",
    crate_root = "src/lib.rs",
    edition = "2021",
    proc_macro_deps = [] if _IS_CHECKED_IN_OVERLAY else all_crate_deps(
        package_name = "src/rust",
        cargo_only = True,
        proc_macro = True,
    ),
    rustc_flags = OPENSSL_CFGS + MACOS_PYO3_LINK_FLAGS,
    target_compatible_with = _TARGET_COMPATIBLE_WITH,
    deps = [] if _IS_CHECKED_IN_OVERLAY else _LOCAL_DEPS + all_crate_deps(
        package_name = "src/rust",
        cargo_only = True,
        normal = True,
    ),
)
