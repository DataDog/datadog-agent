load("@cryptography_crates//:defs.bzl", "RESOLVED_PLATFORMS", "aliases")
load("@rules_rs//rs:rust_crate.bzl", "rust_crate")

_IS_CHECKED_IN_OVERLAY = package_name().startswith("deps/agent_integrations/cryptography/overlay/")

_TARGET_COMPATIBLE_WITH = ["@platforms//:incompatible"] if _IS_CHECKED_IN_OVERLAY else RESOLVED_PLATFORMS

OPENSSL_CFGS = [
    "--cfg=CRYPTOGRAPHY_OPENSSL_350_OR_GREATER",
]

_SRC_RUST = "//" + "/".join(package_name().split("/")[:-1])

_CRYPTOGRAPHY_CRYPTO = _SRC_RUST + "/cryptography-crypto"

_CRYPTOGRAPHY_OPENSSL = _SRC_RUST + "/cryptography-openssl"

_CRYPTOGRAPHY_X509 = _SRC_RUST + "/cryptography-x509"

_ALIASES = {
    label: crate_name
    for label, crate_name in aliases(package_name = "src/rust/cryptography-key-parsing").items()
    if not label.startswith("//src/rust/")
}

_ALIASES.update({
    _CRYPTOGRAPHY_CRYPTO: "cryptography_crypto",
    _CRYPTOGRAPHY_OPENSSL: "cryptography_openssl",
    _CRYPTOGRAPHY_X509: "cryptography_x509",
})

_ALIASES = {} if _IS_CHECKED_IN_OVERLAY else _ALIASES

rust_crate(
    name = "cryptography-key-parsing",
    aliases = _ALIASES,
    binaries = {},
    build_deps = [],
    build_script = "" if _IS_CHECKED_IN_OVERLAY else "build.rs",
    build_script_data = [],
    build_script_env = {},
    build_script_toolchains = [],
    build_script_tools = [],
    crate_features = [],
    crate_name = "cryptography_key_parsing",
    crate_root = "src/lib.rs",
    data = [],
    edition = "2021",
    is_proc_macro = False,
    links = None,
    rustc_flags = OPENSSL_CFGS,
    target_compatible_with = _TARGET_COMPATIBLE_WITH,
    version = "0.1.0",
    deps = [] if _IS_CHECKED_IN_OVERLAY else [
        _CRYPTOGRAPHY_CRYPTO,
        _CRYPTOGRAPHY_OPENSSL,
        _CRYPTOGRAPHY_X509,
        "@cryptography_crates//:asn1-0.24.1",
        "@cryptography_crates//:cfg-if-1.0.4",
        "@cryptography_crates//:openssl-0.10.79",
        "@cryptography_crates//:openssl-sys-0.9.115",
        "@cryptography_crates//:pem-3.0.6",
    ],
)
