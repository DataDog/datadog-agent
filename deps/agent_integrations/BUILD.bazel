load("@py_agent_integrations_tool_requirements//:requirements.bzl", "requirement")
load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "REMOVE_BASE_DIRECTORY", "pkg_files")
load("@rules_python//python:py_binary.bzl", "py_binary")
load("//deps/agent_integrations:defs.bzl", "install_wheels")

py_binary(
    name = "install_wheels_tool",
    srcs = ["install_wheels.py"],
    main = "install_wheels.py",
    deps = [requirement("installer")],
)

install_wheels(
    name = "integrations_dependencies",
    srcs = ["@integrations_core//:dependency_wheels"],
    script_interpreter_relative_path = select({
        "@platforms//os:windows": "embedded3/python3.exe",
        "//conditions:default": "embedded/bin/python3",
    }),
    script_kind = select({
        "@platforms//os:windows": "win-amd64",
        "//conditions:default": "posix",
    }),
    # TODO(agent-build): this currently depends INTEGRATIONS_CORE_VERSION being a commit hash,
    # which is not guaranteed unless running under omnibus-wrapping code.
    tags = ["manual"],
)

pkg_files(
    name = "integrations_dependency_files",
    srcs = [":integrations_dependencies"],
    prefix = "embedded",
    renames = {
        ":integrations_dependencies": REMOVE_BASE_DIRECTORY,
    },
    tags = ["manual"],
)

pkg_install(
    name = "install_dependencies",
    srcs = [":integrations_dependency_files"],
    tags = ["manual"],
)
