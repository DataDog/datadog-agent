load("@py_agent_integrations_tool_requirements//:requirements.bzl", "requirement")
load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "REMOVE_BASE_DIRECTORY", "pkg_attributes", "pkg_files")
load("@rules_python//python:py_binary.bzl", "py_binary")
load("@rules_python//python:py_library.bzl", "py_library")
load("@rules_python//python:py_test.bzl", "py_test")
load(":defs.bzl", "freeze", "install_wheels")
load(":source_packages_test.bzl", "source_packages_test_suite")

py_library(
    name = "wheels_lib",
    srcs = ["wheels.py"],
)

source_packages_test_suite(name = "source_packages_tests")

py_binary(
    name = "install_wheels_tool",
    srcs = ["install_wheels.py"],
    main = "install_wheels.py",
    deps = [
        ":wheels_lib",
        requirement("installer"),
    ],
)

py_binary(
    name = "build_wheel_tool",
    srcs = ["build_wheel.py"],
    main = "build_wheel.py",
    deps = [
        requirement("build"),
        requirement("hatchling"),
    ],
)

py_binary(
    name = "freeze_tool",
    srcs = ["freeze.py"],
    main = "freeze.py",
    deps = [
        ":wheels_lib",
        requirement("installer"),
    ],
)

py_test(
    name = "freeze_test",
    size = "small",
    srcs = [
        "freeze.py",
        "freeze_test.py",
    ],
    deps = [
        ":wheels_lib",
        requirement("installer"),
    ],
)

embedded_dir = select({
    "@platforms//os:windows": "embedded3",
    "//conditions:default": "embedded",
})

entrypoints_dirname = select({
    "@platforms//os:windows": "Scripts",
    "//conditions:default": "bin",
})

dependency_wheels = select(
    {
        "//:linux_x86_64": ["@integration_dependency_wheels_linux_x86_64//:dependency_wheels"],
        "//:linux_arm64": ["@integration_dependency_wheels_linux_aarch64//:dependency_wheels"],
        "//:macos_x86_64": ["@integration_dependency_wheels_macos_x86_64//:dependency_wheels"],
        "//:macos_arm64": ["@integration_dependency_wheels_macos_aarch64//:dependency_wheels"],
        "//:windows_x86_64": ["@integration_dependency_wheels_windows_x86_64//:dependency_wheels"],
    },
    no_match_error = "No integration dependency lockfile repo is configured for this target platform.",
)

install_wheels(
    name = "integrations",
    srcs = [
        "@integration_source_packages//:base_wheels",
        "@integration_source_packages//:integrations_wheels",
    ] + dependency_wheels,
    entrypoints_dirname = entrypoints_dirname,
    script_interpreter_relative_path = embedded_dir + select({
        "@platforms//os:windows": "/python.exe",
        "//conditions:default": "/bin/python3",
    }),
    tags = ["manual"],
)

freeze(
    name = "constraints_file",
    srcs = ["@integration_source_packages//:base_wheels"] + dependency_wheels,
    out = "final_constraints-py3.txt",
    tags = ["manual"],
)

filegroup(
    name = "integrations_runtime",
    srcs = [":integrations"],
    output_group = "runtime",
    tags = ["manual"],
)

filegroup(
    name = "integrations_bin",
    srcs = [":integrations"],
    output_group = "bin",
    tags = ["manual"],
)

pkg_files(
    name = "integrations_runtime_files",
    srcs = [":integrations_runtime"],
    attributes = pkg_attributes(mode = "0644"),
    prefix = embedded_dir,
    renames = {
        ":integrations_runtime": REMOVE_BASE_DIRECTORY,
    },
    tags = ["manual"],
)

pkg_files(
    name = "integrations_bin_files",
    srcs = [":integrations_bin"],
    attributes = pkg_attributes(mode = "0755"),
    prefix = embedded_dir + "/" + entrypoints_dirname,
    renames = {
        ":integrations_bin": REMOVE_BASE_DIRECTORY,
    },
    tags = ["manual"],
)

pkg_files(
    name = "constraints_files",
    srcs = [":constraints_file"],
    attributes = pkg_attributes(mode = "0644"),
    tags = ["manual"],
)

pkg_install(
    name = "install",
    srcs = [
        ":constraints_files",
        ":integrations_bin_files",
        ":integrations_runtime_files",
    ],
    tags = ["manual"],
)
