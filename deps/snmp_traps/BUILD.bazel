load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_files")

package(default_visibility = ["//packages:__subpackages__"])

genrule(
    name = "snmp_traps_gz",
    srcs = ["@snmp_traps//:generated/dd_traps_db.json"],
    outs = ["dd_traps_db.json.gz"],
    cmd = "gzip -9 -c $< > $@",
)

pkg_files(
    name = "all_files",
    srcs = [":snmp_traps_gz"],
    attributes = pkg_attributes(
        group = "root",
        mode = "0644",
        owner = "root",
    ),
    prefix = select({
        "//:macos_arm64": "etc/conf.d/snmp.d/traps_db",
        "//:macos_x86_64": "etc/conf.d/snmp.d/traps_db",
        "//conditions:default": "etc/datadog-agent/conf.d/snmp.d/traps_db",
    }),
)

pkg_install(
    name = "install",
    srcs = [
        ":all_files",
    ],
)
