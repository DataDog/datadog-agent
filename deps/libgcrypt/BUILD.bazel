load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

configure_make(
    name="libgcrypt",
    lib_source = "@libgcrypt//:all",
    configure_options = [
        "--enable-maintainer-mode",
    ],
    deps = [
        "//deps/libgpg-error",
    ],
    out_shared_libs = select({
        "@platforms//os:linux": [
            "libgcrypt.so",
        ],
    }),
    visibility = ["//visibility:public"],
)



