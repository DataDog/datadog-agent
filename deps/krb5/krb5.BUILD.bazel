load("@@//bazel/rules:foreign_cc_shared_wrapper.bzl", "foreign_cc_shared_wrapper")
load("@@//bazel/rules/dd_packaging:dd_cc_packaged.bzl", "dd_cc_packaged")
load("@@//bazel/rules/dd_packaging:dd_collect_dependencies.bzl", "dd_collect_dependencies")
load("@bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")
load("@rules_license//rules:license.bzl", "license")
load("@rules_pkg//pkg:mappings.bzl", "pkg_files")

package(default_package_metadata = [":license"], default_visibility = ["//visibility:public"])

license(
    name = "license",
    license_kinds = ["@rules_license//licenses/spdx:BSD-2-Clause"],
    license_text = "NOTICE",
    visibility = ["//visibility:public"],
)

filegroup(
    name = "all_srcs",
    srcs = glob(["src/**/*"]),
)

# Maps lib_filter name -> {"version": ..., "prefix": ...}.
# - version: full version string ("" for unversioned plugins).
# - prefix: subdirectory under lib/ where the file lands ("" means directly in lib/).
LIBS = {
    "k5tls": {"version": "", "prefix": "krb5/plugins/tls"},
    "db2": {"version": "", "prefix": "krb5/plugins/kdb"},
    "test": {"version": "", "prefix": "krb5/plugins/preauth"},
    "spake": {"version": "", "prefix": "krb5/plugins/preauth"},
    "pkinit": {"version": "", "prefix": "krb5/plugins/preauth"},
    "otp": {"version": "", "prefix": "krb5/plugins/preauth"},
    "libcom_err": {"version": "3.0", "prefix": ""},
    "libgssapi_krb5": {"version": "2.2", "prefix": ""},
    "libgssrpc": {"version": "4.2", "prefix": ""},
    "libk5crypto": {"version": "3.1", "prefix": ""},
    "libkadm5clnt": {"version": "", "prefix": ""},
    "libkadm5clnt_mit": {"version": "12.0", "prefix": ""},
    "libkadm5srv": {"version": "", "prefix": ""},
    "libkadm5srv_mit": {"version": "12.0", "prefix": ""},
    "libkdb5": {"version": "10.0", "prefix": ""},
    "libkrad": {"version": "0.0", "prefix": ""},
    "libkrb5": {"version": "3.3", "prefix": ""},
    "libkrb5support": {"version": "0.1", "prefix": ""},
    "libverto": {"version": "0.0", "prefix": ""},
}

configure_make(
    name = "krb5",
    args = [
        "-j 16",
    ],
    configure_options = [
        "--without-keyutils",  # this would require additional deps/system deps, disable it
        "--without-system-verto",  # do not prefer libverto from the system, if installed
        "--without-libedit",  # we don't want to link with libraries outside of the install dir
        "--disable-static",
        "--with-crypto-impl=openssl",
        "--with-tls-impl=openssl",
        "--disable-nls",
    ],
    lib_source = ":all_srcs",
    deps = [
        "@openssl//:openssl",
    ],
    dynamic_deps = [
        "@openssl//:openssl_shared",
    ],
    out_binaries = [
        "kinit",
    ],
    out_shared_libs = [
        "{}/{}.so".format(spec["prefix"], libname) if spec["prefix"] else "{}.so".format(libname)
        for libname, spec in LIBS.items()
    ],
)

[
    foreign_cc_shared_wrapper(
        name = "{}_shared".format(libname),
        input = ":krb5",
        lib_filter = libname,
    )
    for libname in LIBS.keys()
]

[
    dd_cc_packaged(
        name = "{}_pkg".format(libname),
        input = ":{}_shared".format(libname),
        libname = libname,
        prefix = spec["prefix"],
        version = spec["version"],
        # kinit rides along with libkrb5 so its rpath gets patched via dd_cc_packaged.
        installed_executables = {":_bins": "bin"} if libname == "libkrb5" else {},
        # Headers ride along with libkrb5 so they flow through dd_collect_dependencies.
        installed_files = [":hdr_files"] if libname == "libkrb5" else [],
    )
    for libname, spec in LIBS.items()
]

filegroup(
    name = "_headers",
    srcs = [":krb5"],
    output_group = "include",
)

filegroup(
    name = "_bins",
    srcs = [":krb5"],
    output_group = "kinit",
)

# The rules_foreign_cc "include" output_group is a single tree artifact.
# pkg_files on a tree artifact produces a single "type: tree" manifest entry.
# When the openssl tree already claims dest "embedded" (a parent prefix),
# the krb5 tree at "embedded/include" is silently dropped by the deb builder.
#
# Fix: extract each header as an individual File artifact via genrule so that
# pkg_files produces "type: file" manifest entries. Individual file entries are
# not subject to tree-vs-tree dest-collision and survive packaging correctly.
#
# copy_to_directory is still used to remap the tree root from "krb5/include/"
# to a flat directory so the genrule can address files by relative path.
copy_to_directory(
    name = "_hdr_wrapped",
    srcs = [":_headers"],
    out = "krb5_hdrs",
    root_paths = ["krb5/include"],
)

# Extract every header from the tree artifact as an individual declared file.
# The full list is derived from the rules_foreign_cc build output and must be
# kept in sync if upstream krb5 adds new public headers.
genrule(
    name = "_hdr_files_gen",
    srcs = [":_hdr_wrapped"],
    outs = [
        "krb5_include/com_err.h",
        "krb5_include/gssapi.h",
        "krb5_include/kdb.h",
        "krb5_include/krad.h",
        "krb5_include/krb5.h",
        "krb5_include/profile.h",
        "krb5_include/verto-module.h",
        "krb5_include/verto.h",
        "krb5_include/gssapi/gssapi.h",
        "krb5_include/gssapi/gssapi_alloc.h",
        "krb5_include/gssapi/gssapi_ext.h",
        "krb5_include/gssapi/gssapi_generic.h",
        "krb5_include/gssapi/gssapi_krb5.h",
        "krb5_include/gssapi/mechglue.h",
        "krb5_include/gssrpc/auth.h",
        "krb5_include/gssrpc/auth_gss.h",
        "krb5_include/gssrpc/auth_gssapi.h",
        "krb5_include/gssrpc/auth_unix.h",
        "krb5_include/gssrpc/clnt.h",
        "krb5_include/gssrpc/netdb.h",
        "krb5_include/gssrpc/pmap_clnt.h",
        "krb5_include/gssrpc/pmap_prot.h",
        "krb5_include/gssrpc/pmap_rmt.h",
        "krb5_include/gssrpc/rename.h",
        "krb5_include/gssrpc/rpc.h",
        "krb5_include/gssrpc/rpc_msg.h",
        "krb5_include/gssrpc/svc.h",
        "krb5_include/gssrpc/svc_auth.h",
        "krb5_include/gssrpc/types.h",
        "krb5_include/gssrpc/xdr.h",
        "krb5_include/kadm5/admin.h",
        "krb5_include/kadm5/chpass_util_strings.h",
        "krb5_include/kadm5/kadm_err.h",
        "krb5_include/krb5/ccselect_plugin.h",
        "krb5_include/krb5/certauth_plugin.h",
        "krb5_include/krb5/clpreauth_plugin.h",
        "krb5_include/krb5/hostrealm_plugin.h",
        "krb5_include/krb5/kadm5_auth_plugin.h",
        "krb5_include/krb5/kadm5_hook_plugin.h",
        "krb5_include/krb5/kdcpolicy_plugin.h",
        "krb5_include/krb5/kdcpreauth_plugin.h",
        "krb5_include/krb5/krb5.h",
        "krb5_include/krb5/localauth_plugin.h",
        "krb5_include/krb5/locate_plugin.h",
        "krb5_include/krb5/plugin.h",
        "krb5_include/krb5/preauth_plugin.h",
        "krb5_include/krb5/pwqual_plugin.h",
    ],
    cmd = """
        src=$$(dirname $(location :_hdr_wrapped))
        out=$$(dirname $(RULEDIR)/krb5_include/com_err.h)
        mkdir -p $$out $$out/gssapi $$out/gssrpc $$out/kadm5 $$out/krb5
        cp $$src/krb5_hdrs/com_err.h $$out/
        cp $$src/krb5_hdrs/gssapi.h $$out/
        cp $$src/krb5_hdrs/kdb.h $$out/
        cp $$src/krb5_hdrs/krad.h $$out/
        cp $$src/krb5_hdrs/krb5.h $$out/
        cp $$src/krb5_hdrs/profile.h $$out/
        cp $$src/krb5_hdrs/verto-module.h $$out/
        cp $$src/krb5_hdrs/verto.h $$out/
        cp $$src/krb5_hdrs/gssapi/gssapi.h $$out/gssapi/
        cp $$src/krb5_hdrs/gssapi/gssapi_alloc.h $$out/gssapi/
        cp $$src/krb5_hdrs/gssapi/gssapi_ext.h $$out/gssapi/
        cp $$src/krb5_hdrs/gssapi/gssapi_generic.h $$out/gssapi/
        cp $$src/krb5_hdrs/gssapi/gssapi_krb5.h $$out/gssapi/
        cp $$src/krb5_hdrs/gssapi/mechglue.h $$out/gssapi/
        cp $$src/krb5_hdrs/gssrpc/auth.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/auth_gss.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/auth_gssapi.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/auth_unix.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/clnt.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/netdb.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/pmap_clnt.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/pmap_prot.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/pmap_rmt.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/rename.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/rpc.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/rpc_msg.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/svc.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/svc_auth.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/types.h $$out/gssrpc/
        cp $$src/krb5_hdrs/gssrpc/xdr.h $$out/gssrpc/
        cp $$src/krb5_hdrs/kadm5/admin.h $$out/kadm5/
        cp $$src/krb5_hdrs/kadm5/chpass_util_strings.h $$out/kadm5/
        cp $$src/krb5_hdrs/kadm5/kadm_err.h $$out/kadm5/
        cp $$src/krb5_hdrs/krb5/ccselect_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/certauth_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/clpreauth_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/hostrealm_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/kadm5_auth_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/kadm5_hook_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/kdcpolicy_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/kdcpreauth_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/krb5.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/localauth_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/locate_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/preauth_plugin.h $$out/krb5/
        cp $$src/krb5_hdrs/krb5/pwqual_plugin.h $$out/krb5/
    """,
)

pkg_files(
    name = "hdr_files",
    srcs = [":_hdr_files_gen"],
    strip_prefix = "krb5_include",
    prefix = "include",
)

# Single public entry point for "ship all krb5 libraries".
dd_collect_dependencies(
    name = "installed_libs",
    srcs = [":{}_pkg".format(libname) for libname in LIBS.keys()],
    visibility = ["@@//packages:__subpackages__"],
)
