# ---------------------------------------------------------------------------
# Set-b: per-check datadog_* wheels built from @integrations_core source.
#
# Pattern mirrors the datadog_checks_base_wheel genrule above.
# All integration checks are pure-Python (py3-none-any).
# Uses @python_3_13//:python3 (rather than current_py_toolchain) because
# some checks declare requires-python = ">=3.13" and pip rejects the wheel
# build if the interpreter is Python 3.12.
# ---------------------------------------------------------------------------

genrule(
    name = "active_directory_wheel",
    srcs = [
        "@integrations_core//:active_directory_srcs",
        "@integrations_core//:active_directory_pyproject",
        "@hatchling_whl//file",
        "@hatchling_editables_whl//file",
        "@hatchling_packaging_whl//file",
        "@hatchling_pathspec_whl//file",
        "@hatchling_pluggy_whl//file",
    ],
    outs = ["active_directory.whl"],
    cmd = """
        WHEELS=$$(mktemp -d)
        cp $(location @hatchling_whl//file)          $$WHEELS/hatchling-0.25.1-py2.py3-none-any.whl
        cp $(location @hatchling_editables_whl//file) $$WHEELS/editables-0.6-py3-none-any.whl
        cp $(location @hatchling_packaging_whl//file) $$WHEELS/packaging-26.2-py3-none-any.whl
        cp $(location @hatchling_pathspec_whl//file)  $$WHEELS/pathspec-1.1.1-py3-none-any.whl
        cp $(location @hatchling_pluggy_whl//file)    $$WHEELS/pluggy-1.6.0-py3-none-any.whl
        SRCDIR=$$(dirname $(location @integrations_core//:active_directory_pyproject))
        $(execpath @python_3_13//:python3) -m pip wheel "$$SRCDIR" \\
            --no-deps \\
            --no-index \\
            --find-links="$$WHEELS" \\
            --wheel-dir=$(@D) 2>&1
        mv $(@D)/datadog_active_directory-*.whl $(@D)/active_directory.whl
    """,
    tools = ["@python_3_13//:python3"],
)

