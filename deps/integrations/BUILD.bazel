# Bazel rules for building integrations-core wheels and assembling site-packages.
#
# Background:
#   Omnibus builds these wheels with `pip wheel . --no-deps --no-index` (hatchling backend)
#   against the integrations-core git source pinned in MODULE.bazel (@integrations_core).
#   The integration-check enabled set replicates the omnibus excluded_folders logic from
#   omnibus/config/software/datadog-agent-integrations-py3.rb lines 33-50 and the
#   `dda inv agent.collect-integrations` selection at recipe line 132.
#
# Site-packages layout:
#   (a) Third-party deps: @py_integrations_deps hub (set-a, PyPI/CDN wheels).
#       NOTE: BLOCKER — the integrations-core lockfile
#       (@integrations_core//:.deps/resolved/linux-x86_64_3.13.txt) contains a
#       ${INTEGRATIONS_WHEELS_STORAGE} template variable, and 28 of the 117 packages
#       are served from agent-int-packages.datadoghq.com (Datadog internal CDN),
#       not PyPI.  The @py_integrations_deps hub cannot be consumed verbatim until
#       the URL template is substituted and the internal packages are re-sourced.
#       See MODULE.bazel for the TODO and resolution options.
#
#   (b) datadog-* wheels: built from @integrations_core source with pip+hatchling.
#       datadog_checks_base is now wired and builds successfully.
#       Per-check enabled-checks wheels are still stubbed (see TODO below).
#
# TODO(4b-step0): Prerequisite — 3.13 toolchain retarget in MODULE.bazel is done;
#                 INTEGRATION_PYTHON_VERSION = "3.13" is already set.
# set-a: Third-party wheels from the integrations-core lockfile are now wired via
#        http_file rules in MODULE.bazel + rename genrules below.
# set-b: Per-check wheels are now built from @integrations_core source via genrules
#        below. Excluded: datadog_checks_base (built above), datadog_checks_dev,
#        datadog_checks_tests_helper, docker_daemon, ibm_ace, ibm_mq (arm exclusions),
#        ddev (developer tool).

load("@@//compliance/rules:purl.bzl", "purl_for_generic")
load("@package_metadata//rules:package_metadata.bzl", "package_metadata")
load("@rules_license//rules:license.bzl", "license")
load("@rules_pkg//pkg:mappings.bzl", "REMOVE_BASE_DIRECTORY", "pkg_attributes", "pkg_filegroup", "pkg_files", "strip_prefix")
load(":whl_extract.bzl", "multi_whl_extract", "whl_entry_points")

package(
    default_package_metadata = [":integrations_metadata"],
    default_visibility = ["//packages:__subpackages__"],
)

license(
    name = "integrations_license",
    license_kinds = ["@rules_license//licenses/spdx:BSD-3-Clause"],
    license_text = "@integrations_core//:LICENSE",
    visibility = ["//visibility:public"],
)

package_metadata(
    name = "integrations_metadata",
    attributes = [":integrations_license"],
    purl = purl_for_generic(
        download_url = "https://github.com/DataDog/integrations-core/archive/refs/tags/{version}.tar.gz",
        package = "datadog-agent-integrations-py3",
        version = "ddev-v16.1.1",
    ),
)

# ---------------------------------------------------------------------------
# (b) datadog_checks_base wheel — built from integrations-core source.
#
# Omnibus invocation (recipe line 109):
#   python -m pip wheel . --no-deps --no-index --wheel-dir=<wheel_build_dir>
#   (cwd = integrations-core/datadog_checks_base)
#   with PIP_FIND_LINKS pointing at hatchling downloaded offline.
# ---------------------------------------------------------------------------
genrule(
    name = "datadog_checks_base_wheel",
    srcs = [
        "@integrations_core//:datadog_checks_base_srcs",
        "@integrations_core//:datadog_checks_base_pyproject",
        "@hatchling_whl//file",
        "@hatchling_editables_whl//file",
        "@hatchling_packaging_whl//file",
        "@hatchling_pathspec_whl//file",
        "@hatchling_pluggy_whl//file",
    ],
    outs = ["datadog_checks_base.whl"],
    # datadog_checks_base is pure-Python (py3-none-any), so the interpreter
    # version used to run pip does not affect the output wheel.
    # current_py_toolchain resolves to the default rules_python interpreter
    # (Python 3.12) and exposes $(PYTHON3) as a make-variable.
    # The wheel deps use http_file rules (not pip.parse hub aliases) so they
    # are configuration-independent and do not require a matching Python
    # version flag in the build configuration.
    #
    # TODO(4b-step3-c-extensions): For set-a and enabled-checks wheels that
    # have C extensions, the 3.13 ABI is required. Those wheels must use
    # @cpython//:python_unix_runnable (the hermetic 3.13 interpreter with
    # stdlib and libpython3.so staged as data deps) rather than this approach.
    # http_file downloads files as a fixed name "downloaded", so we rename
    # each to its proper .whl name when staging into the find-links directory.
    cmd = """
        WHEELS=$$(mktemp -d)
        cp $(location @hatchling_whl//file)          $$WHEELS/hatchling-0.25.1-py2.py3-none-any.whl
        cp $(location @hatchling_editables_whl//file) $$WHEELS/editables-0.6-py3-none-any.whl
        cp $(location @hatchling_packaging_whl//file) $$WHEELS/packaging-26.2-py3-none-any.whl
        cp $(location @hatchling_pathspec_whl//file)  $$WHEELS/pathspec-1.1.1-py3-none-any.whl
        cp $(location @hatchling_pluggy_whl//file)    $$WHEELS/pluggy-1.6.0-py3-none-any.whl
        SRCDIR=$$(dirname $(location @integrations_core//:datadog_checks_base_pyproject))
        $(PYTHON3) -m pip wheel "$$SRCDIR" \
            --no-deps \
            --no-index \
            --find-links="$$WHEELS" \
            --wheel-dir=$(@D) 2>&1
        mv $(@D)/datadog_checks_base-*.whl $(@D)/datadog_checks_base.whl
    """,
    toolchains = ["@rules_python//python:current_py_toolchain"],
)

# ---------------------------------------------------------------------------
# lazy_loader — runtime dependency of datadog_checks_base/__init__.py.
#
# lazy_loader is a pure-Python package (lazy_loader-0.4-20260226183451-py3-none-any.whl)
# that must be present in site-packages for `import datadog_checks.base`
# to succeed.  It cannot be bundled inside datadog_checks_base.whl itself
# (that wheel is built with --no-deps), so it is extracted alongside
# datadog_checks_base into the same site_packages_tree below.
#
# http_file downloads files as a generic "downloaded" name without the .whl
# extension.  multi_whl_extract requires allow_files=[".whl"], so we use a
# rename genrule to give the file the proper .whl extension first.
# ---------------------------------------------------------------------------
genrule(
    name = "lazy_loader_whl_renamed",
    srcs = ["@lazy_loader_whl//file"],
    outs = ["lazy_loader-0.4-20260226183451-py3-none-any.whl"],
    cmd = "cp $< $@",
)

# ---------------------------------------------------------------------------
# site_packages_tree — single merged TreeArtifact for all site-packages wheels.
#
# IMPORTANT: rules_pkg uses a dest-keyed dict (content_map) when building
# manifests.  Two pkg_files entries that both use REMOVE_BASE_DIRECTORY with
# the same prefix map to the *same* dest key; the second silently overwrites
# the first, so only the last wheel lands in the package.  The old approach
# of separate whl_extract + pkg_files per wheel therefore only ever included
# lazy_loader (the last entry) and silently dropped datadog_checks_base.
#
# multi_whl_extract extracts all wheels into ONE declared directory so that a
# SINGLE pkg_files entry covers the entire site-packages tree, eliminating the
# collision.  The same approach must be used when set-a and enabled-checks
# wheels are added (see TODOs below).
# ---------------------------------------------------------------------------
multi_whl_extract(
    name = "site_packages_tree",
    python = "@python_3_13//:python3",
    whls = [
        ":datadog_checks_base_wheel",
        ":lazy_loader_whl_renamed",
