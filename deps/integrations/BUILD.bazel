# Build a pympler-0.7 wheel from the PyPI source tarball using setuptools (offline).
# Pympler 0.7 only has a source distribution on PyPI; no pre-built wheel exists.
# We copy the downloaded tarball to a named file so pip recognises it as a local path.
genrule(
    name = "int_whl_pympler_renamed",
    srcs = [
        "@int_whl_pympler_source//file",
        "@int_whl_setuptools//file",
    ],
    outs = ["Pympler-0.7-py3-none-any.whl"],
    cmd = """
        WHEELS=$$(mktemp -d)
        cp $(location @int_whl_setuptools//file) $$WHEELS/setuptools-82.0.1-20260522142604-py3-none-any.whl
        SRCTAR="$$WHEELS/Pympler-0.7.tar.gz"
        cp $(location @int_whl_pympler_source//file) "$$SRCTAR"
        $(execpath @python_3_13//:python3) -m pip wheel "$$SRCTAR" \\
            --no-deps \\
            --no-index \\
            --find-links="$$WHEELS" \\
            --wheel-dir=$(@D) 2>&1
        mv $(@D)/[Pp]ympler-*.whl $(@D)/Pympler-0.7-py3-none-any.whl
    """,
    tools = ["@python_3_13//:python3"],
)

