load("@rules_cc//cc:defs.bzl", "cc_import")
load("@rules_license//rules:license.bzl", "license")
load("@rules_license//rules:license_kind.bzl", "license_kind")
load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_filegroup", "pkg_files", "pkg_mklink")
load("//bazel/rules:foreign_cc_shared_wrapper.bzl", "foreign_cc_shared_wrapper")
load("//bazel/rules/dd_packaging:dd_cc_packaged.bzl", "dd_cc_packaged")
load("//bazel/rules/dd_packaging:dd_collect_dependencies.bzl", "dd_collect_dependencies")

package(
    default_package_metadata = [":license"],
    default_visibility = ["//visibility:public"],
)

SO_VERSION = "18.3"

SO_FULL_VERSION = "3.1"

SO_FILENAME = "libmsodbcsql-%s.so.%s" % (SO_VERSION, SO_FULL_VERSION)

SO_LINK_NAME = "libmsodbcsql-%s.so" % SO_VERSION

# I couldn't find a license kind in sdpx
# so had to create a new kind.
# Also, this license agreement isn't available
# under any URL.
license_kind(
    name = "msodbcsql18_eula_license",
    conditions = [],
)

license(
    name = "license",
    license_kinds = [":msodbcsql18_eula_license"],
    license_text = "LICENSE.txt",
    visibility = ["//visibility:public"],
)

genrule(
    name = "extract",
    srcs = select({
        "//:linux_x86_64": ["@msodbcsql18_deb_amd64//file"],
        "//:linux_arm64": ["@msodbcsql18_deb_arm64//file"],
    }),
    outs = [
        SO_FILENAME,
        "msodbcsqlr18.rll",
    ],
    cmd = """
        set -e

        # Extract deb package
        $(location @libarchive//tar) -xOf $(SRCS) 'data.tar.*' | $(location @libarchive//tar) -xf -

        # Copy the files we need
        cp opt/microsoft/msodbcsql18/lib64/{so_filename} $(location {so_filename})
        cp opt/microsoft/msodbcsql18/share/resources/en_US/msodbcsqlr18.rll $(location msodbcsqlr18.rll)
    """.format(so_filename = SO_FILENAME),
    target_compatible_with = select({
        "@platforms//os:linux": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
    tools = ["@libarchive//tar"],
    visibility = ["//visibility:public"],
)

# Wrap the prebuilt .so as a CcInfo so it can flow through dd_cc_packaged.
cc_import(
    name = "msodbcsql_import",
    shared_library = SO_FILENAME,
    target_compatible_with = select({
        "@platforms//os:linux": [],
        "//conditions:default": ["@platforms//:incompatible"],
    }),
)

# cc_import exposes the .so plus an auto-generated interface symlink in
# DefaultInfo; rewrite_rpath would patch both. foreign_cc_shared_wrapper
# filters down to just the dynamic library via CcInfo's linker_inputs.
foreign_cc_shared_wrapper(
    name = "msodbcsql_shared",
    input = ":msodbcsql_import",
    lib_filter = "libmsodbcsql-%s" % SO_VERSION,
)

pkg_files(
    name = "resource_files",
    srcs = ["msodbcsqlr18.rll"],
    prefix = "msodbcsql/share/resources/en_US",
)

pkg_files(
    name = "license_files",
    srcs = ["LICENSE.txt"],
    # TODO(ABLD-351): Review location
    prefix = "msodbcsql/share/doc/msodbcsql18",
)

# The unversioned linker-name symlink lives in a sibling directory of the
# real .so so it cannot be expressed through so_symlink's same-dir chain.
# Emit it manually and pass it through installed_files so it flows through
# dd_collect_dependencies alongside the rpath-patched library.
pkg_mklink(
    name = "_lib_symlink",
    attributes = pkg_attributes(mode = "0755"),
    link_name = "msodbcsql/lib/%s" % SO_LINK_NAME,
    target = "../lib64/%s" % SO_FILENAME,
)

pkg_filegroup(
    name = "lib_symlink",
    srcs = [":_lib_symlink"],
)

# version="" skips so_symlink's symlink chain (real + soname + linker-name in
# the same dir): msodbcsql ships only the real .so under lib64/ plus a
# separate cross-directory linker-name symlink under lib/.
dd_cc_packaged(
    name = "msodbcsql_pkg",
    dest_dir = "msodbcsql/lib64",
    input = ":msodbcsql_shared",
    installed_files = [
        ":lib_symlink",
        ":license_files",
        ":resource_files",
    ],
)

# Single public entry point for "ship msodbcsql18 and its runtime deps".
# libodbcinst.so.2 is a runtime dependency of libmsodbcsql, included
# explicitly because cc_import doesn't expose dynamic_deps for the aspect
# to discover. The embedded/ prefix is applied at the consumption site.
dd_collect_dependencies(
    name = "installed_libs",
    srcs = [
        ":msodbcsql_pkg",
        "@unixodbc//:odbcinst_pkg",
    ],
    visibility = ["//packages:__subpackages__"],
)
