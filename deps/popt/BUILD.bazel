load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

configure_make(
    name="popt",
    lib_source = "@popt//:all",
    configure_options = [
        "--disable-static",
        "--disable-nls",
    ],
    out_shared_libs = select({
        "@platforms//os:linux": [
            "libpopt.so",
        ],
    }),
    visibility = ["//visibility:public"],
)


