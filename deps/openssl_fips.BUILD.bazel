load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")
load("@rules_python//python:defs.bzl", "py_binary")

package(default_visibility = ["//visibility:public"])

ENABLE_FIPS_CONFIG = [
    "--libdir=lib",
    "enable-fips",
]

filegroup(
    name = "all",
    srcs = glob(
        ["**"],
        exclude = ["BUILD.bazel"],
    ),
)

FIPS_WIN = "fips.dll"

FIPS_LINUX = "fips.so"

configure_make(
    name = "openssl_fips",
    configure_command = "Configure",
    configure_in_place = select({
        "@platforms//os:windows": True,
        "//conditions:default": False,
    }),
    configure_options = select({
        "@platforms//os:windows": [
            "mingw64",
        ],
        "//conditions:default": [],
    }) + ENABLE_FIPS_CONFIG,
    configure_prefix = select({
        "@platforms//os:windows": "perl",
        "//conditions:default": "",
    }),
    copts = ["-O2"],
    lib_source = ":all",
    resource_size = "enormous",
    out_shared_libs = select({
        "@platforms//os:linux": [
            "ossl-modules/" + FIPS_LINUX,
        ],
        "@platforms//os:windows": [
            "ossl-modules/" + FIPS_WIN,
        ],
        "//conditions:default": [],
    }),
    # We don't build FIPS for macOS, therefore, incompatible.
    target_compatible_with = select({
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    targets = [
        "",
        "install_fips",
    ],
)

filegroup(
    name = "fips_provider",
    srcs = [":openssl_fips"],
    output_group = select({
        "@platforms//os:windows": FIPS_WIN,
        "@platforms//os:linux": FIPS_LINUX,
        "//conditions:default": "",
    }),
)

filegroup(
    name = "gendir",
    srcs = [":openssl_fips"],
    output_group = "gen_dir",
)

genrule(
    name = "fipsinstall_sh",
    srcs = ["fipsinstall.sh"],
    outs = ["fipsinstall.sh.out"],
    cmd = "$(execpath :_configure_fips_tool) --input $< --output $@ '{{install_dir}}=$(INSTALL_DIR)/embedded'",
    tools = [":_configure_fips_tool"],
    toolchains = ["@@//:install_dir"],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

genrule(
    name = "openssl_cnf_tmp",
    srcs = ["openssl.cnf.tmp"],
    outs = ["openssl.cnf.tmp.out"],
    cmd = select({
        "@platforms//os:windows": "$(execpath :_configure_fips_tool) --input $< --output $@ '{{embedded_ssl_dir}}=C:/Program Files/Datadog/Datadog Agent/embedded3/ssl'",
        "//conditions:default": "$(execpath :_configure_fips_tool) --input $< --output $@ '{{embedded_ssl_dir}}=$(INSTALL_DIR)/embedded/ssl'",
    }),
    tools = [":_configure_fips_tool"],
    toolchains = ["@@//:install_dir"],
)

# configure_fips.py also supports a legacy --destdir interface for manual use.
py_binary(
    name = "_configure_fips_tool",
    srcs = ["configure_fips.py"],
    main = "configure_fips.py",
)
