"""Static SPDX license text files shipped verbatim in the agent LICENSES/ directory.

These files correspond to the THIRD-PARTY-* files that omnibus downloads from
https://dd-agent-omnibus.s3.amazonaws.com/licenses/ at build time (see
omnibus/licensing.rb STANDARD_LICENSES map). The Bazel build checks these files
in statically so the build is hermetic.
"""

load("@rules_pkg//pkg:mappings.bzl", "pkg_files", "strip_prefix")

pkg_files(
    name = "all_files",
    srcs = [
        "THIRD-PARTY-0BSD",
        "THIRD-PARTY-Apache-2.0",
        "THIRD-PARTY-BSD-2-Clause",
        "THIRD-PARTY-BSD-3-Clause",
        "THIRD-PARTY-ISC",
        "THIRD-PARTY-MIT",
        "THIRD-PARTY-MPL-2.0",
    ],
    prefix = "LICENSES",
    strip_prefix = strip_prefix.from_pkg(),
    visibility = ["//packages:__subpackages__"],
)
