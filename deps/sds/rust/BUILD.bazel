load("@rules_rust//rust:defs.bzl", "rust_shared_library", "rust_static_library")

# Builds libdd_sds from the crates.io `dd-sensitive-data-scanner` crate (with the
# `dd_sds_go` FFI feature, resolved via the root Cargo workspace -> @crates).
# SDS is unsupported on Windows: marking these incompatible there propagates
# through the //deps/sds:dd_sds cdeps edge so the whole sds chain is skipped in
# `//...` on Windows instead of failing to link.

_SDS_COMPAT = select({
    "@platforms//os:windows": ["@platforms//:incompatible"],
    "//conditions:default": [],
})

# Static archive (libdd_sds.a). Used by //deps/sds:dd_sds for the cgo binding:
# static linking pulls in the referenced FFI symbols directly, avoiding any
# shared-library dead-strip concerns and removing the need to ship a runtime .so.
rust_static_library(
    name = "dd_sds_static",
    srcs = ["src/lib.rs"],
    crate_name = "dd_sds",
    crate_root = "src/lib.rs",
    edition = "2024",
    target_compatible_with = _SDS_COMPAT,
    visibility = ["//visibility:public"],
    deps = ["@crates//:dd-sensitive-data-scanner"],
)

# Shared library (libdd_sds.so / .dylib). Produced for the omnibus/Docker path
# (see tasks/sds.py), which ships it under embedded/lib and links it at runtime.
rust_shared_library(
    name = "dd_sds_shared",
    srcs = ["src/lib.rs"],
    crate_name = "dd_sds",
    crate_root = "src/lib.rs",
    edition = "2024",
    target_compatible_with = _SDS_COMPAT,
    visibility = ["//visibility:public"],
    deps = ["@crates//:dd-sensitive-data-scanner"],
)
