load("@//bazel/rules:foreign_cc_shared_wrapper.bzl", "foreign_cc_shared_wrapper")
load("@//bazel/rules/dd_packaging:dd_cc_packaged.bzl", "dd_cc_packaged")
load("@//deps/openssl:version.bzl", "OPENSSL_VERSION")
load("@bazel_lib//lib:copy_to_directory.bzl", "copy_to_directory")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")
load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_filegroup", "pkg_files")

# This should be private. We can fix it in another PR
package(default_visibility = ["//visibility:public"])

filegroup(
    name = "all_srcs",
    srcs = glob(["**"], exclude = ["BUILD.bazel"]),
)

config_setting(
    name = "fips_windows",
    constraint_values = [
        "@platforms//os:windows",
    ],
    flag_values = {"@@//packages/agent:flavor": "fips"},
)

DEFAULT_CONFIG = [
    "no-docs",
    "no-idea",
    "no-mdc2",
    "no-rc5",
    "shared",
    "no-ssl3",
    "no-gost",
    "no-filenames",
    "--libdir=lib",
    # This instructs openssl to dynamically *load* zlib at runtime, not
    # dynamically *link* with it at build time
    "zlib-dynamic",
]

# In order to expose libs to dd_cc_packaged
# we need to define filegroups that handle
# output_group attributes generated by configure_make.
# Unfortunately, it creates one output_group per each
# library file. Thus, these constants.
WIN_LIBSSL = "libssl-3-x64.dll"
WIN_LIBCRYPTO = "libcrypto-3-x64.dll"

LINUX_LIBSSL = "libssl.so"
LINUX_LIBCRYPTO = "libcrypto.so"

MACOS_LIBSSL = "libssl.dylib"
MACOS_LIBCRYPTO = "libcrypto.dylib"

configure_make(
    name = "openssl",
    configure_prefix = select({
        "@platforms//os:windows": "perl",
        "//conditions:default": "",
    }),
    configure_in_place = select({
        "@platforms//os:windows": True,
        "//conditions:default": False,
    }),
    configure_command = select({
        "@platforms//os:linux": "config",
        "@platforms//os:macos": "Configure",
        "@platforms//os:windows": "Configure",
    }),
    configure_options = select({
        "@//:macos_arm64": [
            "darwin64-arm64-cc",
        ] + DEFAULT_CONFIG,
        "@//:macos_x86_64": [
            "darwin64-x86_64-cc",
        ] + DEFAULT_CONFIG,
        # We build openssl for Windows without zlib.
        # Hence, excluding last DEFAULT_CONFIG entry.
        "@platforms//os:windows": [
            "mingw64",
            "no-zlib",
            "no-uplink",
        ] + DEFAULT_CONFIG[:-1],
        "//conditions:default": DEFAULT_CONFIG,
    }) + select({
        ":fips_windows": [
            "-DOSSL_WINCTX=datadog-fips-agent",
            "--openssldir='C:/Program Files/Datadog/Datadog Agent/embedded3/ssl'",
        ],
        "//conditions:default": [],
    }) + select({
        # Set OPENSSLDIR and ENGINESDIR/MODULESDIR (via --runtime-dir) to their
        # actual runtime locations at configure time, so no binary patching is
        # needed after the build.  $(INSTALL_DIR) is provided by //:install_dir
        # via the toolchains attribute below.
        "@platforms//os:windows": [],
        "//conditions:default": [
            "--runtime-openssldir=$(INSTALL_DIR)/embedded/ssl",
            "--runtime-dir=$(INSTALL_DIR)/embedded",
        ],
    }),
    env = select({
        "@platforms//os:macos": {
            # For some reason AR is set to libtool on macos
            # and that breaks the build.
            "AR": "ar",
        },
        "//conditions:default": {},
    }),
    # $(INSTALL_DIR) is the make-variable provided by //:install_dir.
    toolchains = ["@@//:install_dir"],
    lib_source = ":all_srcs",
    resource_size = "enormous",
    out_include_dir = "include",
    out_interface_libs = select({
        "@platforms//os:windows": [
            "libssl.lib",
            "libcrypto.lib",
        ],
        "//conditions:default": [],
    }),
    out_shared_libs = select({
        "@platforms//os:linux": [
            LINUX_LIBSSL,
            LINUX_LIBCRYPTO,
        ],
        "@platforms//os:macos": [
            MACOS_LIBSSL,
            MACOS_LIBCRYPTO,
        ],
        "//conditions:default": [],
    }),
    out_data_dirs = select({
        # ssl/ is empty on Windows because --openssldir above points outside the sandbox; rules_python 1.9.0 skips
        # empty dirs when copying runfiles to a temp dir for `bazel run`, causing FileNotFoundError in pkg_install.
        ":fips_windows": ["lib/ossl-modules", "lib/engines-3"],  #TODO(agent-build): remove special case
        "@@//packages/agent:fips_flavor": ["ssl", "lib/ossl-modules", "lib/engines-3"],
        "@platforms//os:windows": [],
        "//conditions:default": ["lib/ossl-modules", "lib/engines-3"],
    }),
    # For whatever reason rules_foreign_cc does not respect
    # out_dll_dir parameter and tries to find Windows DLLs in
    # lib instead of bin. Technically, those are binaries,
    # hence, we can treat them as such.
    out_binaries = select({
        "@platforms//os:windows": [
            WIN_LIBSSL,
            WIN_LIBCRYPTO,
            "openssl.exe",
        ],
        "//conditions:default": ["openssl"],
    }),
    deps = select({
        "//conditions:default": [
            "@zlib//:zlib",
        ],
        "@platforms//os:windows": [],
    }),
    copts = ["-O2"] + select({
        "@platforms//os:windows": ["-DSIO_UDP_NETRESET=_WSAIOW\\(IOC_VENDOR,15\\)"],
        "//conditions:default": [],
    }),
    targets = ["depend", "", "install_sw", "install_ssldirs"],
    postfix_script = select({
        # Rename .dll.a files into the appropriate extension for import libraries (.lib)
        "@platforms//os:windows": """
        mv $$INSTALLDIR/lib/libcrypto.dll.a $$INSTALLDIR/lib/libcrypto.lib
        mv $$INSTALLDIR/lib/libssl.dll.a $$INSTALLDIR/lib/libssl.lib
        """,
        "//conditions:default": "",
    }),
)

foreign_cc_shared_wrapper(
    name = "openssl_shared",
    input = ":openssl",
)

foreign_cc_shared_wrapper(
    name = "libssl_shared",
    input = ":openssl",
    lib_filter = "libssl",
)

foreign_cc_shared_wrapper(
    name = "libcrypto_shared",
    input = ":openssl",
    lib_filter = "libcrypto",
)

# On Windows, lib_filter fails because DLLs live in out_binaries and
# rules_foreign_cc leaves LibraryToLink.dynamic_library = None.
# openssl_shared (no lib_filter) succeeds silently with empty DefaultInfo;
# the DLLs are supplied explicitly via installed_executables instead.
alias(
    name = "_libssl_shared_input",
    actual = select({
        "@platforms//os:windows": ":openssl_shared",
        "//conditions:default": ":libssl_shared",
    }),
)

alias(
    name = "_libcrypto_shared_input",
    actual = select({
        "@platforms//os:windows": ":openssl_shared",
        "//conditions:default": ":libcrypto_shared",
    }),
)

dd_cc_packaged(
    name = "libssl_shared_pkg",
    input = ":_libssl_shared_input",
    version = OPENSSL_VERSION,
    libname = "libssl",
)

pkg_files(
    name = "_fips_openssl_cnf",
    srcs = ["@openssl_fips//:openssl_cnf_tmp"],
    prefix = "ssl",
    # Bazel genrule adds .out suffix; strip it so fipsinstall.sh finds openssl.cnf.tmp.
    renames = {"@openssl_fips//:openssl_cnf_tmp": "openssl.cnf.tmp"},
    attributes = pkg_attributes(mode = "0644"),
)

pkg_files(
    name = "_fips_fipsinstall_sh",
    srcs = ["@openssl_fips//:fipsinstall_sh"],
    prefix = "bin",
    # Bazel genrule adds .out suffix; strip it so the post-install hook finds fipsinstall.sh.
    renames = {"@openssl_fips//:fipsinstall_sh": "fipsinstall.sh"},
    attributes = pkg_attributes(mode = "0755"),
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)

pkg_filegroup(
    name = "_fips_extra_files",
    srcs = [":_fips_openssl_cnf"] + select({
        "@platforms//os:windows": [],
        "//conditions:default": [":_fips_fipsinstall_sh"],
    }),
)

dd_cc_packaged(
    name = "libcrypto_shared_pkg",
    input = ":_libcrypto_shared_input",
    version = OPENSSL_VERSION,
    libname = "libcrypto",
    installed_files = [":openssl_files"] + select({
        "@@//packages/agent:fips_flavor": [":_fips_extra_files"],
        "//conditions:default": [],
    }),
    installed_executables = {
        ":openssl_binary": "bin",
    } | select({
        # On Windows, DLLs are in out_binaries so LibraryToLink.dynamic_library is
        # None; supply them explicitly so _dd_packaged_files_rule installs them.
        "@platforms//os:windows": {
            ":libcrypto_shared_file": "bin",
            ":libssl_shared_file": "bin",
        },
        "//conditions:default": {},
    }) | select({
        # Engines, modules, and fips provider are only installed for FIPS builds.
        # Non-FIPS Windows has out_data_dirs = [] so the engines/modules output groups
        # do not exist there; non-FIPS non-Windows builds don't need them either.
        "@@//packages/agent:fips_flavor": {
            ":_engines": "lib",
            ":_ossl_modules": "lib",
            "@openssl_fips//:fips_provider": "lib/ossl-modules",
        },
        "//conditions:default": {},
    }),
)

# The dynamic library built with configure/make. Even though the name
# is libssl.so, it is not actually the same folder, so we can have our
# own libssl.so shadow it.
filegroup(
    name = "libssl_shared_file",
    srcs = [":openssl"],
    output_group = select({
        "@platforms//os:windows": WIN_LIBSSL,
        "@platforms//os:macos": MACOS_LIBSSL,
        "@platforms//os:linux": LINUX_LIBSSL,
    }),
)

filegroup(
    name = "libcrypto_shared_file",
    srcs = [":openssl"],
    output_group = select({
        "@platforms//os:windows": WIN_LIBCRYPTO,
        "@platforms//os:macos": MACOS_LIBCRYPTO,
        "@platforms//os:linux": LINUX_LIBCRYPTO,
    }),
)

filegroup(
    name = "openssl_binary",
    srcs = [":openssl"],
    output_group = select({
        "@platforms//os:windows": "openssl.exe",
        "//conditions:default": "openssl",
    }),
)

filegroup(
    name = "_ossl_modules",
    srcs = [":openssl"],
    output_group = "ossl-modules",
)

filegroup(
    name = "_engines",
    srcs = [":openssl"],
    output_group = "engines-3",
)

# Strip all executables (binaries, shared libs, engines, modules) from the
# openssl install tree so that openssl_files contains only the supplementary
# files (headers, pkgconfig, ssl/).  Path-glob exclusion via copy_to_directory
# is used because pkg_files label-based excludes cannot exclude TreeArtifacts
# produced by out_data_dirs.
copy_to_directory(
    name = "_openssl_extra_files",
    srcs = [":openssl"],
    root_paths = ["openssl"],
    out = "openssl_extra",
    exclude_srcs_patterns = [
        # Binary handled via installed_executables
        "bin/**",
        # Shared + static libs handled by libssl_shared_pkg / libcrypto_shared_pkg
        "lib/libssl*",
        "lib/libcrypto*",
        # Engines are rpath-patched and installed via installed_executables
        "lib/engines-3/**",
        # ossl-modules (legacy.so etc.) also need rpath patching and are
        # installed via installed_executables; fips.so comes from openssl_fips
        "lib/ossl-modules/**",
    ],
)

pkg_files(
    name = "openssl_files",
    srcs = [":_openssl_extra_files"],
    strip_prefix = "openssl_extra",
)
