load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

configure_make(
    name="libxcrypt",
    lib_source = "@libxcrypt//:all",
    configure_options = [
        "--disable-obsolete-api",
        "--disable-werror",
        "--enable-shared",
        "--disable-static",
        # https://github.com/besser82/libxcrypt/issues/181
        "--disable-symvers",
    ],
    deps = [
        "@zlib//:zlib",
        "@bzip2//:bz2",
        "@xz//:lzma",
    ],
    out_shared_libs = select({
        "@platforms//os:linux": [
            "libcrypt.so",
            "libcrypt.so.2",
            "libcrypt.so.2.0.0",
        ],
    }),
    visibility = ["//visibility:public"],
    # Workaround for https://github.com/bazel-contrib/rules_foreign_cc/issues/1160
    env = {
        "LD": "",
    },
)

