load("@package_metadata//rules:package_metadata.bzl", "package_metadata")
load("@rules_license//rules:license.bzl", "license")
load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "pkg_files", "strip_prefix")

package(
    default_package_metadata = [":package_metadata"],
    default_visibility = [
        "@@//compliance:__subpackages__",
        "@@//deps/openscap:__pkg__",
        "@@//packages:__subpackages__",
    ],
)

VERSION = "1.4.2"

PURL = "pkg:generic/openscap@{version}?download_url=https://github.com/OpenSCAP/openscap/releases/download/{version}/openscap-{version}.tar.gz".format(version = VERSION)

package_metadata(
    name = "package_metadata",
    attributes = [
        ":license",
    ],
    purl = PURL,
)

license(
    name = "license",
    license_kinds = ["@rules_license//licenses/spdx:LGPL-3.0-or-later"],
    license_text = "COPYING",
    visibility = ["//visibility:public"],
)

# This is temporary. Eventually there will be a cc_library for openscap.
filegroup(
    name = "all_deps",
    srcs = [
        "@libyaml",
        "@lua//:liblua",
        "@acl",
        "@attr",
        "@bzip2//:bz2",
        "@gcrypt",
        "@gpg-error",
        "@libpcap//:pcap",
        "@libsepol//:sepol",
        "@libxml2",
        "@libxslt",
        "@nghttp2",
        "@pcre2",
        "@popt",
        "@zstd",
    ],
)
