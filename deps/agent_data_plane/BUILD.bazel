"""Agent Data Plane (ADP) - prebuilt binary shipped alongside the agent.

Replaces omnibus/config/software/datadog-agent-data-plane.rb.
"""

load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_filegroup", "pkg_files", "strip_prefix")

package(default_visibility = ["//packages:__subpackages__"])

_ARCHIVE_BY_CONDITION = {
    "//packages/agent:linux_x86_64_fips": "agent_data_plane_fips_linux_amd64",
    "//packages/agent:linux_arm64_fips": "agent_data_plane_fips_linux_arm64",
    "//packages/agent:windows_x86_64_fips": "agent_data_plane_windows_amd64_fips",
    "//:linux_x86_64": "agent_data_plane_linux_amd64",
    "//:linux_arm64": "agent_data_plane_linux_arm64",
    "//packages/agent:macos_x86_64_base": "agent_data_plane_darwin_amd64",
    "//packages/agent:macos_arm64_base": "agent_data_plane_darwin_arm64",
    "//:windows_x86_64": "agent_data_plane_windows_amd64",
}

alias(
    name = "archive_binary",
    actual = select({
        condition: "@{}//:binary".format(repo)
        for condition, repo in _ARCHIVE_BY_CONDITION.items()
    }),
)

alias(
    name = "archive_license_files",
    actual = select({
        condition: "@{}//:license_files".format(repo)
        for condition, repo in _ARCHIVE_BY_CONDITION.items()
    }),
)

alias(
    name = "archive_license_3rdparty",
    actual = select({
        condition: "@{}//:license_3rdparty".format(repo)
        for condition, repo in _ARCHIVE_BY_CONDITION.items()
    }),
)

pkg_files(
    name = "binary_files",
    srcs = [":archive_binary"],
    attributes = pkg_attributes(mode = "0755"),
    prefix = select({
        "@platforms//os:windows": "bin/agent",
        "//conditions:default": "embedded/bin",
    }),
)

pkg_files(
    name = "license_files",
    srcs = [
        ":archive_license_3rdparty",
        ":archive_license_files",
    ],
    prefix = "LICENSES",
    renames = {
        ":archive_license_3rdparty": "LICENSE-agent-data-plane-3rdparty.csv",
    },
    strip_prefix = strip_prefix.files_only(),
)

pkg_filegroup(
    name = "all_files",
    srcs = [
        ":binary_files",
        ":license_files",
    ],
)
