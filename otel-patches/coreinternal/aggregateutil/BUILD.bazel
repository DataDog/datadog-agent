        "aggregate_test.go",
        "type_test.go",
    ],
    embed = [":aggregateutil"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//require",
        "@io_opentelemetry_go_collector_pdata//pcommon",
        "@io_opentelemetry_go_collector_pdata//pmetric",
    ],
)
