load("@@rules_go+//go:def.bzl", "go_library", "go_test")

go_library(
    name = "clientutil",
    srcs = ["client.go"],
    importpath = "github.com/open-telemetry/opentelemetry-collector-contrib/internal/coreinternal/clientutil",
    visibility = ["//visibility:public"],
    deps = ["@io_opentelemetry_go_collector_client//:client"],
)

go_test(
    name = "clientutil_test",
    srcs = ["client_test.go"],
    embed = [":clientutil"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@io_opentelemetry_go_collector_client//:client",
    ],
)
