load("@@rules_go+//go:def.bzl", "go_library", "go_test")

go_library(
    name = "timeutils",
    srcs = [
        "doc.go",
        "parser.go",
        "ticker_helper.go",
    ],
    cgo = True,
    importpath = "github.com/open-telemetry/opentelemetry-collector-contrib/internal/coreinternal/timeutils",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_elastic_lunes//:lunes",
        "//otel-patches/coreinternal/timeutils/internal/ctimefmt",
    ],
)

go_test(
    name = "timeutils_test",
    srcs = [
        "package_test.go",
        "parser_test.go",
        "strptime_test.go",
        "ticker_test.go",
    ],
    embed = [":timeutils"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_goleak//:goleak",
    ],
)
