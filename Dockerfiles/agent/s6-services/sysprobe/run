#!/usr/bin/execlineb -P

# Check if the system-probe and system-probe-lite exist before running
ifelse -n
    { s6-test -x "/opt/datadog-agent/embedded/bin/system-probe" }
    {
        foreground { /initlog.sh "system-probe not bundled, disabling" }
        foreground { /bin/s6-svc -d /var/run/s6/services/sysprobe/ }
    }
    ifelse -n
        { s6-test -x "/opt/datadog-agent/embedded/bin/system-probe-lite" }
        {
            foreground { /initlog.sh "system-probe-lite not bundled, disabling" }
            foreground { /bin/s6-svc -d /var/run/s6/services/sysprobe/ }
        }
        foreground { /initlog.sh "starting system-probe with system-probe-lite" }
        /opt/datadog-agent/embedded/bin/system-probe-lite -- /opt/datadog-agent/embedded/bin/system-probe run --config=/etc/datadog-agent/system-probe.yaml
