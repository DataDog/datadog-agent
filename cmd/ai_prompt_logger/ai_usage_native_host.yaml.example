# Runtime settings for the AI usage Chrome native messaging host. The Agent installs the
# host binary; this file configures how it reaches the local Agent (trace receiver / EVP).
#
# Install the active file as `ai_usage_native_host.yaml` in the same configuration
# directory your platform uses for the Agent (typically alongside `datadog.yaml`).
#
# Copy this example to `ai_usage_native_host.yaml` in that directory, or edit after install.
#
# You can also point the host at this file explicitly (same idea as `agent run -c` /
# `system-probe --config`):
#   ai-prompt-logger-native-host --config=/path/to/ai_usage_native_host.yaml

# Base URL of the Agent trace receiver (same role as DD_TRACE_AGENT_URL).
# Use http:// only (local receiver is plain HTTP; this host has no TLS client).
trace_agent_url: "http://127.0.0.1:8126"

# EVP proxy API version (same role as DD_EVP_PROXY_API_VERSION).
evp_proxy_api_version: 2

# AI usage EVP intake subdomain header.
ai_usage_evp_subdomain: "softinv-intake"

# Standalone desktop monitoring settings. These are used only when the binary is
# launched with --desktop-monitor; Chrome native messaging mode ignores them.
desktop_monitoring:
  enabled: true
  poll_interval_seconds: 60
  # Hosted AI CLIs are counted only after their process-level read/write
  # counters advance since the previous poll. The first poll initializes the
  # baseline and does not emit AI-usage event.
  process_activity_window_seconds: 600

  # Lookup table 1: direct AI desktop apps or AI CLIs. Process names are matched
  # case-insensitively by executable basename, with or without the .exe suffix.
  ai_process_names:
    - process_names: ["Cursor.exe", "Cursor"]
      tool: "Cursor"
      provider: "Anysphere"
      match_scope: "both"
      approved: false
    - process_names: ["Claude.exe", "Claude"]
      tool: "Claude"
      provider: "Anthropic"
      match_scope: "direct"
      approved: false
    - process_names: ["claude.exe", "claude"]
      tool: "Claude Code"
      provider: "Anthropic"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["cowork-svc.exe", "cowork-svc"]
      tool: "Claude Cowork"
      provider: "Anthropic"
      match_scope: "hosted_child"
      approved: false
      secondary: true
    - process_names: ["Codex.exe", "codex"]
      tool: "Codex"
      provider: "OpenAI"
      match_scope: "both"
      approved: false
    - process_names: ["OpenClaw.exe", "openclaw-desktop.exe", "OpenClaw.Tray.WinUI.exe", "OpenClaw", "openclaw-desktop"]
      tool: "OpenClaw"
      provider: "OpenClaw"
      match_scope: "both"
      approved: false
    # Additional Agent Skills client candidates. These entries are intentionally
    # limited to plausible native desktop apps or CLIs; cloud-only products,
    # libraries, and IDE extensions without a distinct process are omitted.
    - process_names: ["Junie.exe"]
      tool: "Junie"
      provider: "JetBrains"
      match_scope: "direct"
      approved: false
    - process_names: ["gemini.exe", "gemini-cli.exe"]
      tool: "Gemini CLI"
      provider: "Google"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["hermes.exe", "hermes", "hermes-agent.exe", "hermes-agent"]
      tool: "Hermes Agent"
      provider: "Nous Research"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["autohand.exe", "autohand-code.exe"]
      tool: "Autohand Code CLI"
      provider: "Autohand"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["opencode.exe"]
      tool: "OpenCode"
      provider: "OpenCode"
      match_scope: "both"
      approved: false
    - process_names: ["openhands.exe"]
      tool: "OpenHands"
      provider: "OpenHands"
      match_scope: "both"
      approved: false
    - process_names: ["mux.exe"]
      tool: "Mux"
      provider: "Coder"
      match_scope: "both"
      approved: false
    - process_names: ["amp.exe"]
      tool: "Amp"
      provider: "Sourcegraph"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["letta.exe", "letta-code.exe"]
      tool: "Letta"
      provider: "Letta"
      match_scope: "both"
      approved: false
    - process_names: ["firebender.exe"]
      tool: "Firebender"
      provider: "Firebender"
      match_scope: "direct"
      approved: false
    - process_names: ["goose.exe"]
      tool: "Goose"
      provider: "Block"
      match_scope: "both"
      approved: false
    - process_names: ["Piebald.exe", "piebald.exe"]
      tool: "Piebald"
      provider: "Piebald"
      match_scope: "both"
      approved: false
    - process_names: ["factory.exe"]
      tool: "Factory"
      provider: "Factory"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["trae.exe", "Trae.exe"]
      tool: "TRAE"
      provider: "ByteDance"
      match_scope: "both"
      approved: false
    - process_names: ["roo-code.exe", "roocode.exe"]
      tool: "Roo Code"
      provider: "Roo Code"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["mistral-vibe.exe", "vibe.exe"]
      tool: "Mistral AI Vibe"
      provider: "Mistral AI"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["command-code.exe", "commandcode.exe"]
      tool: "Command Code"
      provider: "Command Code"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["vtcode.exe", "vt-code.exe"]
      tool: "VT Code"
      provider: "VT Code"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["qodo.exe", "qodo-cli.exe"]
      tool: "Qodo"
      provider: "Qodo"
      match_scope: "both"
      approved: false
    - process_names: ["kiro.exe", "Kiro.exe"]
      tool: "Kiro"
      provider: "Kiro"
      match_scope: "both"
      approved: false
    - process_names: ["workshop.exe", "Workshop.exe"]
      tool: "Workshop"
      provider: "Workshop"
      match_scope: "both"
      approved: false
    - process_names: ["nanobot.exe"]
      tool: "nanobot"
      provider: "nanobot"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["fast-agent.exe", "fastagent.exe"]
      tool: "fast-agent"
      provider: "fast-agent"
      match_scope: "hosted_child"
      approved: false
    - process_names: ["tabnine.exe", "tabnine-cli.exe"]
      tool: "Tabnine"
      provider: "Tabnine"
      match_scope: "both"
      approved: false
    - process_names: ["emdash.exe"]
      tool: "Emdash"
      provider: "Emdash"
      match_scope: "both"
      approved: false

  # Lookup table 2: foreground host apps that may contain AI CLI children.
  # Broad runtimes such as node.exe/node or python.exe/python are intentionally omitted from
  # lookup table 1 to avoid false positives without command-line inspection.
  host_process_names:
    - "cmd.exe"
    - "powershell.exe"
    - "pwsh.exe"
    - "WindowsTerminal.exe"
    - "wt.exe"
    - "conhost.exe"
    - "Code.exe"
    - "Cursor.exe"
    - "devenv.exe"
    - "idea64.exe"
    - "pycharm64.exe"
    - "webstorm64.exe"
    - "rider64.exe"
    - "wezterm-gui.exe"
    - "Terminal"
    - "iTerm2"
    - "Ghostty"
    - "WezTerm"
    - "wezterm-gui"
    - "Alacritty"
    - "alacritty"
    - "kitty"
    - "Code"
    - "Cursor"
    - "IntelliJ IDEA"
    - "PyCharm"
    - "WebStorm"
    - "Rider"
    - "alacritty.exe"
    - "mintty.exe"
    - "Tabby.exe"
