load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "api",
    srcs = [
        "grpc.go",
        "grpc_kubemetadata.go",
        "grpc_kubemetadata_nocompile.go",
        "listener.go",
        "server.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/cluster-agent/api",
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/cluster-agent/api/agent",
        "//cmd/cluster-agent/api/v1:api",
        "//cmd/cluster-agent/api/v1/languagedetection",
        "//cmd/cluster-agent/api/v2/series",
        "//comp/api/grpcserver/helpers",
        "//comp/core/autodiscovery/def",
        "//comp/core/config",
        "//comp/core/diagnose/def",
        "//comp/core/ipc/def",
        "//comp/core/settings/def",
        "//comp/core/status",
        "//comp/core/tagger/def",
        "//comp/core/tagger/server",
        "//comp/core/telemetry/def",
        "//comp/core/workloadmeta/def",
        "//comp/metadata/clusteragent/def",
        "//comp/metadata/clusterchecks/def",
        "//pkg/api/middleware",
        "//pkg/api/util",
        "//pkg/config/setup",
        "//pkg/proto/pbgo/core",
        "//pkg/util/grpc",
        "//pkg/util/kubernetes/apiserver/controllers",
        "//pkg/util/log",
        "//pkg/util/log/setup",
        "@com_github_grpc_ecosystem_go_grpc_middleware_v2//interceptors/auth",
        "@org_golang_google_grpc//:grpc",
    ],
)

dd_agent_go_test(
    name = "api_test",
    srcs = ["server_test.go"],
    embed = [":api"],
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//comp/core/ipc/mock",
        "//pkg/api/util",
        "//pkg/config/mock",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
