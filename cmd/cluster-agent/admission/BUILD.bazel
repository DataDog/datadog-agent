load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "admission",
    srcs = ["server.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/cluster-agent/admission",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/clusteragent/admission/common",
        "//pkg/clusteragent/admission/metrics",
        "//pkg/config/setup",
        "//pkg/status/health",
        "//pkg/util/kubernetes/apiserver/common/namespace",
        "//pkg/util/kubernetes/certificate",
        "//pkg/util/log",
        "//pkg/util/log/setup",
        "@io_k8s_api//admission/v1:admission",
        "@io_k8s_api//admission/v1beta1",
        "@io_k8s_api//admissionregistration/v1:admissionregistration",
        "@io_k8s_api//authentication/v1:authentication",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_apimachinery//pkg/runtime/serializer",
        "@io_k8s_apimachinery//pkg/types",
        "@io_k8s_client_go//dynamic",
        "@io_k8s_client_go//kubernetes",
        "@io_k8s_client_go//listers/core/v1:core",
    ],
)

dd_agent_go_test(
    name = "admission_test",
    srcs = ["server_test.go"],
    embed = [":admission"],
    flavors = [
        "base",
        "fips",
    ],
    deps = [
        "//pkg/clusteragent/admission/common",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_k8s_api//admission/v1:admission",
    ],
)
