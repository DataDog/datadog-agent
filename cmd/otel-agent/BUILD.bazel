load("@rules_go//go:def.bzl", "go_binary", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "otel-agent_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/otel-agent",
    visibility = ["//visibility:private"],
    deps = [
        "//cmd/internal/runcmd",
        "//cmd/otel-agent/command",
        "//comp/logs-library/metrics",
        "//pkg/util/flavor",
        "//pkg/version",
    ],
)

go_binary(
    name = "otel-agent",
    embed = [":otel-agent_lib"],
    gotags = ["otlp"],
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "otel-agent_test",
    srcs = ["main_test.go"],
    embed = [":otel-agent_lib"],
    flavors = [
        "base",
        "fips",
        "heroku",
    ],
    deps = [
        "//comp/logs-library/metrics",
        "//pkg/util/flavor",
        "@com_github_stretchr_testify//assert",
    ],
)
