load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")
load("//tasks:build_tags.bzl", "FIPS_TAGS", "HOST_PROFILER_TAGS")

go_library(
    name = "host-profiler_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/host-profiler",
    visibility = ["//visibility:private"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//cmd/host-profiler/command",
            "//cmd/internal/runcmd",
            "//pkg/util/flavor",
            "//pkg/version",
            "@org_golang_x_sys//unix",
        ],
        "@rules_go//go/platform:linux": [
            "//cmd/host-profiler/command",
            "//cmd/internal/runcmd",
            "//pkg/util/flavor",
            "//pkg/version",
            "@org_golang_x_sys//unix",
        ],
        "//conditions:default": [],
    }),
)

go_binary(
    name = "host-profiler",
    embed = [":host-profiler_lib"],
    gotags = HOST_PROFILER_TAGS + select({
        "//bazel/flags:fips_non_windows": FIPS_TAGS,
        "//conditions:default": [],
    }),
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:public"],
)

go_test(
    name = "host-profiler_test",
    srcs = ["dist_test.go"],
    embed = [":host-profiler_lib"],
    gotags = ["test"],
)
