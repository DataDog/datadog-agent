load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")
load("//bazel/rules/go:go_binary.bzl", "dd_agent_go_binary")
load("//tasks:build_tags.bzl", "HOST_PROFILER_TAGS")

# gazelle:dd_agent_go_test on

go_library(
    name = "host-profiler_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/host-profiler",
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:private"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//cmd/host-profiler/command",
            "//cmd/internal/runcmd",
            "//pkg/util/flavor",
            "//pkg/version",
            "@org_golang_x_sys//unix",
        ],
        "@rules_go//go/platform:linux": [
            "//cmd/host-profiler/command",
            "//cmd/internal/runcmd",
            "//pkg/util/flavor",
            "//pkg/version",
            "@org_golang_x_sys//unix",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_binary(
    name = "host-profiler",
    embed = [":host-profiler_lib"],
    gotags = HOST_PROFILER_TAGS,
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "host-profiler_test",
    srcs = ["dist_test.go"],
    embed = [":host-profiler_lib"],
)
