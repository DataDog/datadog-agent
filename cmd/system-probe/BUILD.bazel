load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "system-probe_lib",
    srcs = [
        "main.go",
        "main_windows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/system-probe",
    visibility = ["//visibility:private"],
    deps = select({
        "@rules_go//go/platform:aix": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:android": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:darwin": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:dragonfly": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:freebsd": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:illumos": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:ios": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:linux": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:netbsd": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:openbsd": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:solaris": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:windows": [
            "//cmd/internal/runcmd",
            "//cmd/system-probe/command",
            "//cmd/system-probe/subcommands",
            "//pkg/util/log",
            "//pkg/util/winutil/servicemain",
            "@//cmd/system-probe/windows/service",
        ],
        "//conditions:default": [],
    }),
)

go_binary(
    name = "system-probe",
    embed = [":system-probe_lib"],
    visibility = ["//visibility:public"],
    # Stamp version/commit at binary link time, overriding the "dev" defaults
    # set in //pkg/version:version.  Build with --stamp
    # --workspace_status_command=bazel/tools/workspace_status.sh
    x_defs = {
        "github.com/DataDog/datadog-agent/pkg/version.Commit": "{STABLE_GIT_COMMIT}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentVersion": "{STABLE_AGENT_VERSION}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentVersionURLSafe": "{STABLE_AGENT_VERSION_URL_SAFE}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentPackageVersion": "{STABLE_AGENT_VERSION}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentPayloadVersion": "{STABLE_AGENT_PAYLOAD_VERSION}",
    },
)
