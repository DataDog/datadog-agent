load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ebpf",
    srcs = [
        "btf_dumper.go",
        "command.go",
        "command_linux.go",
        "command_unsupported.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/system-probe/subcommands/ebpf",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/system-probe/command",
        "@com_github_cilium_ebpf//btf",
        "@com_github_spf13_cobra//:cobra",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/util/kernel",
            "//pkg/util/log",
            "@com_github_cilium_ebpf//:ebpf",
            "@org_golang_x_sys//unix",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/util/kernel",
            "//pkg/util/log",
            "@com_github_cilium_ebpf//:ebpf",
            "@org_golang_x_sys//unix",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "ebpf_test",
    srcs = [
        "command_linux_btf_test.go",
        "command_linux_test.go",
    ],
    embed = [":ebpf"],
    gotags = [
        "test",
        "linux_bpf",
    ],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/util/kernel",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_cilium_ebpf//rlimit",
        "@com_github_stretchr_testify//require",
    ] + select({
        "@rules_go//go/platform:android": [
            "//cmd/system-probe/command",
            "@com_github_spf13_cobra//:cobra",
        ],
        "@rules_go//go/platform:linux": [
            "//cmd/system-probe/command",
            "@com_github_spf13_cobra//:cobra",
        ],
        "//conditions:default": [],
    }),
)
