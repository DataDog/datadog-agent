load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "log",
    srcs = [
        "channel_writer.go",
        "log.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/serverless-init/log",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/hostname/hostnameinterface/def",
        "//comp/core/tagger/def",
        "//comp/logs/agent/config",
        "//comp/logs/agent/def",
        "//comp/serializer/logscompression/def",
        "//pkg/logs/sources",
        "//pkg/serverless/logs",
        "//pkg/serverless/tags",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "log_test",
    srcs = [
        "channel_writer_test.go",
        "log_test.go",
    ],
    embed = [":log"],
    deps = [
        "//comp/logs/agent/config",
        "@com_github_stretchr_testify//assert",
    ],
)
