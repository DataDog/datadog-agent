dd_agent_go_test(
    name = "enhanced-metrics_test",
    srcs = ["collector_test.go"],
    embed = [":enhanced-metrics"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/metrics",
            "//pkg/util/cgroups",
            "//pkg/util/pointer",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//mock",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/metrics",
            "//pkg/util/cgroups",
            "//pkg/util/pointer",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//mock",
        ],
        "//conditions:default": [],
