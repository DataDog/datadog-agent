            "//pkg/util/log",
            "//pkg/util/pointer",
            "//pkg/util/system",
        ],
        "@rules_go//go/platform:darwin": [
            "//pkg/metrics",
        ],
        "@rules_go//go/platform:dragonfly": [
            "//pkg/metrics",
        ],
        "@rules_go//go/platform:freebsd": [
            "//pkg/metrics",
        ],
        "@rules_go//go/platform:illumos": [
            "//pkg/metrics",
        ],
        "@rules_go//go/platform:ios": [
            "//pkg/metrics",
        ],
        "@rules_go//go/platform:js": [
            "//pkg/metrics",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/metrics",
            "//pkg/util/cgroups",
            "//pkg/util/log",
            "//pkg/util/pointer",
            "//pkg/util/system",
