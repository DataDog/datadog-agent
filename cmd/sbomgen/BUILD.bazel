load("@rules_go//go:def.bzl", "go_binary", "go_library")
load("//tasks:build_tags.bzl", "FIPS_TAGS", "SBOMGEN_TAGS")

go_library(
    name = "sbomgen_lib",
    srcs = [
        "main.go",
        "scanners.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/sbomgen",
    visibility = ["//visibility:private"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//comp/core/workloadmeta/def",
            "//pkg/sbom",
            "//pkg/util/containerd",
            "//pkg/util/crio",
            "//pkg/util/docker",
            "//pkg/util/trivy",
            "@com_github_containerd_containerd//:containerd",
            "@com_github_spf13_cobra//:cobra",
        ],
        "@rules_go//go/platform:linux": [
            "//comp/core/workloadmeta/def",
            "//pkg/sbom",
            "//pkg/util/containerd",
            "//pkg/util/crio",
            "//pkg/util/docker",
            "//pkg/util/trivy",
            "@com_github_containerd_containerd//:containerd",
            "@com_github_spf13_cobra//:cobra",
        ],
        "//conditions:default": [],
    }),
)

go_binary(
    name = "sbomgen",
    embed = [":sbomgen_lib"],
    gotags = SBOMGEN_TAGS + select({
        "//bazel/flags:fips_non_windows": FIPS_TAGS,
        "//conditions:default": [],
    }),
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:public"],
    # Stamp version/commit at binary link time, overriding the "dev" defaults
    # set in //pkg/version:version.  Build with --stamp
    # --workspace_status_command=bazel/tools/workspace_status.sh
    x_defs = {
        "github.com/DataDog/datadog-agent/pkg/version.Commit": "{STABLE_GIT_COMMIT}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentVersion": "{STABLE_AGENT_VERSION}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentVersionURLSafe": "{STABLE_AGENT_VERSION_URL_SAFE}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentPackageVersion": "{STABLE_AGENT_VERSION}",
        "github.com/DataDog/datadog-agent/pkg/version.AgentPayloadVersion": "{STABLE_AGENT_PAYLOAD_VERSION}",
    },
)
