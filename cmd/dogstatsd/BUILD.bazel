        ],
        "@rules_go//go/platform:windows": [
            "//cmd/dogstatsd/command",
            "//cmd/dogstatsd/subcommands/start",
            "//comp/aggregator/demultiplexer/def",
            "//comp/core/config",
            "//comp/core/log/def",
            "//comp/dogstatsd/server/def",
            "//pkg/util/flavor",
            "//pkg/util/log",
            "//pkg/util/winutil",
            "//pkg/util/winutil/messagestrings",
            "//pkg/util/winutil/servicemain",
        ],
        "//conditions:default": [],
    }),
