load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:go_binary.bzl", "dd_agent_go_binary")
load("//tasks:build_tags.bzl", "COMMON_TAGS", "DARWIN_EXCLUDED_TAGS", "DOGSTATSD_TAGS", "FIPS_TAGS", "LINUX_ONLY_TAGS", "WINDOWS_EXCLUDED_TAGS")

# gazelle:dd_agent_go_test on

go_library(
    name = "dogstatsd_lib",
    srcs = [
        "main_nix.go",
        "main_windows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/dogstatsd",
    visibility = ["//visibility:private"],
    deps = select({
        "@rules_go//go/platform:aix": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:android": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:darwin": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:dragonfly": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:freebsd": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:illumos": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:ios": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:js": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:linux": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:netbsd": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:openbsd": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:osx": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:plan9": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
        "@rules_go//go/platform:qnx": [
            "//cmd/dogstatsd/command",
            "//pkg/util/defaultpaths",
            "//pkg/util/flavor",
            "//pkg/util/log",
        ],
