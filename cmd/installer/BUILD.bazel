load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/go:go_binary.bzl", "dd_agent_go_binary")
load("//tasks:build_tags.bzl", "COMMON_TAGS", "INSTALLER_TAGS")

go_library(
    name = "installer_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/installer",
    visibility = ["//visibility:private"],
    deps = [
        "//cmd/installer/command",
        "//cmd/installer/subcommands",
        "//pkg/fleet/installer/commands",
        "//pkg/fleet/installer/errors",
        "@com_github_spf13_cobra//:cobra",
        "@org_uber_go_dig//:dig",
    ],
)

dd_agent_go_binary(
    name = "installer",
    # keep
    srcs = select({
        "@platforms//os:windows": ["//cmd/installer/windows_resources:rsrc"],
        "//conditions:default": [],
    }),
    # For Windows we always need cgo to link the resource files.
    # For FIPS we need cgo for the usual reasons.
    # This behavior was determined by looking at the usage patterns of
    # how the omnibus build and tasks/installer.py interacted.
    # In the future, we may find it easier to always use cgo.
    cgo = select({
        "//packages/agent:fips_flavor": True,
        "@platforms//os:windows": True,
        "//conditions:default": False,
    }),
    embed = [":installer_lib"],
    # TODO(agent-build): Perhaps the toolchain or the macro should select
    # these based on debug or release builds.
    gc_linkopts = [
        "-s",
        "-w",
    ],
    gotags = sorted(COMMON_TAGS | INSTALLER_TAGS),
    visibility = ["//visibility:public"],
)

go_test(
    name = "installer_test",
    srcs = ["main_test.go"],
    embed = [":installer_lib"],
    gotags = ["test"],
    deps = [
        "//pkg/fleet/installer/commands",
        "@com_github_spf13_cobra//:cobra",
        "@com_github_stretchr_testify//assert",
    ],
)
