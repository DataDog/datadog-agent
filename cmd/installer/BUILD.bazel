load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/go:go_binary.bzl", "dd_agent_go_binary")
load("//tasks:build_tags.bzl", "INSTALLER_TAGS")

# gazelle:dd_agent_go_test off

go_library(
    name = "installer_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/installer",
    visibility = ["//visibility:private"],
    deps = [
        "//cmd/installer/command",
        "//cmd/installer/subcommands",
        "//pkg/fleet/installer/commands",
        "//pkg/fleet/installer/errors",
        "@com_github_spf13_cobra//:cobra",
        "@org_uber_go_dig//:dig",
    ],
)

dd_agent_go_binary(
    name = "installer",
    # keep
    srcs = select({
        "@platforms//os:windows": ["//cmd/installer/windows_resources:rsrc"],
        "//conditions:default": [],
    }),
    # FIPS requires cgo; Windows cgo is provided by dd_agent_go_binary default.
    cgo = select({
        "//packages/agent:fips_flavor": True,
        "@platforms//os:windows": True,
        "//conditions:default": False,
    }),
    embed = [":installer_lib"],
    gotags = INSTALLER_TAGS,
    visibility = ["//visibility:public"],
)

go_test(
    name = "installer_test",
    srcs = ["main_test.go"],
    embed = [":installer_lib"],
    gotags = ["test"],
    deps = [
        "//pkg/fleet/installer/commands",
        "@com_github_spf13_cobra//:cobra",
        "@com_github_stretchr_testify//assert",
    ],
)
