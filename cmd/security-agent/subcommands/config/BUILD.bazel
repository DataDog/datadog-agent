load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = ["config.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/security-agent/subcommands/config",
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/security-agent/command",
        "//comp/core",
        "//comp/core/config",
        "//comp/core/ipc/def",
        "//comp/core/ipc/fx",
        "//comp/core/ipc/httphelpers",
        "//comp/core/log/def",
        "//comp/core/secrets/def",
        "//pkg/config/fetcher",
        "//pkg/config/settings",
        "//pkg/config/settings/http",
        "//pkg/config/setup",
        "//pkg/util/fxutil",
        "@com_github_spf13_cobra//:cobra",
        "@org_uber_go_fx//:fx",
    ],
)

dd_agent_go_test(
    name = "config_test",
    srcs = ["config_test.go"],
    embed = [":config"],
    flavors = [
        "base",
        "fips",
    ],
    deps = [
        "//cmd/security-agent/command",
        "//pkg/util/fxutil",
    ],
