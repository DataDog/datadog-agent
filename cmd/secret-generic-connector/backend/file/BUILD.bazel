load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "file",
    srcs = [
        "json.go",
        "text.go",
        "yaml.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/secret-generic-connector/backend/file",
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/secret-generic-connector/secret",
        "@com_github_mitchellh_mapstructure//:mapstructure",
        "@in_yaml_go_yaml_v3//:yaml",
    ],
)

dd_agent_go_test(
    name = "file_test",
    srcs = [
        "json_test.go",
        "text_test.go",
        "yaml_test.go",
    ],
    embed = [":file"],
    deps = [
        "//cmd/secret-generic-connector/secret",
        "@com_github_stretchr_testify//assert",
    ],
)
