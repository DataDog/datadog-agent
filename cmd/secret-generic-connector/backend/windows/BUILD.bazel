load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "windows",
    srcs = [
        "regkey.go",
        "regkey_nonwindows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/secret-generic-connector/backend/windows",
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/secret-generic-connector/secret",
    ] + select({
        "@io_bazel_rules_go//go/platform:windows": [
            "@com_github_mitchellh_mapstructure//:mapstructure",
            "@org_golang_x_sys//windows/registry",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "windows_test",
    srcs = ["regkey_test.go"],
    embed = [":windows"],
    gotags = ["test"],
    target_compatible_with = ["@platforms//os:windows"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@org_golang_x_sys//windows/registry",
    ],
)
