dd_agent_go_test(
    name = "streamlogs_test",
    srcs = ["command_test.go"],
    embed = [":streamlogs"],
    deps = [
        "//cmd/agent/command",
        "//comp/core",
        "//pkg/util/fxutil",
        "@com_github_stretchr_testify//require",
