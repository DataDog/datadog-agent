"""Sample admin-owned allowlist for the powershell check.

Installed into the Windows-only, admin-writable protected directory
(C:\\ProgramData\\Datadog\\protected). The powershell check reads only
powershell_allowlist.yaml, so this .example is a template, never live policy.
"""

load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_files", "strip_prefix")

pkg_files(
    name = "protected_files",
    srcs = ["powershell_allowlist.yaml.example"],
    attributes = pkg_attributes(mode = "0644"),
    prefix = "etc/datadog-agent/protected",
    strip_prefix = strip_prefix.from_pkg(),
    visibility = ["//packages:__subpackages__"],
)
