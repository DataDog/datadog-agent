load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "misconfig",
    srcs = [
        "global.go",
        "mounts.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/agent/common/misconfig",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/env",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
            "//vendor/github.com/syndtr/gocapability/capability",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/env",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
            "//vendor/github.com/syndtr/gocapability/capability",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "misconfig_test",
    srcs = ["mounts_test.go"],
    data = glob(["testdata/**"]),
    embed = [":misconfig"],
    gotags = ["test"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/stretchr/testify/assert",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/stretchr/testify/assert",
        ],
        "//conditions:default": [],
    }),
)
