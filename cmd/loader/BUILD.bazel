"""The trace loader."""

load("@rules_go//go:def.bzl", "go_binary", "go_library")
load(
    "@rules_pkg//pkg:mappings.bzl",
    "pkg_attributes",
    "pkg_files",
)

package(default_visibility = ["//packages:__subpackages__"])

pkg_files(
    name = "trace_loader",
    srcs = select({
        "//packages/agent:linux_default": [
            "@trace_loader_binary//:trace_loader",
        ],
        "//packages/agent:linux_fips": [
            "@trace_loader_binary//:trace_loader",
        ],
        # This shouldn't be needed in practice, but it is used by the systemd
        # service, which is used when installing the deb manually.
        "//packages/agent:linux_heroku": [
            "main_noop.sh",
        ],
        "//conditions:default": [],
    }),
    attributes = pkg_attributes(mode = "755"),
    prefix = "embedded/bin",
    renames = select({
        "//packages/agent:linux_heroku": {":main_noop.sh": "trace-loader"},
        "//conditions:default": {},
    }),
    target_compatible_with = ["@platforms//os:linux"],
)

go_library(
    name = "loader_lib",
    srcs = [
        "docs.go",
        "main_nix.go",
        "memory_darwin.go",
        "memory_linux.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/loader",
    deps = select({
        "@rules_go//go/platform:android": [
            "//comp/otelcol/otlp/configcheck",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/delegatedauth/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/log/def",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/secrets/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/env",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/utils",
            "//vendor/github.com/DataDog/datadog-agent/pkg/trace/api/loader",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log/setup",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:darwin": [
            "//comp/otelcol/otlp/configcheck",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/delegatedauth/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/log/def",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/secrets/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/env",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/utils",
            "//vendor/github.com/DataDog/datadog-agent/pkg/trace/api/loader",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log/setup",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:ios": [
            "//comp/otelcol/otlp/configcheck",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/delegatedauth/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/log/def",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/secrets/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/env",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/utils",
            "//vendor/github.com/DataDog/datadog-agent/pkg/trace/api/loader",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log/setup",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:linux": [
            "//comp/otelcol/otlp/configcheck",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/delegatedauth/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/log/def",
            "//vendor/github.com/DataDog/datadog-agent/comp/core/secrets/noop-impl/types",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/env",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
            "//vendor/github.com/DataDog/datadog-agent/pkg/config/utils",
            "//vendor/github.com/DataDog/datadog-agent/pkg/trace/api/loader",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log/setup",
            "//vendor/golang.org/x/sys/unix",
        ],
        "//conditions:default": [],
    }),
)

go_binary(
    name = "loader",
    embed = [":loader_lib"],
    # keep
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
)
