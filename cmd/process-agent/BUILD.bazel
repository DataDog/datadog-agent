load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:go_binary.bzl", "dd_agent_go_binary")
load("//tasks:build_tags.bzl", "COMMON_TAGS", "PROCESS_AGENT_TAGS")

go_library(
    name = "process-agent_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/cmd/process-agent",
    visibility = ["//visibility:private"],
    deps = [
        "//cmd/internal/runcmd",
        "//cmd/process-agent/command",
        "//cmd/process-agent/subcommands",
        "//pkg/util/flavor",
    ],
)

dd_agent_go_binary(
    name = "process-agent",
    embed = [":process-agent_lib"],
    gotags = sorted(COMMON_TAGS | PROCESS_AGENT_TAGS),
    visibility = ["//visibility:public"],
)
