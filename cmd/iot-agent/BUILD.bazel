load("@rules_go//go:def.bzl", "go_binary", "go_library")
load("//tasks:build_tags.bzl", "FIPS_TAGS", "IOT_AGENT_TAGS")

go_library(
    name = "iot-agent_lib",
    srcs = [
        "docs.go",
        "main.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/cmd/iot-agent",
    visibility = ["//visibility:private"],
    deps = select({
        "@rules_go//go/platform:aix": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:android": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:darwin": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:dragonfly": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:freebsd": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:illumos": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:ios": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:js": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:linux": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:netbsd": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:openbsd": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:osx": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:plan9": [
            "//cmd/agent/command",
            "//cmd/iot-agent/subcommands",
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:qnx": [
            "//cmd/agent/command",
