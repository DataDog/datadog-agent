load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

go_library(
    name = "worksynchronizer_lib",
    srcs = ["worksynchronizer.go"],
    importpath = "github.com/DataDog/datadog-agent/internal/tools/worksynchronizer",
    visibility = ["//visibility:private"],
    deps = [
        "//vendor/go.yaml.in/yaml/v3:yaml",
        "//vendor/golang.org/x/mod/modfile",
    ],
)

go_binary(
    name = "worksynchronizer",
    embed = [":worksynchronizer_lib"],
    visibility = ["//:__subpackages__"],
)

go_test(
    name = "worksynchronizer_test",
    srcs = ["worksynchronizer_test.go"],
    data = glob(["testdata/**"]),
    embed = [":worksynchronizer_lib"],
    deps = [
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
    ],
)
