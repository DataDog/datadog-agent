load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

# gazelle:resolve go github.com/DataDog/datadog-agent/comp/core //comp/core

go_library(
    name = "anomalydetection-testbench_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/internal/qbranch/anomalydetection-testbench",
    tags = ["manual"],
    visibility = ["//visibility:private"],
    deps = [
        "//comp/anomalydetection/observer/def",
        "//comp/anomalydetection/observer/fx",
        "//comp/anomalydetection/observer/impl",
        "//comp/anomalydetection/recorder/fx-noop",
        "//comp/anomalydetection/reporter/fx-testbench",
        "//comp/anomalydetection/reporter/impl-testbench",
        "//comp/core",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/tagger/def",
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadmeta/def",
        "//internal/qbranch/anomalydetection-testbench/bench",
        "//pkg/util/fxutil",
        "//pkg/util/option",
        "@org_uber_go_fx//:fx",
    ],
)

go_binary(
    name = "anomalydetection-testbench",
    embed = [":anomalydetection-testbench_lib"],
    tags = ["manual"],
    visibility = ["//visibility:private"],
)

go_test(
    name = "anomalydetection-testbench_test",
    srcs = ["main_test.go"],
    embed = [":anomalydetection-testbench_lib"],
    gotags = ["test"],
    tags = ["manual"],
    visibility = ["//visibility:private"],
    deps = [
        "//comp/anomalydetection/observer/fx",
        "//comp/anomalydetection/recorder/fx-noop",
        "//comp/anomalydetection/reporter/fx-testbench",
        "//comp/core",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/tagger/def",
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadmeta/def",
        "//pkg/util/fxutil",
        "//pkg/util/option",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_fx//:fx",
    ],
)
