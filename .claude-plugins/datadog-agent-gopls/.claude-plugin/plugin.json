{
  "name": "datadog-agent-gopls",
  "version": "1.0.1",
  "description": "Go LSP (gopls) pre-configured for the datadog-agent repository with build tags and performance flags",
  "author": {
    "name": "L\u00e9na\u00efc Huard",
    "email": "lenaic.huard@datadoghq.com"
  },
  "lspServers": {
    "gopls": {
      "command": "gopls",
      "extensionToLanguage": {
        ".go": "go"
      },
      "initializationOptions": {
        "build.buildFlags": [
          "-tags=cel,clusterchecks,consul,datadog.no_waf,ec2,etcd,fargateprocess,grpcnotrace,jmx,kubeapiserver,kubelet,ncm,netgo,no_dynamic_plugins,npm,oracle,orchestrator,osusergo,otlp,python,retrynotrace,seclmax,serverless,sharedlibrarycheck,systemprobechecks,test,trivy_no_javadb,zk,zlib,zstd",
          "-buildvcs=false"
        ],
        "formatting.local": "github.com/DataDog/datadog-agent"
      }
    }
  }
}
