load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = [
        "config.go",
        "mutation.go",
        "pattern.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/appsec/config",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
        "//pkg/util/kubernetes",
        "//pkg/util/kubernetes/apiserver/common/namespace",
        "//pkg/util/log",
        "@io_k8s_api//admissionregistration/v1:admissionregistration",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/apis/meta/v1/unstructured",
        "@io_k8s_apimachinery//pkg/runtime/schema",
        "@io_k8s_client_go//dynamic",
    ],
)

dd_agent_go_test(
    name = "config_test",
    srcs = [
        "config_test.go",
        "mutation_test.go",
    ],
    embed = [":config"],
    flavors = [
        "base",
        "fips",
    ],
    deps = [
        "//comp/core/log/mock",
        "//pkg/clusteragent/admission/mutate/common",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
