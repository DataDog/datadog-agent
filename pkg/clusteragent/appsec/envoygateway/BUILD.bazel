load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "envoygateway",
    srcs = [
        "backend.go",
        "detection.go",
        "enablebackend.go",
        "envoy.go",
        "envoy_sidecar.go",
        "events.go",
        "referencegrants.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/appsec/envoygateway",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/log/def",
        "//pkg/clusteragent/admission/mutate/common",
        "//pkg/clusteragent/appsec/config",
        "//pkg/clusteragent/appsec/sidecar",
        "//pkg/errors",
        "@com_github_envoyproxy_gateway//api/v1alpha1",
        "@io_k8s_api//admissionregistration/v1:admissionregistration",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/errors",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/apis/meta/v1/unstructured",
        "@io_k8s_apimachinery//pkg/fields",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_apimachinery//pkg/runtime/schema",
        "@io_k8s_apimachinery//pkg/types",
        "@io_k8s_client_go//dynamic",
        "@io_k8s_client_go//tools/record",
        "@io_k8s_sigs_gateway_api//apis/v1:apis",
        "@io_k8s_sigs_gateway_api//apis/v1beta1",
        "@io_k8s_sigs_yaml//:yaml",
        "@io_k8s_utils//ptr",
    ],
)

dd_agent_go_test(
    name = "envoygateway_test",
    srcs = [
        "backend_test.go",
        "enablebackend_test.go",
        "envoy_sidecar_test.go",
        "envoy_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":envoygateway"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//pkg/clusteragent/appsec/config",
        "//pkg/clusteragent/appsec/sidecar",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/errors",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/apis/meta/v1/unstructured",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_apimachinery//pkg/runtime/schema",
        "@io_k8s_client_go//dynamic",
        "@io_k8s_client_go//dynamic/fake",
        "@io_k8s_client_go//testing",
        "@io_k8s_client_go//tools/record",
    ],
)
