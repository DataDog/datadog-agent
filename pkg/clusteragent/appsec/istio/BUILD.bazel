load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "istio",
    srcs = [
        "detection.go",
        "events.go",
        "gateway.go",
        "gateway_sidecar.go",
        "istio.go",
        "sidecar.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/appsec/istio",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/log/def",
        "//pkg/clusteragent/admission/mutate/common",
        "//pkg/clusteragent/appsec/config",
        "//pkg/clusteragent/appsec/sidecar",
        "//pkg/errors",
        "@io_istio_api//networking/v1alpha3",
        "@io_istio_client_go//pkg/apis/networking/v1alpha3",
        "@io_k8s_api//admissionregistration/v1:admissionregistration",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/errors",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/apis/meta/v1/unstructured",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_apimachinery//pkg/runtime/schema",
        "@io_k8s_client_go//dynamic",
        "@io_k8s_client_go//tools/record",
        "@org_golang_google_protobuf//types/known/structpb",
    ],
)

dd_agent_go_test(
    name = "istio_test",
    srcs = [
        "gateway_sidecar_test.go",
        "gateway_test.go",
        "istio_test.go",
        "sidecar_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":istio"],
    flavors = [
        "base",
        "fips",
    ],
    deps = [
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//pkg/clusteragent/appsec/config",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/errors",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/apis/meta/v1/unstructured",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_apimachinery//pkg/runtime/schema",
        "@io_k8s_client_go//dynamic",
        "@io_k8s_client_go//dynamic/fake",
        "@io_k8s_client_go//testing",
        "@io_k8s_client_go//tools/record",
    ],
)
