load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "api",
    srcs = [
        "handler_telemetry.go",
        "leader_forwarder.go",
        "leader_handler.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/api",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//pkg/config/setup",
        "//pkg/util/kubernetes/apiserver/leaderelection",
        "//pkg/util/log",
        "//pkg/util/log/setup",
        "@com_github_datadog_dd_trace_go_v2//ddtrace/tracer",
        "@com_github_prometheus_client_golang//prometheus",
    ],
)

go_test(
    name = "api_test",
    srcs = [
        "handler_telemetry_test.go",
        "leader_forwarder_test.go",
        "leader_forwarder_tracing_test.go",
        "leader_handler_test.go",
        "leader_handler_tracing_test.go",
    ],
    embed = [":api"],
    gotags = ["test"],
    deps = [
        "@com_github_datadog_dd_trace_go_v2//ddtrace/mocktracer",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
