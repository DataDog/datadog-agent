load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = [
        "config.go",
        "filter.go",
        "mutator.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/admission/mutate/config",
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/cluster-agent/admission",
        "//comp/core/config",
        "//pkg/clusteragent/admission/common",
        "//pkg/clusteragent/admission/metrics",
        "//pkg/clusteragent/admission/mutate/common",
        "//pkg/util/kubernetes/apiserver/common/namespace",
        "//pkg/util/log",
        "//pkg/util/pointer",
        "@io_k8s_api//admission/v1:admission",
        "@io_k8s_api//admissionregistration/v1:admissionregistration",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_client_go//dynamic",
    ],
)

dd_agent_go_test(
    name = "config_test",
    srcs = ["config_test.go"],
    data = glob(["testdata/**"]),
    embed = [":config"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//cmd/cluster-agent/admission",
        "//comp/core/config",
        "//pkg/clusteragent/admission/common",
        "//pkg/clusteragent/admission/mutate/common",
        "//pkg/util/kubernetes/apiserver/common/namespace",
        "//pkg/util/pointer",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_k8s_api//admission/v1:admission",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_apimachinery//pkg/runtime/serializer",
    ],
)
