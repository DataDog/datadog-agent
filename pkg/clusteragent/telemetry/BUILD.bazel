load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "telemetry",
    srcs = ["collector.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/telemetry",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/setup",
        "//pkg/config/utils",
        "//pkg/util/http",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "telemetry_test",
    srcs = ["collector_test.go"],
    embed = [":telemetry"],
    flavors = [
        "base",
        "fips",
    ],
    deps = [
        "//pkg/config/mock",
        "@com_github_stretchr_testify//assert",
    ],
)
