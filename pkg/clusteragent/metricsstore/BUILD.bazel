load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "metricsstore",
    srcs = [
        "store.go",
        "types.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/clusteragent/metricsstore",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/aggregator/sender",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "metricsstore_test",
    srcs = [
        "store_test.go",
        "writer_test.go",
    ],
    embed = [":metricsstore"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//pkg/aggregator/mocksender",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//mock",
    ],
)
