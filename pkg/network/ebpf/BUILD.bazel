load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

# gazelle:dd_agent_go_test off

# gazelle:resolve go github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest //pkg/ebpf/ebpftest:cgo_align

exports_files([
    "conntrack_types_linux.go",
    "conntrack_types_linux_test.go",
    "tuple_types_linux.go",
    "tuple_types_linux_test.go",
    "kprobe_types_linux.go",
    "kprobe_types_linux_test.go",
])

cgo_godefs(
    name = "conntrack_types_godefs",
    src = "conntrack_types.go",
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

cgo_godefs(
    name = "tuple_types_godefs",
    src = "tuple_types.go",
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

cgo_godefs(
    name = "kprobe_types_godefs",
    src = "kprobe_types.go",
    hdrs = ["//pkg/network/ebpf/c/prebuilt:prebuilt_headers"],
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

go_library(
    name = "ebpf",
    srcs = [
        "bpf_module.go",
        "conntrack.go",
        "conntrack_types_linux.go",
        "kprobe.go",
        "kprobe_types_linux.go",
        "tuple.go",
        "tuple_types_linux.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/network/ebpf",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/ebpf/bytecode",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/process/util",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/process/util",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "ebpf_test",
    srcs = [
        "conntrack_types_linux_test.go",
        "kprobe_types_linux_test.go",
        "tuple_types_linux_test.go",
    ],
    embed = [":ebpf"],
    gotags = [
        "test",
        "linux_bpf",
    ],
    # keep: alignment tests require cgo_align, which can not be part
    # of the canonical ebpftest library.
    deps = [
        "//pkg/ebpf/ebpftest:cgo_align",
    ],
)
