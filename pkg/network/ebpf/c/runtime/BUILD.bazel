load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("//bazel/rules/ebpf:ebpf.bzl", "ebpf_program_suite")

_RUNTIME_HDRS = glob(["*.h"])

cc_library(
    name = "runtime_headers",
    hdrs = _RUNTIME_HDRS,
    includes = ["."],
)

filegroup(
    name = "runtime_headers_files",
    srcs = _RUNTIME_HDRS,
    visibility = ["//visibility:public"],
)

ebpf_program_suite(
    name = "usm",
    visibility = ["//visibility:public"],
    src = "usm.c",
    core = True,
    deps = [
        ":runtime_headers",
        "//pkg/ebpf/c:ebpf_c_headers",
        "//pkg/network/ebpf/c:ebpf_c_network",
    ],
)

ebpf_program_suite(
    name = "shared-libraries",
    visibility = ["//visibility:public"],
    src = "shared-libraries.c",
    core = True,
    deps = [
        ":runtime_headers",
        "//pkg/ebpf/c:ebpf_c_headers",
        "//pkg/network/ebpf/c:ebpf_c_network",
    ],
)

ebpf_program_suite(
    name = "conntrack",
    visibility = ["//visibility:public"],
    src = "conntrack.c",
    core = True,
    deps = [
        ":runtime_headers",
        "//pkg/ebpf/c:ebpf_c_headers",
        "//pkg/network/ebpf/c:ebpf_c_network",
    ],
)

exports_files([
    "conntrack-types.h",
    "conntrack.h",
    "conntrack.c",
    "offsetguess-test.c",
    "shared-libraries.c",
    "usm.c",
])
