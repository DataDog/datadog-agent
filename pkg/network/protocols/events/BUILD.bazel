load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

# gazelle:dd_linux_bpf on
# gazelle:resolve go github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest //pkg/ebpf/ebpftest:cgo_align

exports_files([
    "types_linux.go",
    "types_linux_test.go",
])

cgo_godefs(
    name = "types_godefs",
    src = "types.go",
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

go_library(
    name = "events",
    srcs = [
        "batch_consumer.go",
        "batch_offsets.go",
        "batch_reader.go",
        "configuration.go",
        "consumer.go",
        "direct_consumer.go",
        "test_helpers.go",
        "types_linux.go",
        "worker_pool.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/network/protocols/events",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/maps",
        "//pkg/ebpf/modifiers",
        "//pkg/ebpf/names",
        "//pkg/ebpf/perf",
        "//pkg/ebpf/telemetry",
        "//pkg/network/config",
        "//pkg/network/protocols/telemetry",
        "//pkg/network/usm/utils",
        "//pkg/util/kernel",
        "//pkg/util/log",
        "//pkg/util/sync",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_cilium_ebpf//asm",
        "@com_github_cilium_ebpf//features",
        "@com_github_cilium_ebpf//perf",
        "@com_github_cilium_ebpf//ringbuf",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@org_golang_x_sys//unix",
    ],
)

go_test(
    name = "events_test",
    srcs = [
        "batch_offsets_test.go",
        "consumer_test.go",
        "types_linux_test.go",
    ],
    embed = [":events"],
    gotags = ["test"],
    deps = [
        "//pkg/ebpf",
        "//pkg/network/config",
        "//pkg/util/kernel",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "//conditions:default": [],
    }),
)
