load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:resolve go github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest //pkg/ebpf/ebpftest:cgo_align

exports_files([
    "types_linux.go",
    "types_linux_test.go",
])

cgo_godefs(
    name = "types_godefs",
    src = "types.go",
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

go_library(
    name = "http2",
    srcs = [
        "cyclic_map.go",
        "dynamic_table.go",
        "incomplete_stats.go",
        "kernel_requirements.go",
        "model_linux.go",
        "protocol.go",
        "raw_traffic.go",
        "static_table.go",
        "telemetry.go",
        "testutils.go",
        "types_linux.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/network/protocols/http2",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/ebpf",
        "//pkg/network/config",
        "//pkg/network/ebpf",
        "//pkg/network/protocols",
        "//pkg/network/protocols/events",
        "//pkg/network/protocols/http",
        "//pkg/network/protocols/http/testutil",
        "//pkg/network/protocols/telemetry",
        "//pkg/network/usm/buildmode",
        "//pkg/network/usm/utils",
        "//pkg/util/intern",
        "//pkg/util/kernel",
        "//pkg/util/log",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@com_github_davecgh_go_spew//spew",
        "@com_github_stretchr_testify//require",
        "@org_golang_x_net//http2",
        "@org_golang_x_net//http2/hpack",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/network/types",
            "//pkg/process/util",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/network/types",
            "//pkg/process/util",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "http2_test",
    srcs = [
        "cyclic_map_test.go",
        "incomplete_stats_test.go",
        "model_test.go",
        "statkeeper_discovery_test.go",
        "telemetry_test.go",
        "types_linux_test.go",
    ],
    embed = [":http2"],
    deps = [
        "//pkg/ebpf",
        "//pkg/network/config",
        "//pkg/network/protocols/http",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_x_net//http2/hpack",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "//conditions:default": [],
    }),
)
