load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "telemetry",
    srcs = [
        "delta.go",
        "endpoint.go",
        "metric.go",
        "metric_group.go",
        "options.go",
        "prometheus.go",
        "registry.go",
        "registry_testutil.go",
        "reporters.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/network/protocols/telemetry",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//pkg/system-probe/utils",
        "//vendor/github.com/DataDog/datadog-go/v5/statsd",
        "//vendor/go.uber.org/atomic",
        "//vendor/k8s.io/apimachinery/pkg/util/sets",
    ],
)

go_test(
    name = "telemetry_test",
    srcs = [
        "delta_test.go",
        "metric_group_test.go",
        "metric_test.go",
        "utils_test.go",
    ],
    embed = [":telemetry"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/k8s.io/apimachinery/pkg/util/sets",
    ],
)
