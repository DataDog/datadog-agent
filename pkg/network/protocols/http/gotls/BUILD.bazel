load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

exports_files([
    "go_tls_types_linux.go",
    "go_tls_types_linux_test.go",
])

cgo_godefs(
    name = "go_tls_types_godefs",
    src = "go_tls_types.go",
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

go_library(
    name = "gotls",
    srcs = ["go_tls_types_linux.go"],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/network/protocols/http/gotls",
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "gotls_test",
    srcs = ["go_tls_types_linux_test.go"],
    embed = [":gotls"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "//conditions:default": [],
    }),
)
