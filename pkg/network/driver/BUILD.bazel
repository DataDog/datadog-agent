load("@rules_cc//cc:defs.bzl", "cc_library")
load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

exports_files([
    "types.go",
    "types_windows.go",
])

cc_library(
    name = "ddnpmapi",
    hdrs = ["ddnpmapi.h"],
    target_compatible_with = ["@platforms//os:windows"],
)

cgo_godefs(
    name = "types_godefs",
    src = "types.go",
    platform = "windows",
    visibility = ["//visibility:public"],
    deps = [":ddnpmapi"],
)

go_library(
    name = "driver",
    srcs = [
        "ddnpmapi.h",
        "doc.go",
        "driver_windows.go",
        "flow_windows.go",
        "handle.go",
        "types_windows.go",
        "utils.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/network/driver",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "//comp/core/telemetry",
            "//pkg/telemetry",
            "//pkg/util/log",
            "//pkg/util/winutil",
            "@org_golang_x_sys//windows",
            "@org_uber_go_atomic//:atomic",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "driver_test",
    srcs = ["driver_test.go"],
    embed = [":driver"],
    gotags = ["test"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "@com_github_stretchr_testify//assert",
            "@org_golang_x_sys//windows",
        ],
        "//conditions:default": [],
    }),
)
