load("@rules_cc//cc:defs.bzl", "cc_library")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

exports_files([
    "types.go",
    "types_windows.go",
])

cc_library(
    name = "ddnpmapi",
    hdrs = ["ddnpmapi.h"],
    target_compatible_with = ["@platforms//os:windows"],
)

cgo_godefs(
    name = "types_godefs",
    src = "types.go",
    platform = "windows",
    deps = [":ddnpmapi"],
)
