load("@rules_go//go:def.bzl", "go_library", "go_test")

# gazelle:dd_linux_bpf on

go_library(
    name = "procnet",
    srcs = [
        "parser.go",
        "procnet.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/network/usm/procnet",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/util/kernel",
        "//pkg/util/kernel/netns",
    ],
)

go_test(
    name = "procnet_test",
    srcs = [
        "parser_test.go",
        "procnet_test.go",
    ],
    embed = [":procnet"],
    gotags = [
        "test",
        "linux_bpf",
    ],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//pkg/network/protocols/http/testutil",
        "@com_github_stretchr_testify//assert",
    ],
)
