load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "bininspect",
    srcs = [
        "dwarf.go",
        "newproc.go",
        "pclntab.go",
        "symbol_filter.go",
        "symbols.go",
        "types.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/network/go/bininspect",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/network/go/asmscan",
            "//pkg/network/go/binversion",
            "//pkg/network/go/dwarfutils",
            "//pkg/network/go/dwarfutils/locexpr",
            "//pkg/network/go/goid",
            "//pkg/network/go/goversion",
            "//pkg/util/common",
            "//pkg/util/log",
            "//pkg/util/safeelf",
            "@com_github_go_delve_delve//pkg/dwarf/godwarf",
            "@com_github_go_delve_delve//pkg/dwarf/loclist",
            "@com_github_go_delve_delve//pkg/goversion",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/network/go/asmscan",
            "//pkg/network/go/binversion",
            "//pkg/network/go/dwarfutils",
            "//pkg/network/go/dwarfutils/locexpr",
            "//pkg/network/go/goid",
            "//pkg/network/go/goversion",
            "//pkg/util/common",
            "//pkg/util/log",
            "//pkg/util/safeelf",
            "@com_github_go_delve_delve//pkg/dwarf/godwarf",
            "@com_github_go_delve_delve//pkg/dwarf/loclist",
            "@com_github_go_delve_delve//pkg/goversion",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "bininspect_test",
    srcs = [
        "pclntab_test.go",
        "symbols_test.go",
    ],
    data = ["//pkg/network/usm/testdata/site-packages/ddtrace:testdata"],
    embed = [":bininspect"],
    flavors = ["base"],  # keep
    # Use static linking to prevent symbol stripping. The test introspects the
    # binary to look at its symbols.
    static = "on",  # keep
    target_compatible_with = ["@platforms//os:linux"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/network/protocols/http/testutil",
            "//pkg/util/common",
            "//pkg/util/safeelf",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/network/protocols/http/testutil",
            "//pkg/util/common",
            "//pkg/util/safeelf",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
        ],
        "//conditions:default": [],
    }),
)
