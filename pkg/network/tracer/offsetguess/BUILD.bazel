load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:resolve go github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest //pkg/ebpf/ebpftest:cgo_align

exports_files([
    "offsetguess_types_linux.go",
    "offsetguess_types_linux_test.go",
])

cgo_godefs(
    name = "offsetguess_types_godefs",
    src = "offsetguess_types.go",
    hdrs = ["//pkg/network/ebpf/c/prebuilt:prebuilt_headers"],
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

go_library(
    name = "offsetguess",
    srcs = [
        "conntrack.go",
        "offsetguess.go",
        "offsetguess_types_linux.go",
        "overlaps.go",
        "tracer.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/network/tracer/offsetguess",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/maps",
        "//pkg/network/config",
        "//pkg/network/ebpf",
        "//pkg/network/ebpf/probes",
        "//pkg/util/kernel",
        "//pkg/util/kernel/netns",
        "//pkg/util/log",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@com_github_shirou_gopsutil_v4//host",
        "@com_github_vishvananda_netns//:netns",
        "@org_golang_x_sys//unix",
    ],
)

dd_agent_go_test(
    name = "offsetguess_test",
    srcs = ["offsetguess_types_linux_test.go"],
    embed = [":offsetguess"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "//conditions:default": [],
    }),
)
