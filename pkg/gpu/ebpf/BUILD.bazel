load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")
load("//bazel/rules/go_stringer:defs.bzl", "go_stringer")

# gazelle:dd_agent_go_test on
# gazelle:resolve go github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest //pkg/ebpf/ebpftest:cgo_align
# gazelle:go_stringer_src kprobe_types_string_linux.go=kprobe_types_linux.go

exports_files([
    "kprobe_types_linux.go",
    "kprobe_types_linux_test.go",
])

cgo_godefs(
    name = "kprobe_types_godefs",
    src = "kprobe_types.go",
    hdrs = ["//pkg/gpu/ebpf/c:gpu_headers"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "ebpf",
    srcs = [
        "kprobe_types_linux.go",
        "kprobe_types_string_linux.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/gpu/ebpf",
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "ebpf_test",
    srcs = ["kprobe_types_linux_test.go"],
    embed = [":ebpf"],
    target_compatible_with = ["@platforms//os:linux"],  # keep
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "//conditions:default": [],
    }),
)

go_stringer(
    name = "kprobe_types_string_linux",
    src = "kprobe_types_linux.go",
    linecomment = True,
    output = "kprobe_types_string_linux.go",
    types = ["CudaEventType"],
)
