load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "containers",
    srcs = ["containers.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/gpu/containers",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//comp/core/workloadmeta/def",
            "//pkg/gpu/safenvml",
            "//pkg/util/gpu",
            "//pkg/util/kernel",
        ],
        "@rules_go//go/platform:linux": [
            "//comp/core/workloadmeta/def",
            "//pkg/gpu/safenvml",
            "//pkg/util/gpu",
            "//pkg/util/kernel",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "containers_test",
    srcs = ["containers_test.go"],
    embed = [":containers"],
    flavors = [
        "base",
        "fips",
    ],
    deps = select({
        "@rules_go//go/platform:android": [
            "//comp/core/workloadmeta/def",
            "//comp/core/workloadmeta/mock",
            "//pkg/gpu/safenvml",
            "//pkg/gpu/safenvml/testutil",
            "//pkg/gpu/testutil",
            "//pkg/util/gpu",
            "//pkg/util/kernel",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
        ],
        "@rules_go//go/platform:linux": [
            "//comp/core/workloadmeta/def",
            "//comp/core/workloadmeta/mock",
            "//pkg/gpu/safenvml",
            "//pkg/gpu/safenvml/testutil",
            "//pkg/gpu/testutil",
            "//pkg/util/gpu",
            "//pkg/util/kernel",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
        ],
        "//conditions:default": [],
    }),
)
