load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "prm",
    srcs = [
        "fields.go",
        "handler.go",
        "query.go",
        "tlv.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/gpu/prm",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/collector/corechecks/gpu/model",
            "//pkg/system-probe/utils",
            "@com_github_nvidia_go_nvml//pkg/nvml",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/collector/corechecks/gpu/model",
            "//pkg/system-probe/utils",
            "@com_github_nvidia_go_nvml//pkg/nvml",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "prm_test",
    srcs = [
        "handler_test.go",
        "query_test.go",
        "test_fakes_test.go",
    ],
    embed = [":prm"],
    flavors = [
        "base",
        "fips",
    ],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/collector/corechecks/gpu/model",
            "@com_github_nvidia_go_nvml//pkg/nvml",
            "@com_github_stretchr_testify//require",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/collector/corechecks/gpu/model",
            "@com_github_nvidia_go_nvml//pkg/nvml",
            "@com_github_stretchr_testify//require",
        ],
        "//conditions:default": [],
    }),
)
