load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "expvars",
    srcs = [
        "expvars.go",
        "timestamp.go",
        "workers.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/runner/expvars",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/haagent/def",
        "//pkg/collector/check",
        "//pkg/collector/check/id",
        "//pkg/collector/check/stats",
        "//pkg/util/log",
        "@com_github_mohae_deepcopy//:deepcopy",
    ],
)

dd_agent_go_test(
    name = "expvars_test",
    srcs = [
        "expvars_test.go",
        "timestamp_test.go",
        "workers_test.go",
    ],
    embed = [":expvars"],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//comp/haagent/mock",
        "//pkg/collector/check/id",
        "//pkg/collector/check/stats",
        "//pkg/collector/check/stub",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
