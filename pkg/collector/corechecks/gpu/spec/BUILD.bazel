load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "spec",
    srcs = [
        "spec.go",
        "testutil.go",
        "validation.go",
    ],
    embedsrcs = [
        "aggregations.yaml",
        "architectures.yaml",
        "gpu_metrics.yaml",
        "tags.yaml",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/gpu/spec",
    visibility = ["//visibility:public"],
    deps = [
        "@in_yaml_go_yaml_v2//:yaml",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/gpu/testutil",
            "@com_github_nvidia_go_nvml//pkg/nvml",
            "@com_github_stretchr_testify//require",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/gpu/testutil",
            "@com_github_nvidia_go_nvml//pkg/nvml",
            "@com_github_stretchr_testify//require",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "spec_test",
    srcs = [
        "spec_test.go",
        "validation_test.go",
    ],
    embed = [":spec"],
    include_default = False,
    tag_sets = ["nvml"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/gpu/safenvml",
            "//pkg/gpu/testutil",
            "@com_github_nvidia_go_nvml//pkg/nvml",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
            "@in_yaml_go_yaml_v2//:yaml",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/gpu/safenvml",
            "//pkg/gpu/testutil",
            "@com_github_nvidia_go_nvml//pkg/nvml",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
            "@in_yaml_go_yaml_v2//:yaml",
        ],
        "//conditions:default": [],
    }),
)
