    data = glob(["testdata/**"]),
    embed = [":openmetrics"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/metadata/inventorychecks/mock",
        "//pkg/aggregator/mocksender",
        "//pkg/aggregator/sender",
        "//pkg/collector/check",
        "//pkg/collector/check/id",
        "//pkg/collector/check/stats",
        "//pkg/config/mock",
        "//pkg/config/model",
        "//pkg/config/setup",
        "//pkg/metrics/event",
        "//pkg/metrics/servicecheck",
        "//pkg/serializer/types",
        "//pkg/util/flavor",
        "//pkg/util/infratags",
        "@com_github_stretchr_testify//mock",
        "@com_github_stretchr_testify//require",
    ],
)
