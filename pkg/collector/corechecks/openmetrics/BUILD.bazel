        "@com_github_prometheus_prometheus//model/textparse",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)

dd_agent_go_test(
    name = "openmetrics_test",
    srcs = [
        "api_test.go",
        "benchmark_test.go",
        "check_test.go",
        "config_compat_test.go",
        "parse_test.go",
        "upstream_parity_test.go",
