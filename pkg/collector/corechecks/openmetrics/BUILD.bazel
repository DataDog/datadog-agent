load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "openmetrics",
    srcs = [
        "api.go",
        "auth.go",
        "check.go",
        "config.go",
        "labels.go",
        "metadata.go",
        "parse.go",
        "scraper.go",
        "telemetry.go",
        "transform.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/openmetrics",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/common/types",
        "//comp/core/autodiscovery/integration",
        "//comp/core/telemetry/impl",
        "//pkg/aggregator/sender",
        "//pkg/collector/check",
        "//pkg/collector/corechecks",
        "//pkg/config/setup",
        "//pkg/metrics/servicecheck",
        "//pkg/util/http",
        "//pkg/util/log",
        "//pkg/util/option",
        "@com_github_golang_jwt_jwt_v5//:jwt",
