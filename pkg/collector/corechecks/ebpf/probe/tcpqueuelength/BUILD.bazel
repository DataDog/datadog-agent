load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_linux_bpf on

exports_files([
    "tcp_queue_length_kern_types_linux.go",
    "tcp_queue_length_kern_types_linux_test.go",
])

cgo_godefs(
    name = "tcp_queue_length_kern_types_godefs",
    src = "tcp_queue_length_kern_types.go",
    hdrs = ["//pkg/collector/corechecks/ebpf/c/runtime:corecheck_ebpf_headers"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "tcpqueuelength",
    srcs = [
        "tcp_queue_length.go",
        "tcp_queue_length_kern_types_linux.go",
        "tcp_queue_length_stub.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/ebpf/probe/tcpqueuelength",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/collector/corechecks/ebpf/probe/tcpqueuelength/model",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/bytecode/runtime",
        "//pkg/ebpf/features",
        "//pkg/ebpf/maps",
        "//pkg/util/kernel",
        "//pkg/util/log",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@org_golang_x_sys//unix",
    ],
)

# tcp_queue_length_kern_types_linux_test.go and tcp_queue_length_test.go must be
# in separate rules because tcp_queue_length_kern_types_linux_test.go needs
# //pkg/ebpf/ebpftest:cgo_align (for TestCgoAlignment) while
# tcp_queue_length_test.go needs //pkg/ebpf/ebpftest (for TestBuildMode/CORE).
# Both targets share importpath "github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest"
# and cannot coexist in the same rule's deps.

dd_agent_go_test(
    name = "tcpqueuelength_types_test",
    # keep: split from tcpqueuelength_test; see comment above.
    srcs = ["tcp_queue_length_kern_types_linux_test.go"],
    embed = [":tcpqueuelength"],
    # keep: cgo_align has the same importpath as ebpftest; see pkg/ebpf/ebpftest/BUILD.bazel.
    deps = select({
        "@rules_go//go/platform:linux": ["//pkg/ebpf/ebpftest:cgo_align"],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "tcpqueuelength_test",
    # keep: split from tcpqueuelength_types_test; see comment above.
    srcs = ["tcp_queue_length_test.go"],
    embed = [":tcpqueuelength"],
    # keep: needs TestBuildMode/CORE from the main ebpftest library (not cgo_align).
    deps = [
        "//pkg/collector/corechecks/ebpf/probe/tcpqueuelength/model",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode/runtime",
        "//pkg/ebpf/ebpftest",
        "//pkg/util/kernel",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_x_sync//errgroup",
    ],
)
