load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

exports_files([
    "c_types_linux.go",
    "c_types_linux_test.go",
])

cgo_godefs(
    name = "c_types_godefs",
    src = "c_types.go",
    hdrs = ["//pkg/collector/corechecks/ebpf/c/runtime:corecheck_ebpf_headers"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "ebpfcheck",
    srcs = [
        "c_types_linux.go",
        "dedup.go",
        "map.go",
        "map_prog_helper.go",
        "probe.go",
        "prog.go",
        "utils.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/ebpf/probe/ebpfcheck",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/collector/corechecks/ebpf/probe/ebpfcheck/model",
        "//pkg/config/setup",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/maps",
        "//pkg/util/kernel",
        "//pkg/util/log",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_cilium_ebpf//asm",
        "@com_github_cilium_ebpf//btf",
        "@com_github_cilium_ebpf//features",
        "@com_github_cilium_ebpf//link",
        "@com_github_cilium_ebpf//rlimit",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@org_golang_x_exp//constraints",
        "@org_golang_x_sys//unix",
    ],
)

go_test(
    name = "ebpfcheck_test",
    srcs = [
        "c_types_linux_test.go",
        "probe_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":ebpfcheck"],
    gotags = ["test"],
    deps = [
        "//pkg/collector/corechecks/ebpf/probe/ebpfcheck/model",
        "//pkg/ebpf",
        "//pkg/ebpf/ebpftest:cgo_align",
        "//pkg/ebpf/maps",
        "//pkg/util/kernel",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_cilium_ebpf//btf",
        "@com_github_cilium_ebpf//perf",
        "@com_github_cilium_ebpf//rlimit",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_x_sys//unix",
    ],
)
