load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

# gazelle:dd_linux_bpf on

exports_files([
    "c_types_linux.go",
    "c_types_linux_test.go",
])

cgo_godefs(
    name = "c_types_godefs",
    src = "c_types.go",
    hdrs = ["//pkg/collector/corechecks/ebpf/c/runtime:corecheck_ebpf_headers"],
    visibility = ["//visibility:public"],
)

go_library(
    name = "oomkill",
    srcs = [
        "c_types_linux.go",
        "oom_kill.go",
    ],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/ebpf/probe/oomkill",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/collector/corechecks/ebpf/probe/oomkill/model",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/bytecode/runtime",
        "//pkg/ebpf/maps",
        "//pkg/util/kernel",
        "//pkg/util/log",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
        "@org_golang_x_sys//unix",
    ],
)

# c_types_linux_test.go and oom_kill_test.go must be in separate rules because
# c_types_linux_test.go needs //pkg/ebpf/ebpftest:cgo_align (for TestCgoAlignment)
# while oom_kill_test.go needs //pkg/ebpf/ebpftest (for TestBuildMode/CORE).
# Both targets share importpath "github.com/DataDog/datadog-agent/pkg/ebpf/ebpftest"
# and cannot coexist in the same rule's deps.

go_test(
    name = "oomkill_types_test",
    # keep: split from oomkill_test; see comment above.
    srcs = ["c_types_linux_test.go"],
    embed = [":oomkill"],
    gotags = ["test"],
    target_compatible_with = ["@platforms//os:linux"],  # keep
    # keep: cgo_align has the same importpath as ebpftest; see pkg/ebpf/ebpftest/BUILD.bazel.
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/ebpftest:cgo_align",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "oomkill_test",
    # keep: split from oomkill_types_test; see comment above.
    srcs = ["oom_kill_test.go"],
    embed = [":oomkill"],
    gotags = [
        "test",
        "linux_bpf",
    ],
    tags = ["manual"],
    target_compatible_with = ["@platforms//os:linux"],  # keep
    # keep: needs TestBuildMode/CORE from the main ebpftest library (not cgo_align).
    deps = [
        "//pkg/collector/corechecks/ebpf/probe/oomkill/model",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode/runtime",
        "//pkg/ebpf/ebpftest",
        "//pkg/util/kernel",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_x_sys//unix",
    ],
)
