load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "util",
    srcs = [
        "tags.go",
        "types.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/cluster/orchestrator/util",
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "util_test",
    srcs = ["tags_test.go"],
    embed = [":util"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = ["@com_github_stretchr_testify//assert"],
)
