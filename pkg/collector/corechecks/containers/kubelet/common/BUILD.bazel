load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "common",
    srcs = [
        "config.go",
        "pod.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/containers/kubelet/common",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/common/types",
        "//comp/core/tagger/def",
        "//comp/core/tagger/tags",
        "//comp/core/tagger/types",
        "//comp/core/tagger/utils",
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadfilter/util/workloadmeta",
        "//comp/core/workloadmeta/def",
        "//pkg/util/log",
        "//pkg/util/prometheus",
        "@in_yaml_go_yaml_v2//:yaml",
        "@io_k8s_utils//ptr",
    ],
)

dd_agent_go_test(
    name = "common_test",
    srcs = [
        "config_test.go",
        "pod_test.go",
    ],
    embed = [":common"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//comp/core",
        "//comp/core/tagger/types",
        "//comp/core/workloadmeta/def",
        "//comp/core/workloadmeta/fx-mock",
        "//comp/core/workloadmeta/mock",
        "//pkg/util/fxutil",
        "//pkg/util/pointer",
        "@com_github_stretchr_testify//assert",
        "@org_uber_go_fx//:fx",
    ],
)
