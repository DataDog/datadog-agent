    srcs = ["provider_test.go"],
    data = ["//pkg/collector/corechecks/containers/kubelet:testdata"],  # keep
    embed = [":node"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//comp/core/autodiscovery/common/types",
        "//pkg/aggregator/mocksender",
        "//pkg/collector/check/id",
        "//pkg/collector/corechecks/containers/kubelet/common",
        "//pkg/util/kubernetes/kubelet/mock",
