load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "node",
    srcs = ["provider.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/containers/kubelet/provider/node",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/aggregator/sender",
        "//pkg/collector/corechecks/containers/kubelet/common",
        "//pkg/util/kubernetes/kubelet",
