load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "versa",
    srcs = ["versa.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/corechecks/network-devices/versa",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//pkg/aggregator/sender",
        "//pkg/collector/check",
        "//pkg/collector/corechecks",
        "//pkg/collector/corechecks/network-devices/versa/client",
        "//pkg/collector/corechecks/network-devices/versa/payload",
        "//pkg/collector/corechecks/network-devices/versa/report",
        "//pkg/networkdevice/metadata",
        "//pkg/snmp/utils",
        "//pkg/util/log",
        "//pkg/util/option",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)

dd_agent_go_test(
    name = "versa_test",
    srcs = ["versa_test.go"],
    embed = [":versa"],
    deps = [
        "//pkg/collector/corechecks/network-devices/versa/client",
        "//pkg/networkdevice/metadata",
    ],
)
