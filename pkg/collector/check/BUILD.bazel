load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "check",
    srcs = [
        "check.go",
        "check_mock.go",
        "context.go",
        "jmx.go",
        "loader.go",
        "metadata.go",
        "retry.go",
        "shadow.go",
        "unwrap.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/collector/check",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/diagnose/def",
        "//comp/healthplatform/store/def",
        "//comp/metadata/inventorychecks/def",
        "//pkg/aggregator/sender",
        "//pkg/collector/check/id",
        "//pkg/collector/check/stats",
        "//pkg/config/setup",
        "//pkg/util/log",
        "//pkg/util/scrubber",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)

dd_agent_go_test(
    name = "check_test",
    srcs = [
        "check_test.go",
        "id_test.go",
        "jmx_test.go",
        "metadata_test.go",
        "shadow_test.go",
        "unwrap_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":check"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/diagnose/def",
        "//comp/healthplatform/store/def",
        "//pkg/aggregator/sender",
        "//pkg/collector/check/id",
        "//pkg/collector/check/stats",
        "//pkg/collector/check/stub",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)
