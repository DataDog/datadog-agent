# gazelle:exclude api_vtproto.pb.go
# gazelle:go_grpc_compilers @rules_go//proto:go_proto,//bazel/rules/go_proto_compiler:go_grpc_futureproof,//bazel/rules/go_proto_compiler:go_vtproto_serde
load("@protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_go//go:def.bzl", "go_library")
load("@rules_go//proto:def.bzl", "go_proto_library")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

proto_library(
    name = "api_proto",
    srcs = ["api.proto"],
    visibility = ["//visibility:public"],
    deps = [
        "@protobuf//:empty_proto",
        "@protobuf//:timestamp_proto",
    ],
)

go_proto_library(
    name = "api_go_proto",
    compilers = [
        "@rules_go//proto:go_proto",
        "//bazel/rules/go_proto_compiler:go_grpc_futureproof",
        "//bazel/rules/go_proto_compiler:go_vtproto_serde",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/security/proto/api",
    proto = ":api_proto",
    visibility = ["//visibility:public"],
)

go_library(
    name = "api",
    srcs = ["vt_grpc.go"],
    embed = [":api_go_proto"],
    importpath = "github.com/DataDog/datadog-agent/pkg/security/proto/api",
    visibility = ["//visibility:public"],
    deps = [
        "@org_golang_google_grpc//encoding",
        "@org_golang_google_grpc//encoding/proto",
        "@org_golang_google_protobuf//proto",
    ],
)

write_pb_go(
    name = "write_pb_go",
    srcs = {
        ":api_go_proto": [
            "api.pb.go",
            "api_grpc.pb.go",
            "api_vtproto.pb.go",
        ],
    },
)
