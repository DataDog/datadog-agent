load("@bazel_lib//lib:run_binary.bzl", "run_binary")
load("@bazel_lib//lib:write_source_files.bzl", "write_source_file")
load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# Generated by :utils_syscall_table_gen, materialized into syscalls.go via
# :utils_syscall_table. The generated file lives only in bazel-bin; the in-tree
# syscalls.go is the actual source. Exclude it so Gazelle doesn't list it in srcs.
# gazelle:exclude utils_syscall_table_gen.go

run_binary(
    name = "utils_syscall_table_gen",
    srcs = [
        "@linux_v6_13_syscall_64_tbl//file",
        "@linux_v6_13_unistd_h//file",
    ],
    outs = ["utils_syscall_table_gen.go"],
    args = [
        "-amd64-table=$(execpath @linux_v6_13_syscall_64_tbl//file)",
        "-arm64-table=$(execpath @linux_v6_13_unistd_h//file)",
        "-output=$(execpath utils_syscall_table_gen.go)",
    ],
    tool = "//pkg/security/generators/utils_syscall_table_generator",
)

write_source_file(
    name = "utils_syscall_table",
    in_file = ":utils_syscall_table_gen",
    out_file = "syscalls.go",
)

go_library(
    name = "utils",
    srcs = [
        "arch.go",
        "cgroup.go",
        "cidr.go",
        "dev.go",
        "endpoint.go",
        "graph.go",
        "ipnet.go",
        "json.go",
        "limiter.go",
        "lru_interner.go",
        "mount_linux.go",
        "mount_other.go",
        "notifier.go",
        "numcpu.go",
        "proc_common.go",
        "proc_linux.go",
        "proc_other.go",
        "rand.go",
        "scrubber.go",
        "stat_unix.go",
        "stringkeys.go",
        "sys.go",
        "syscalls.go",
        "tags.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/security/utils",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/logs/agent/config",
        "//pkg/process/procutil",
        "//pkg/template/text",
        "//pkg/util/hostport",
        "//pkg/util/scrubber",
        "//pkg/version",
        "@com_github_hashicorp_golang_lru_v2//simplelru",
        "@com_github_mailru_easyjson//:easyjson",
        "@com_github_mailru_easyjson//jwriter",
        "@com_github_masterminds_semver_v3//:semver",
        "@com_github_shirou_gopsutil_v4//process",
        "@org_uber_go_atomic//:atomic",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/security/secl/containerutils",
            "//pkg/security/secl/model/sharedconsts",
            "//pkg/security/seclog",
            "//pkg/security/utils/cgroup",
            "//pkg/util/kernel",
            "@com_github_moby_sys_mountinfo//:mountinfo",
            "@com_github_shirou_gopsutil_v4//cpu",
            "@org_golang_x_sys//unix",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/security/secl/containerutils",
            "//pkg/security/secl/model/sharedconsts",
            "//pkg/security/seclog",
            "//pkg/security/utils/cgroup",
            "//pkg/util/kernel",
            "@com_github_moby_sys_mountinfo//:mountinfo",
            "@com_github_shirou_gopsutil_v4//cpu",
            "@org_golang_x_sys//unix",
        ],
        "//conditions:default": [],
    }),
