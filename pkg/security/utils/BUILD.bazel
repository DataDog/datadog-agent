    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/security/seclog",
            "//pkg/security/utils/cgroup",
            "//pkg/util/kernel",
            "//vendor/github.com/DataDog/datadog-agent/pkg/security/secl/containerutils",
            "//vendor/github.com/DataDog/datadog-agent/pkg/security/secl/model/sharedconsts",
            "//vendor/github.com/moby/sys/mountinfo",
