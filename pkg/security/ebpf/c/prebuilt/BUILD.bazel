load("//bazel/rules:ebpf.bzl", "ebpf_prog")

_COMMON_DEPS = [
    "//pkg/ebpf/c:ebpf_c_headers",
    "//pkg/security/ebpf/c/include:security_ebpf_headers",
]

_SECURITY_FLAGS = [
    "-Ipkg/security/ebpf/c/include",
    "-g",
]

# runtime-security: basic variant
ebpf_prog(
    name = "runtime-security",
    src = "probe.c",
    extra_flags = _SECURITY_FLAGS,
    deps = _COMMON_DEPS,
)

# runtime-security: syscall wrapper variant
ebpf_prog(
    name = "runtime-security-syscall-wrapper",
    src = "probe.c",
    extra_flags = _SECURITY_FLAGS + ["-DUSE_SYSCALL_WRAPPER"],
    deps = _COMMON_DEPS,
)

# runtime-security: fentry variant (syscall wrapper + fentry)
ebpf_prog(
    name = "runtime-security-fentry",
    src = "probe.c",
    extra_flags = _SECURITY_FLAGS + [
        "-DUSE_SYSCALL_WRAPPER",
        "-DUSE_FENTRY",
    ],
    deps = _COMMON_DEPS,
)

# offset guesser
ebpf_prog(
    name = "runtime-security-offset-guesser",
    src = "offset-guesser.c",
    extra_flags = _SECURITY_FLAGS,
    deps = _COMMON_DEPS,
)
