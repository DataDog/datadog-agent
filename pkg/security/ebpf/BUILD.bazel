load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ebpf",
    srcs = [
        "compile.go",
        "compile_unsupported.go",
        "features_ebpf.go",
        "features_unsupported.go",
        "loader.go",
        "manager.go",
        "manager_ebpf.go",
        "manager_noebpf.go",
        "map.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/security/ebpf",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/bytecode/runtime",
        "//pkg/ebpf/maps",
        "//pkg/security/probe/config",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf",
            "//pkg/ebpf/modifiers",
            "//pkg/security/ebpf/probes",
            "//pkg/security/seclog",
            "@com_github_cilium_ebpf//asm",
            "@com_github_datadog_ebpf_manager//:ebpf-manager",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf",
            "//pkg/ebpf/modifiers",
            "//pkg/security/ebpf/probes",
            "//pkg/security/seclog",
            "@com_github_cilium_ebpf//asm",
            "@com_github_datadog_ebpf_manager//:ebpf-manager",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "ebpf_test",
    srcs = ["compile_test.go"],
    embed = [":ebpf"],
    gotags = ["test"],
    deps = [
        "//pkg/ebpf/ebpftest",
        "//pkg/security/probe/config",
        "//pkg/system-probe/config",
        "@com_github_stretchr_testify//require",
    ],
)
