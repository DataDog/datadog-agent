load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/cws_codegen:defs.bzl", "operators")

# Source-level export so the //pkg/security/secl/model:event_deep_copy_*
# Bazel codegens can resolve eval.MatchingValue, eval.MatchingSubExpr, the
# eval.Field alias, and eval.EventType.
exports_files(
    [
        "context.go",
        "event.go",
        "field.go",
    ],
    visibility = ["//pkg/security/secl/model:__pkg__"],
)

go_library(
    name = "eval",
    srcs = [
        "cidr.go",
        "context.go",
        "context_functests.go",
        "context_regular.go",
        "dns_linux.go",
        "dns_others.go",
        "errors.go",
        "eval.go",
        "eval_operators.go",
        "evaluators.go",
        "event.go",
        "field.go",
        "glob.go",
        "macro.go",
        "model.go",
        "oo_case_insensitive.go",
        "oo_extension.go",
        "oo_glob_cmp.go",
        "operators.go",
        "opts.go",
        "pattern.go",
        "registers.go",
        "rule.go",
        "state.go",
        "strings.go",
        "strings_linux.go",
        "strings_others.go",
        "utils.go",
        "variables.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/security/secl/compiler/eval",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/security/secl/compiler/ast",
        "//vendor/github.com/DataDog/datadog-agent/pkg/security/secl/utils",
        "//vendor/github.com/alecthomas/participle/lexer",
        "//vendor/github.com/charlievieth/strcase",
        "//vendor/github.com/jellydator/ttlcache/v3:ttlcache",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/weppos/publicsuffix-go/publicsuffix",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/weppos/publicsuffix-go/publicsuffix",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "eval_test",
    srcs = [
        "eval_test.go",
        "glob_test.go",
        "model_test.go",
        "oo_case_insensitive_test.go",
        "oo_glob_cmp_test.go",
        "pattern_test.go",
        "strings_linux_test.go",
        "strings_test.go",
    ],
    embed = [":eval"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/security/secl/compiler/ast",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/golang.org/x/text/cases",
        "//vendor/golang.org/x/text/language",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/weppos/publicsuffix-go/publicsuffix",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/weppos/publicsuffix-go/publicsuffix",
        ],
        "//conditions:default": [],
    }),
)

operators(
    name = "eval_operators",
    output = "eval_operators.go",
)
