load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/cws_codegen:defs.bzl", "accessors", "bpf_maps_generator", "event_deep_copy")
load("//bazel/rules/go_stringer:defs.bzl", "go_stringer")

exports_files(
    glob(
        ["*.go"],
        # All generator-managed .go files are exported by their own macro
        # (bazel/rules/cws_codegen:defs.bzl, bazel/rules/go_stringer:defs.bzl)
        # with the right per-output visibility — don't re-export them here.
        exclude = [
            "accessors_unix.go",
            "accessors_windows.go",
            "consts_map_names_linux.go",
            "event_deep_copy_unix.go",
            "event_deep_copy_windows.go",
            "field_accessors_unix.go",
            "field_accessors_windows.go",
            "field_handlers_unix.go",
            "field_handlers_windows.go",
            "model_string.go",
        ],
    ),
    visibility = ["//pkg/security/seclwin/model:__pkg__"],
)

go_stringer(
    name = "model_string",
    src = "model.go",
    linecomment = True,
    output = "model_string.go",
    types = ["HashState"],
)

# TODO(ABLD-420): hand-wired because the matching //go:generate directive lives
# in pkg/security/ebpf/map.go, which is currently gazelle-excluded. Once
# pkg/security/ebpf is gazelle-managed, teach the //bazel/rules/cws_codegen
# extension to parse this directive (and either emit the rule here, or move the
# directive into this package) and drop this manual call.
bpf_maps_generator(
    name = "consts_map_names_linux",
    package_name = "model",
    header = "//pkg/security/ebpf/c/include:maps.h",
    output = "consts_map_names_linux.go",
)

# TODO(ABLD-420): plug these into the //bazel/rules/cws_codegen Gazelle
# extension so the calls are emitted from the matching //go:generate directives
# in model_unix.go / model_windows.go instead of being hand-wired.
# Generator outputs (input==output cycles if passed back to the parser).
_EVENT_DEEP_COPY_GENERATED = [
    "accessors_unix.go",
    "accessors_windows.go",
    "consts_map_names_linux.go",
    "event_deep_copy_unix.go",
    "event_deep_copy_windows.go",
    "field_accessors_unix.go",
    "field_accessors_windows.go",
    "field_handlers_unix.go",
    "field_handlers_windows.go",
    "model_string.go",
]

# In-package files the event_deep_copy generator must parse to resolve type
# definitions referenced from the model (alias types like EventType,
# EventFilteringProfileState; siblings like ArgsEnvs, etc.). The lists are
# build-tag-filtered by filename so the parser doesn't see two `Event`
# definitions when running for one platform.
EVENT_DEEP_COPY_PKG_SRCS_UNIX = glob(
    ["*.go"],
    exclude = _EVENT_DEEP_COPY_GENERATED + [
        "*_windows.go",
        "*_test.go",
    ],
)

EVENT_DEEP_COPY_PKG_SRCS_WINDOWS = glob(
    ["*.go"],
    exclude = _EVENT_DEEP_COPY_GENERATED + [
        "*_unix.go",
        "*_linux.go",
        "*_linux_*.go",
        "*_darwin.go",
        "*_unsupported.go",
        "*_test.go",
    ],
)

[
    event_deep_copy(
        name = "event_deep_copy_{}".format(variant["suffix"]),
        srcs = variant["pkg_srcs"] + variant["external_srcs"],
        model = variant["model"],
        output = "event_deep_copy_{}.go".format(variant["suffix"]),
        package_path = "github.com/DataDog/datadog-agent/pkg/security/secl/model",
        tags = variant["tags"],
        types_file = "model.go",
    )
    for variant in [
        {
            "tags": "unix",
            "model": "model_unix.go",
            "suffix": "unix",
            "pkg_srcs": EVENT_DEEP_COPY_PKG_SRCS_UNIX,
            # External package files providing types referenced by the model
            # whose sub-fields the generator needs to recurse into. Keep this
            # list aligned with model_unix.go's import block — adding a struct
            # field of a new external type means adding its source label here.
            #
            # gopacket.CaptureInfo is intentionally absent: gazelle's
            # go_repository for @com_github_google_gopacket doesn't export its
            # source files, and CaptureInfo is value-only so the generator's
            # zero-children fallback (return fieldToCopy) is semantically
            # equivalent to a per-field copy. If gopacket ever grows a
            # non-value field, expose its sources here and drop the fallback.
            "external_srcs": [
                "//pkg/discovery/tracermetadata/model:tracer_metadata.go",
                "//pkg/security/secl/compiler/eval:context.go",
                "//pkg/security/secl/compiler/eval:event.go",
                "//pkg/security/secl/compiler/eval:field.go",
                "//pkg/security/secl/model/utils:uint128.go",
            ],
        },
        {
            "tags": "windows",
            "model": "model_windows.go",
            "suffix": "windows",
            "pkg_srcs": EVENT_DEEP_COPY_PKG_SRCS_WINDOWS,
            "external_srcs": [
                "//pkg/discovery/tracermetadata/model:tracer_metadata.go",
                "//pkg/security/secl/compiler/eval:context.go",
                "//pkg/security/secl/compiler/eval:event.go",
                "//pkg/security/secl/compiler/eval:field.go",
            ],
        },
    ]
]

[
    accessors(
        name = "accessors_{}".format(variant["name"]),
        srcs = variant["consts"],
        doc_output = variant["doc"],
        field_accessors_output = "field_accessors_{}.go".format(variant["suffix"]),
        field_handlers = "field_handlers_{}.go".format(variant["suffix"]),
        model = variant["model"],
        output = "accessors_{}.go".format(variant["suffix"]),
        package_path = "github.com/DataDog/datadog-agent/pkg/security/secl/model",
        tags = variant["tags"],
        types_file = "model.go",
        visibility = variant["visibility"],
    )
    for variant in [
        {
            "name": "unix",
            "tags": "unix",
            "model": "model_unix.go",
            "suffix": "unix",
            "doc": "secl_linux.json",
            "consts": [
                "consts_common.go",
                "consts_linux.go",
                "consts_linux_amd64.go",
                "consts_linux_arm.go",
                "consts_linux_arm64.go",
            ],
            "visibility": ["//docs/cloud-workload-security:__pkg__"],
        },
        {
            "name": "windows",
            "tags": "windows",
            "model": "model_windows.go",
            "suffix": "windows",
            "doc": "secl_windows.json",
            "consts": [
                "consts_common.go",
                "consts_windows.go",
            ],
            # seclwin consumes accessors_windows.go and field_handlers_windows.go;
            # docs/cloud-workload-security consumes secl_windows.json.
            "visibility": [
                "//docs/cloud-workload-security:__pkg__",
                "//pkg/security/seclwin/model:__pkg__",
            ],
        },
    ]
]

