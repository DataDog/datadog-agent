    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = ["//pkg/dyninst/symdb/uploader"],
)

go_test(
    name = "symdbprinter_test",
    srcs = ["symdbprinter_test.go"],
    embed = [":symdbprinter"],
    gotags = [
        "test",
        "linux_bpf",
