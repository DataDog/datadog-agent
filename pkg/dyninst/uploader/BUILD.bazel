load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "uploader",
    srcs = [
        "batcher.go",
        "batcher_state.go",
        "config.go",
        "diagnostics.go",
        "doc.go",
        "logs.go",
        "metrics.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/dyninst/uploader",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/util/log",
        "@org_golang_x_time//rate",
    ],
)

go_test(
    name = "uploader_test",
    srcs = [
        "batcher_snapshot_test.go",
        "config_test.go",
        "main_test.go",
        "uploader_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":uploader"],
    gotags = [
        "test",
        "linux_bpf",
    ],
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//pkg/dyninst/dyninsttest",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v3//:yaml",
        "@org_uber_go_goleak//:goleak",
    ],
)
