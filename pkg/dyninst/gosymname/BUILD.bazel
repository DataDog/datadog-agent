load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# Unlike most of pkg/dyninst, this package is plain Go with no linux_bpf-gated
# sources, so it opts back into flavored tests.
# gazelle:dd_linux_bpf off
# gazelle:dd_agent_go_test on

go_library(
    name = "gosymname",
    srcs = [
        "class.go",
        "doc.go",
        "escape.go",
        "generic.go",
        "interpretation.go",
        "parse.go",
        "source.go",
        "symbol.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/dyninst/gosymname",
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "gosymname_test",
    srcs = [
        "benchmark_test.go",
        "comparison_test.go",
        "escape_test.go",
        "fuzz_test.go",
        "generic_test.go",
        "symbol_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":gosymname"],
    deps = [
        "@com_github_goccy_go_yaml//:go-yaml",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
