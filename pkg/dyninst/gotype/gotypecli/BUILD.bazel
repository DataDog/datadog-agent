load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "gotypecli_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/dyninst/gotype/gotypecli",
    tags = ["manual"],
    visibility = ["//visibility:private"],
    deps = [
        "//pkg/dyninst/gotype",
        "//pkg/dyninst/gotype/gotypeprinter",
        "//pkg/dyninst/object",
