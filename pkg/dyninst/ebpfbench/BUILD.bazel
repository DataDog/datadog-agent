load("@rules_go//go:def.bzl", "go_binary", "go_library")

go_library(
    name = "ebpfbench_lib",
    srcs = ["main.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/dyninst/ebpfbench",
    tags = ["manual"],
    visibility = ["//visibility:private"],
    deps = [
        "//pkg/dyninst/compiler",
        "//pkg/dyninst/ir",
        "//pkg/dyninst/irgen",
        "//pkg/dyninst/loader",
        "//pkg/dyninst/object",
        "//pkg/dyninst/output",
        "//pkg/dyninst/process",
        "//pkg/dyninst/testprogs",
        "//pkg/dyninst/uprobe",
        "@com_github_cilium_ebpf//ringbuf",
    ],
)

go_binary(
    name = "ebpfbench",
    embed = [":ebpfbench_lib"],
    gotags = ["linux_bpf"],
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:public"],
)
