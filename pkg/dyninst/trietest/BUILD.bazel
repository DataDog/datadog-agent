    cdeps = ["//pkg/dyninst/ebpf:dyninst_ebpf_headers"],
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/dyninst/trietest",
    tags = ["manual"],
    visibility = ["//visibility:public"],
