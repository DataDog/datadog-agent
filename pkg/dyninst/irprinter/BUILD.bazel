load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "irprinter",
    srcs = [
        "doc.go",
        "json.go",
        "yaml.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/dyninst/irprinter",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/dyninst/ir",
        "//vendor/github.com/go-json-experiment/json",
        "//vendor/github.com/go-json-experiment/json/jsontext",
        "//vendor/go.yaml.in/yaml/v3:yaml",
    ],
)

go_test(
    name = "irprinter_test",
    srcs = ["example_test.go"],
    embed = [":irprinter"],
    gotags = ["test"],
    deps = ["//pkg/dyninst/ir"],
)
