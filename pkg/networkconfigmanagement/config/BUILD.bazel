load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "config",
    srcs = ["config.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/networkconfigmanagement/config",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/ipc/def",
        "//comp/core/ipc/httphelpers",
        "//pkg/snmp/utils",
        "//pkg/util/log",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)

go_test(
    name = "config_test",
    srcs = ["config_test.go"],
    embed = [":config"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)
