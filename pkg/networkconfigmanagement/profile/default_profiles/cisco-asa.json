{
  "commands": [
    {
      "type": "version",
      "values": [
        "show version"
      ]
    },
    {
      "type": "running",
      "values": [
        "more system:running-config"
      ],
      "processing_rules": {
        "metadata": [],
        "validation": [
          {
            "type": "valid_output",
            "pattern": "ASA Version \\d+\\.\\d+\\(\\d+\\)"
          }
        ],
        "redaction": [
          {
            "regex": "(?m)^(snmp-server community).*",
            "replacement": "$1 <secret hidden>"
          },
          {
            "regex": "(?m)^(enable password) \\S+( .*)?$",
            "replacement": "$1 <secret hidden>$2"
          },
          {
            "regex": "(?m)^(passwd) \\S+( .*)?$",
            "replacement": "$1 <secret hidden>$2"
          },
          {
            "regex": "(?m)^(username \\S+ password) \\S+( .*)?$",
            "replacement": "$1 <secret hidden>$2"
          },
          {
            "regex": "(ikev[12] ((remote|local)-authentication )?pre-shared-key( hex)?) (\\S+)",
            "replacement": "$1 <secret hidden>"
          },
          {
            "regex": "(?m)^(crypto isakmp key) \\S+( .*)?$",
            "replacement": "$1 <secret hidden>$2"
          },
          {
            "regex": "(?m)^(aaa-server \\S+(?: \\(\\S+\\))? host \\S+\\n(?: [^\\n]+\\n)* +key) \\S+$",
            "replacement": "$1 <secret hidden>",
            "multiline": true
          },
          {
            "regex": "ldap-login-password (\\S+)",
            "replacement": "ldap-login-password <secret hidden>"
          },
          {
            "regex": "(?m)^snmp-server host (.*) community (\\S+)",
            "replacement": "snmp-server host $1 community <secret hidden>"
          },
          {
            "regex": "(?m)^(failover key) .+",
            "replacement": "$1 <secret hidden>"
          },
          {
            "regex": "(?m)^(\\s+ospf message-digest-key \\d+ md5) .+",
            "replacement": "$1 <secret hidden>"
          },
          {
            "regex": "(?m)^(\\s+ospf authentication-key) .+",
            "replacement": "$1 <secret hidden>"
          },
          {
            "regex": "(?m)^(\\s+neighbor \\S+ password) .+",
            "replacement": "$1 <secret hidden>"
          }
        ]
      }
    }
  ]
}
