load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "telemetry",
    srcs = ["telemetry.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/networkpath/telemetry",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/networkdevice/utils",
        "//pkg/networkpath/metricsender",
        "//pkg/networkpath/payload",
    ],
)

dd_agent_go_test(
    name = "telemetry_test",
    srcs = ["telemetry_test.go"],
    embed = [":telemetry"],
    deps = [
        "//pkg/metrics",
        "//pkg/networkpath/metricsender",
        "//pkg/networkpath/payload",
        "@com_github_stretchr_testify//assert",
    ],
)
