load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "legacy",
    srcs = [
        "converter.go",
        "docker.go",
        "importer.go",
        "kubernetes.go",
        "no_docker.go",
        "trace-agent.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/config/legacy",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/providers",
        "//pkg/collector/corechecks/containers/docker",
        "//pkg/config/model",
        "//pkg/config/setup",
        "//pkg/config/utils",
        "@in_gopkg_ini_v1//:ini_v1",
        "@in_yaml_go_yaml_v2//:yaml",
    ],
)

dd_agent_go_test(
    name = "legacy_test",
    srcs = [
        "converter_test.go",
        "docker_test.go",
        "importer_test.go",
        "kubernetes_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":legacy"],
    deps = [
        "//pkg/config/mock",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
