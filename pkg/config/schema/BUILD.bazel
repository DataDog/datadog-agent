load("@rules_go//go:def.bzl", "go_library", "go_test")
load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "pkg_files")
load("//bazel/rules:zstd.bzl", "zstd_compress")

ZSTD_ARGS = [
    "--no-check",  # match DataDog/zstd Go library behavior: no XXH64 frame checksum
    "-5",  # match DataDog/zstd: DefaultCompression = 5
]

# yaml/core_schema.yaml references per-section sub-files (yaml/logs_config.yaml,
# yaml/apm_config.yaml, ...) via $ref. Merge them into a single file before
# compression so the embedded Go artifact stays a single self-contained
# schema and the Go loader doesn't need to handle $ref resolution.
genrule(
    name = "merged_core_schema",
    srcs = glob(["yaml/*.yaml"]),
    outs = ["core_schema.merged.yaml"],
    cmd = "$(execpath //tasks:merge_schema) $(execpath yaml/core_schema.yaml) $@",
    tools = ["//tasks:merge_schema"],
)

zstd_compress(
    name = "compress_core",
    src = ":merged_core_schema",
    out = "compressed/core_schema.yaml.zstd",
    args = ZSTD_ARGS,
)

zstd_compress(
    name = "compress_system_probe",
    src = "yaml/system-probe_schema.yaml",
    out = "compressed/system-probe_schema.yaml.zstd",
    args = ZSTD_ARGS,
)

pkg_files(
    name = "compressed",
    srcs = [
        ":compress_core",
        ":compress_system_probe",
    ],
    prefix = "compressed",
)

pkg_install(
    name = "install_compressed",
    srcs = [":compressed"],
)

go_library(
    name = "schema",
    srcs = ["schema.go"],
    embedsrcs = [
        "compressed/.embed",
        "compressed/core_schema.yaml.zstd",
        "compressed/system-probe_schema.yaml.zstd",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/config/schema",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_datadog_zstd//:zstd",
        "@com_github_santhosh_tekuri_jsonschema_v6//:jsonschema",
        "@in_yaml_go_yaml_v3//:yaml",
    ],
)

go_test(
    name = "schema_test",
    srcs = ["schema_test.go"],
    embed = [":schema"],
    gotags = ["test"],
    deps = [
        "@com_github_santhosh_tekuri_jsonschema_v6//:jsonschema",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//assert/yaml",
    ],
)
