load("@bazel_lib//lib:run_binary.bzl", "run_binary")
load("@bazel_lib//lib:write_source_files.bzl", "write_source_files")
load("@rules_go//go:def.bzl", "go_library", "go_test")

run_binary(
    name = "compress",
    srcs = [
        "core_schema.yaml",
        "system-probe_schema.yaml",
    ],
    outs = [
        "core_schema.yaml.zstd",
        "system-probe_schema.yaml.zstd",
    ],
    args = [
        "$(location core_schema.yaml)",
        "$(location core_schema.yaml.zstd)",
        "$(location system-probe_schema.yaml)",
        "$(location system-probe_schema.yaml.zstd)",
    ],
    tool = "//pkg/config/schema/compressor",
)

write_source_files(
    name = "write_compressed",
    files = {
        "compressed/core_schema.yaml.zstd": ":core_schema.yaml.zstd",
        "compressed/system-probe_schema.yaml.zstd": ":system-probe_schema.yaml.zstd",
    },
)

go_library(
    name = "schema",
    srcs = ["schema.go"],
    embedsrcs = [
        "compressed/core_schema.yaml.zstd",
        "compressed/system-probe_schema.yaml.zstd",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/config/schema",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_datadog_zstd//:zstd",
        "@com_github_santhosh_tekuri_jsonschema_v6//:jsonschema",
        "@in_yaml_go_yaml_v3//:yaml",
    ],
)

go_test(
    name = "schema_test",
    srcs = ["schema_test.go"],
    embed = [":schema"],
    gotags = ["test"],
    deps = [
        "@com_github_santhosh_tekuri_jsonschema_v6//:jsonschema",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//assert/yaml",
    ],
)
