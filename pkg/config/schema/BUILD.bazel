load("@bazel_lib//lib:write_source_files.bzl", "write_source_files")
load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules:zstd.bzl", "zstd_compress")

ZSTD_ARGS = [
    "--no-check",  # match DataDog/zstd Go library behavior: no XXH64 frame checksum
    "-5",  # match DataDog/zstd: DefaultCompression = 5
]

zstd_compress(
    name = "compress_core",
    src = "core_schema.yaml",
    out = "compressed/core_schema.yaml.zstd",
    args = ZSTD_ARGS,
)

zstd_compress(
    name = "compress_system_probe",
    src = "system-probe_schema.yaml",
    out = "compressed/system-probe_schema.yaml.zstd",
    args = ZSTD_ARGS,
)

# diff_test = False suppresses the auto-generated _test rules that assert the
# source .zstd files exist and match — those would fail before
# `bazel run :write_compressed` is executed, blocking `bazel test //...`.
write_source_files(
    name = "write_compressed",
    diff_test = False,
    files = {
        "compressed/core_schema.yaml.zstd": ":compress_core",
        "compressed/system-probe_schema.yaml.zstd": ":compress_system_probe",
    },
)

# The .zstd files under compressed/ are generated by :write_compressed and are
# not committed to the repo. They are picked up by glob when present so that
# production builds embed them; when absent (e.g. during `bazel test`), only
# the .embed placeholder is embedded and tests mock getSchema.
go_library(
    name = "schema",
    srcs = [
        "schema.go",
        "schema_embed.go",
    ],
    embedsrcs = [
        "compressed/.embed",
        ":compress_core",
        ":compress_system_probe",
    ],  # keep
    importpath = "github.com/DataDog/datadog-agent/pkg/config/schema",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_datadog_zstd//:zstd",
        "@com_github_santhosh_tekuri_jsonschema_v6//:jsonschema",
        "@in_yaml_go_yaml_v3//:yaml",
    ],
)

go_test(
    name = "schema_test",
    srcs = ["schema_test.go"],
    embed = [":schema"],
    gotags = ["test"],
    importpath = "github.com/DataDog/datadog-agent/pkg/config/schema",
    deps = [
        "@com_github_santhosh_tekuri_jsonschema_v6//:jsonschema",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//assert/yaml",
    ],
)
