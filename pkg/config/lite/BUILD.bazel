load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "lite",
    srcs = [
        "enc.go",
        "env.go",
        "file.go",
        "fuzzy.go",
        "lite.go",
        "parse.go",
        "regex.go",
        "rescue.go",
        "runtime.go",
        "strings.go",
        "types.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/config/lite",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/schema",
        "@com_github_datadog_agent_payload_v5//healthplatform",
        "@org_golang_google_protobuf//types/known/structpb",
