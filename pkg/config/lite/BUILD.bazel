go_test(
    name = "lite_test",
    srcs = [
        "lite_test.go",
        "rescue_test.go",
    ],
    embed = [":lite"],
    gotags = ["test"],
    deps = [
        "@com_github_datadog_agent_payload_v5//healthplatform",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
