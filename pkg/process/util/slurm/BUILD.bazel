load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "slurm",
    srcs = ["slurm.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/process/util/slurm",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/security/utils",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/security/utils",
        ],
        "//conditions:default": [],
