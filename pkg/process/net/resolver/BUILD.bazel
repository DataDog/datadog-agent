load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "resolver",
    srcs = ["resolver.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/process/net/resolver",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//pkg/process/util",
        "//pkg/process/util/containers",
        "//pkg/util/log",
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_datadog_agent_payload_v5//process",
        "@org_go4_intern//:intern",
    ],
)

dd_agent_go_test(
    name = "resolver_test",
    srcs = ["resolver_test.go"],
    embed = [":resolver"],
    deps = [
        "//pkg/process/util/containers/mocks",
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_datadog_agent_payload_v5//process",
        "@com_github_stretchr_testify//assert",
        "@org_uber_go_mock//gomock",
    ],
)
