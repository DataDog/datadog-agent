load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

filegroup(
    name = "nodejs_testdata",
    srcs = glob(["testdata/**"]),
    visibility = ["//visibility:public"],
)

go_library(
    name = "nodejs",
    srcs = ["nodejs.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/process/metadata/parser/nodejs",
    visibility = ["//visibility:public"],
    deps = ["//pkg/util/log"],
)

dd_agent_go_test(
    name = "nodejs_test",
    srcs = ["nodejs_test.go"],
    data = glob(["testdata/**"]),
    embed = [":nodejs"],
    deps = ["@com_github_stretchr_testify//assert"],
)
