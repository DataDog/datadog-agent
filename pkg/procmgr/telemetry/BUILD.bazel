load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "telemetry",
    srcs = [
        "client.go",
        "client_grpc.go",
        "client_grpc_unix.go",
        "client_grpc_windows.go",
        "collector.go",
        "collector_linux.go",
        "collector_other.go",
        "collector_windows.go",
        "paths_linux.go",
        "paths_other.go",
        "paths_windows.go",
        "reporter.go",
        "services.go",
        "telemetry.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/procmgr/telemetry",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//pkg/proto/pbgo/procmgr",
        "//pkg/util/defaultpaths",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_grpc//credentials/insecure",
    ] + select({
        "@rules_go//go/platform:windows": [
            "//pkg/util/winutil",
            "@com_github_microsoft_go_winio//:go-winio",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "telemetry_test",
    srcs = ["collector_test.go"],
    embed = [":telemetry"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
