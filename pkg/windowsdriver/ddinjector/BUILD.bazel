load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "ddinjector",
    srcs = [
        "ddinjector.go",
        "ddinjector_testutil.go",
        "types.go",
    ],
    cdeps = ["//pkg/windowsdriver/include:ddinjector_public"],  # keep
    cgo = True,
    importpath = "github.com/DataDog/datadog-agent/pkg/windowsdriver/ddinjector",
    target_compatible_with = ["@platforms//os:windows"],  # keep
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "//comp/core/telemetry/def",
            "//pkg/util/log",
            "@org_golang_x_sys//windows",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "ddinjector_test",
    srcs = ["ddinjector_test.go"],
    embed = [":ddinjector"],
    gotags = ["test"],
    target_compatible_with = ["@platforms//os:windows"],  # keep
    deps = select({
        "@rules_go//go/platform:windows": [
            "@com_github_stretchr_testify//assert",
            "@org_golang_x_sys//windows",
        ],
        "//conditions:default": [],
    }),
)
