        "//pkg/aggregator/sender",
        "//pkg/collector/check/id",
        "//pkg/config/setup",
        "//pkg/util/hostname",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "vbrsender_test",
    srcs = ["vbrsender_test.go"],
    embed = [":vbrsender"],
    deps = [
        "//pkg/collector/check/stats",
        "//pkg/config/setup",
        "//pkg/metrics/event",
        "//pkg/metrics/servicecheck",
        "//pkg/serializer/types",
        "//pkg/util/infratags",
        "@com_github_stretchr_testify//require",
    ],
