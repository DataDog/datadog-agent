"""Scripts and configuration embedded into the installer as data."""

load("@rules_go//go:def.bzl", "go_library")

filegroup(
    name = "tmpl_gen",
    srcs = glob(["tmpl/gen/**"]),
    visibility = [
        "//pkg/fleet/installer/packages/embedded/tmplgen:__pkg__",
        "//visibility:public",
    ],
)

go_library(
    name = "embedded",
    srcs = ["embed.go"],
    embedsrcs = [
        "scripts/dd-cleanup",
        "scripts/dd-container-install",
        "scripts/dd-host-install",
    ] + glob([
        "tmpl/gen/debrpm/*.service",
        "tmpl/gen/debrpm/*.yaml",
        "tmpl/gen/debrpm-nocap/*.yaml",
        "tmpl/gen/oci/*.service",
        "tmpl/gen/oci/*.yaml",
        "tmpl/gen/oci-nocap/*.yaml",
    ]),
    importpath = "github.com/DataDog/datadog-agent/pkg/fleet/installer/packages/embedded",
    visibility = ["//visibility:public"],
)
