description: Datadog Agent Data Plane
command: '{{.InstallDir}}/bin/agent/agent-data-plane.exe'
args:
  - --config
  - '{{.EtcDir}}/datadog.yaml'
  - run
  - --pidfile
  - '{{.EtcDir}}/run/agent-data-plane.pid'
auto_start: true
condition_path_exists: '{{.InstallDir}}/bin/agent/agent-data-plane.exe'
restart: on-failure
restart_sec: 2
start_limit_interval_sec: 10
start_limit_burst: 5
stdout: inherit
stderr: inherit
