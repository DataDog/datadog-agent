description: Datadog Private Action Runner - On-Demand Executor
command: {{.InstallDir}}/embedded/bin/privateactionrunner
args:
  - run-executor
  - --cfgpath
  - ${DD_CONF_DIR}/datadog.yaml
auto_start: false
condition_path_exists: {{.InstallDir}}/embedded/bin/privateactionrunner
restart: never
environment_file: -${DD_CONF_DIR}/environment
stdout: inherit
stderr: inherit
