description: Datadog Distribution of OpenTelemetry Collector
command: {{.InstallDir}}/ext/ddot/embedded/bin/otel-agent.exe
auto_start: true
condition_path_exists: {{.InstallDir}}/ext/ddot/embedded/bin/otel-agent.exe
restart: on-failure
restart_sec: 2
start_limit_interval_sec: 10
start_limit_burst: 5
env:
  DD_OTELCOLLECTOR_INSTALLATION_METHOD: bare-metal
{{- if not .Stable}}
  DD_INVENTORIES_FIRST_RUN_DELAY: "5"
{{- end}}
stdout: inherit
stderr: inherit
