load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = [
        "config.go",
        "write.go",
        "write_nix.go",
        "write_windows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/fleet/installer/setup/config",
    visibility = ["//visibility:public"],
    deps = [
        "@in_yaml_go_yaml_v3//:yaml",
        "@org_golang_x_text//encoding/unicode",
    ] + select({
        "@rules_go//go/platform:windows": [
            "//pkg/fleet/installer/paths",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "config_test",
    srcs = [
        "config_test.go",
        "write_test.go",
        "write_windows_test.go",
    ],
    embed = [":config"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v3//:yaml",
        "@org_golang_x_text//encoding",
        "@org_golang_x_text//encoding/unicode",
    ] + select({
        "@rules_go//go/platform:windows": [
            "@org_golang_x_sys//windows",
        ],
        "//conditions:default": [],
    }),
)
