load("@rules_go//go:def.bzl", "go_library", "go_test")

# gazelle:go_test file

go_library(
    name = "config",
    srcs = [
        "config.go",
        "write.go",
        "write_nix.go",
        "write_windows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/fleet/installer/setup/config",
    visibility = ["//visibility:public"],
    deps = [
        "@in_yaml_go_yaml_v3//:yaml",
        "@org_golang_x_text//encoding/unicode",
    ] + select({
        "@rules_go//go/platform:windows": [
            "//pkg/fleet/installer/paths",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "config_test",
    srcs = ["config_test.go"],
    embed = [":config"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v3//:yaml",
    ],
)

go_test(
    name = "write_test",
    srcs = ["write_test.go"],
    embed = [":config"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_x_text//encoding",
        "@org_golang_x_text//encoding/unicode",
    ],
)

go_test(
    name = "write_windows_test",
    srcs = ["write_windows_test.go"],
    embed = [":config"],
    gotags = ["test"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "@com_github_stretchr_testify//assert",
            "@org_golang_x_sys//windows",
        ],
        "//conditions:default": [],
    }),
)
