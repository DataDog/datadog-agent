load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "setup",
    srcs = [
        "setup.go",
        "setup_nonwindows.go",
        "setup_windows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/fleet/installer/setup",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/fleet/installer/env",
        "//pkg/fleet/installer/exec",
        "//pkg/fleet/installer/paths",
        "//pkg/fleet/installer/setup/common",
        "//pkg/fleet/installer/setup/defaultscript",
        "//pkg/fleet/installer/setup/djm",
    ] + select({
        "@rules_go//go/platform:windows": [
            "//pkg/fleet/installer/bootstrap",
            "//pkg/fleet/installer/oci",
            "@com_github_google_go_containerregistry//pkg/v1/remote/transport",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "setup_test",
    srcs = ["setup_windows_test.go"],
    embed = [":setup"],
    target_compatible_with = ["@platforms//os:windows"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "//pkg/fleet/installer/env",
            "@com_github_stretchr_testify//assert",
        ],
        "//conditions:default": [],
    }),
)
