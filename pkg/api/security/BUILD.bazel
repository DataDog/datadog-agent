load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "security",
    srcs = ["security.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/api/security",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/model",
        "//pkg/config/utils",
        "//pkg/util/filesystem",
        "//pkg/util/log",
    ],
)

go_test(
    name = "security_test",
    srcs = ["security_test.go"],
    embed = [":security"],
    gotags = ["test"],  # keep: pkg/config/nodetreemodel SetWithoutSource / assert_testonly
    deps = select({
        "@rules_go//go/platform:windows": [],
        "//conditions:default": [
            "//pkg/config/mock",
            "//pkg/config/model",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
        ],
    }),
)
