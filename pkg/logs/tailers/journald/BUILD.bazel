load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "journald",
    srcs = [
        "docker.go",
        "journal_factory.go",
        "tailer.go",
        "tailer_util.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/logs/tailers/journald",
    target_compatible_with = ["@platforms//os:linux"],  # keep
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/tagger/def",
        "//comp/core/tagger/tags",
        "//comp/core/tagger/types",
        "//comp/core/telemetry/def",
        "//comp/logs-library/processor",
        "//comp/logs/agent/config",
        "//comp/logs/auditor/def",
        "//pkg/logs/internal/decoder",
        "//pkg/logs/internal/tag",
        "//pkg/logs/message",
        "//pkg/logs/sources",
        "//pkg/util/cache",
        "//pkg/util/log",
        "@com_github_coreos_go_systemd_v22//sdjournal",
    ],
)

dd_agent_go_test(
    name = "journald_test",
    srcs = [
        "docker_test.go",
        "tailer_test.go",
    ],
    embed = [":journald"],
    flavors = [
        "base",
        "fips",
        "iot",
    ],
    target_compatible_with = ["@platforms//os:linux"],  # keep
    deps = [
        "//comp/core/tagger/fx-mock",
        "//comp/logs/agent/config",
        "//comp/logs/auditor/mock",
        "//pkg/config/mock",
        "//pkg/logs/message",
        "//pkg/logs/sources",
        "//pkg/util/cache",
        "@com_github_coreos_go_systemd_v22//sdjournal",
        "@com_github_stretchr_testify//assert",
    ],
)
