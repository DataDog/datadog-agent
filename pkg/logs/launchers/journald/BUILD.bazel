dd_agent_go_test(
    name = "journald_test",
    srcs = ["launcher_test.go"],
    embed = [":journald"],
    include_default = False,
    tag_sets = ["systemd"],
    deps = [
        "//comp/core/tagger/fx-mock",
        "//comp/logs-library/pipeline",
        "//comp/logs/agent/config",
        "//comp/logs/agent/flare",
        "//comp/logs/auditor/mock",
        "//pkg/logs/launchers",
        "//pkg/logs/sources",
        "//pkg/logs/tailers",
        "//pkg/logs/tailers/journald",
        "@com_github_coreos_go_systemd_v22//sdjournal",
        "@com_github_stretchr_testify//assert",
    ],
)
