load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "util",
    srcs = [
        "moving_sum.go",
        "service_name.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/logs/internal/util",
    tags_independent = True,
    visibility = [
        "//pkg/logs:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_client//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_diagnostic//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_message//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_metrics//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_processor//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_sender//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_sources//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_status_statusinterface//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_status_utils//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_types//:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_logs_util_testutils//:__subpackages__",
    ],
    deps = [
        "//comp/core/tagger/types",
        "//pkg/util/log",
        "@com_github_benbjohnson_clock//:clock",
    ],
)

dd_agent_go_test(
    name = "util_test",
    srcs = [
        "moving_sum_test.go",
        "service_name_test.go",
    ],
    embed = [":util"],
    deps = [
        "//comp/core/tagger/types",
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_stretchr_testify//assert",
    ],
)
