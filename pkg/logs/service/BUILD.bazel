load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "service",
    srcs = [
        "service.go",
        "services.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/logs/service",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["//pkg/util/log"],
)

dd_agent_go_test(
    name = "service_test",
    srcs = ["services_test.go"],
    embed = [":service"],
    deps = ["@com_github_stretchr_testify//assert"],
)
