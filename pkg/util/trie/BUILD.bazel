load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "trie",
    srcs = ["trie.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/trie",
    tags_closure_independent = True,
    tags_independent = True,
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "trie_test",
    srcs = ["trie_test.go"],
    embed = [":trie"],
    deps = ["@com_github_stretchr_testify//assert"],
)
