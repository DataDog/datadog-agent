load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "common",
    srcs = [
        "common.go",
        "common_linux.go",
        "common_nolinux.go",
        "feature_gate.go",
        "version.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/kubernetes/apiserver/common",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/setup/constants",
        "//pkg/util/cache",
        "//pkg/util/kubernetes/apiserver/common/namespace",
        "//pkg/util/log",
        "//pkg/util/prometheus",
        "//pkg/util/retry",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/errors",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/version",
        "@io_k8s_client_go//discovery",
        "@io_k8s_client_go//kubernetes/typed/core/v1:core",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/util/system",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/util/system",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "common_test",
    srcs = [
        "common_test.go",
        "feature_gate_test.go",
        "version_test.go",
    ],
    embed = [":common"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//pkg/util/cache",
        "//pkg/util/kubernetes/apiserver/common/namespace",
        "@com_github_stretchr_testify//assert",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/errors",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
        "@io_k8s_apimachinery//pkg/version",
        "@io_k8s_client_go//discovery/fake",
        "@io_k8s_client_go//kubernetes/fake",
    ],
)
