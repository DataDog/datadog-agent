load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "kubernetes",
    srcs = [
        "auth.go",
        "const.go",
        "doc.go",
        "helpers.go",
        "hostname_stub.go",
        "resource.go",
        "tags.go",
        "time.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/kubernetes",
    visibility = ["//visibility:public"],
    # NOTE: hostname.go (//go:build kubeapiserver && !kubelet) is intentionally excluded.
    # It imports pkg/util/kubernetes/apiserver, which imports pkg/util/kubernetes/kubelet,
    # which imports pkg/util/kubernetes — creating a cycle that Bazel cannot resolve.
    # cluster-agent's GetKubeAPIServerHostname is blocked by this structural cycle until
    # the source is refactored to break it (e.g. extract to a subpackage).
    deps = [
        "//pkg/util/log",
        "//pkg/util/pointer",
        "@io_k8s_apimachinery//pkg/api/resource",
    ],
)

go_test(
    name = "kubernetes_test",
    srcs = [
        "helpers_test.go",
        "resource_test.go",
        "tags_test.go",
    ],
    embed = [":kubernetes"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@io_k8s_apimachinery//pkg/api/resource",
    ],
)
