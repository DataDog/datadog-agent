load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "kubelet",
    srcs = [
        "deviceplugin.go",
        "diagnosis.go",
        "doc.go",
        "json.go",
        "kubelet.go",
        "kubelet_client.go",
        "kubelet_common.go",
        "kubelet_hosts.go",
        "kubelet_interface.go",
        "kubelet_orchestrator.go",
        "metadata.go",
        "metadata_no_kubelet.go",
        "pod.go",
        "podresources.go",
        "telemetry.go",
        "types_kubelet.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/kubernetes/kubelet",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/diagnose/def",
        "//comp/core/tagger/types",
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//pkg/config/env",
        "//pkg/config/setup",
        "//pkg/errors",
        "//pkg/util/cache",
        "//pkg/util/containers",
        "//pkg/util/docker",
        "//pkg/util/filesystem",
        "//pkg/util/kubernetes",
        "//pkg/util/log",
        "//pkg/util/retry",
        "@com_github_json_iterator_go//:go",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/api/resource",
        "@io_k8s_apimachinery//pkg/runtime",
        "@io_k8s_client_go//kubernetes/scheme",
        "@io_k8s_client_go//transport",
        "@io_k8s_kubelet//pkg/apis/deviceplugin/v1beta1",
        "@io_k8s_kubelet//pkg/apis/podresources/v1:podresources",
        "@io_k8s_kubelet//pkg/apis/stats/v1alpha1",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_grpc//credentials/insecure",
    ],
)

dd_agent_go_test(
    name = "kubelet_test",
    srcs = [
        "deviceplugin_test.go",
        "kubelet_client_test.go",
        "kubelet_common_test.go",
        "kubelet_hosts_test.go",
        "kubelet_orchestrator_test.go",
        "kubelet_test.go",
        "pod_test.go",
        "podresources_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":kubelet"],
    flavors = [
        "base",
        "dogstatsd",
        "fips",
    ],
    deps = [
        "//pkg/config/create",
        "//pkg/config/mock",
        "//pkg/errors",
        "//pkg/util/log",
        "//pkg/util/log/setup",
        "@com_github_json_iterator_go//:go",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@com_github_stretchr_testify//suite",
        "@io_k8s_kubelet//pkg/apis/podresources/v1:podresources",
    ] + select({
        "@rules_go//go/platform:android": [
            "@io_k8s_kubelet//pkg/apis/deviceplugin/v1beta1",
            "@org_golang_google_grpc//:grpc",
            "@org_golang_google_grpc//credentials/insecure",
        ],
        "@rules_go//go/platform:linux": [
            "@io_k8s_kubelet//pkg/apis/deviceplugin/v1beta1",
            "@org_golang_google_grpc//:grpc",
            "@org_golang_google_grpc//credentials/insecure",
        ],
        "//conditions:default": [],
    }),
)
