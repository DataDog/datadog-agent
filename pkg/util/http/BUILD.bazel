load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "http",
    srcs = [
        "client.go",
        "helpers.go",
        "token.go",
        "transport.go",
        "warnings.go",
        "warnings_mock.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/http",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
        "//vendor/golang.org/x/net/http/httpproxy",
        "//vendor/golang.org/x/net/http2",
    ],
)

go_test(
    name = "http_test",
    srcs = [
        "client_test.go",
        "helpers_test.go",
        "token_test.go",
        "transport_test.go",
        "warnings_test.go",
    ],
    embed = [":http"],
    # keep
    gotags = ["test"] + select({
        "@platforms//os:linux": ["linux"],
        "@platforms//os:macos": ["darwin"],
        "@platforms//os:windows": ["windows"],
        "//conditions:default": [],
    }),
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/mock",
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
    ],
)
