load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "iisconfig",
    srcs = [
        "apmtags.go",
        "iisconfig.go",
        "tagtree.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/winutil/iisconfig",
    target_compatible_with = ["@platforms//os:windows"],  # keep
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/fsnotify/fsnotify",
            "//vendor/golang.org/x/sys/windows/registry",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "iisconfig_test",
    srcs = [
        "apmtags_test.go",
        "iisconfig_test.go",
        "matching_subsite_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":iisconfig"],
    gotags = ["test"],
    target_compatible_with = ["@platforms//os:windows"],  # keep
    deps = select({
        "@rules_go//go/platform:windows": [
            "//vendor/github.com/stretchr/testify/assert",
            "//vendor/github.com/stretchr/testify/require",
        ],
        "//conditions:default": [],
    }),
)
