        "doc.go",
        "elevated.go",
        "eventlog.go",
        "msi.go",
        "pe_timestamp_windows.go",
        "process.go",
        "scmmonitor.go",
        "service.go",
        "setupapi.go",
        "shutil.go",
        "time.go",
        "users.go",
        "wincrypt.go",
        "winctrlhandler.go",
        "winsec.go",
        "winstrings.go",
        "winver.go",
        "wnet.go",
