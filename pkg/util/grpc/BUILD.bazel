load("@rules_go//go:def.bzl", "go_library", "go_test")

# hack.go uses //go:build hack_no_include (blank import to pin cloud.google.com/go/compute)
# scope tag here, not in root ALL_BUILD_TAGS.
# gazelle:build_tags hack_no_include

go_library(
    name = "grpc",
    srcs = [
        "agent_client.go",
        "auth.go",
        "cert.go",
        "chunks.go",
        "hack.go",
        "interceptors.go",
        "logger.go",
        "metrics.go",
        "mock_server.go",
        "server.go",
        "timeout.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/grpc",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/impl",
        "//vendor/cloud.google.com/go/compute/apiv1",
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
        "//vendor/github.com/DataDog/datadog-agent/pkg/proto/pbgo/core",
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/grpc/context",
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/system/socket",
        "//vendor/github.com/grpc-ecosystem/go-grpc-middleware/auth",
        "//vendor/github.com/mdlayher/vsock",
        "//vendor/google.golang.org/grpc",
        "//vendor/google.golang.org/grpc/backoff",
        "//vendor/google.golang.org/grpc/codes",
        "//vendor/google.golang.org/grpc/credentials",
        "//vendor/google.golang.org/grpc/grpclog",
        "//vendor/google.golang.org/grpc/peer",
        "//vendor/google.golang.org/grpc/status",
    ],
)

go_test(
    name = "grpc_test",
    srcs = ["agent_client_test.go"],
    embed = [":grpc"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
        "//vendor/github.com/stretchr/testify/assert",
    ],
)
