load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "flavor",
    srcs = [
        "flavor.go",
        "flavor_test_util.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/flavor",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/model",
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/setup",
    ],
)

go_test(
    name = "flavor_test",
    srcs = ["flavor_test.go"],
    embed = [":flavor"],
    # keep: pkg/config/nodetreemodel SetWithoutSource; OS tags for platform-specific flavor tests
    gotags = ["test"] + select({
        "@platforms//os:linux": ["linux"],
        "@platforms//os:macos": ["darwin"],
        "@platforms//os:windows": ["windows"],
        "//conditions:default": [],
    }),
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/config/mock",
        "//vendor/github.com/stretchr/testify/assert",
    ],
)
