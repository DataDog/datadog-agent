load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "containerd",
    srcs = [
        "containerd_util.go",
        "diagnosis.go",
        "namespaces.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/containerd",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/diagnose/def",
        "//pkg/config/env",
        "//pkg/config/setup",
        "//pkg/errors",
        "//pkg/util/containers/image",
        "//pkg/util/log",
        "//pkg/util/retry",
        "@com_github_containerd_containerd_api//types",
        "@com_github_containerd_containerd_v2//client",
        "@com_github_containerd_containerd_v2//core/containers",
        "@com_github_containerd_containerd_v2//core/leases",
        "@com_github_containerd_containerd_v2//core/mount",
        "@com_github_containerd_containerd_v2//defaults",
        "@com_github_containerd_containerd_v2//pkg/namespaces",
        "@com_github_containerd_containerd_v2//pkg/oci",
        "@com_github_containerd_errdefs//:errdefs",
        "@com_github_opencontainers_image_spec//identity",
    ],
)

dd_agent_go_test(
    name = "containerd_test",
    srcs = [
        "containerd_util_test.go",
        "namespaces_test.go",
    ],
    embed = [":containerd"],
    include_default = False,
    tag_sets = ["containerd"],
    deps = [
        "//pkg/config/mock",
        "//pkg/util/containerd/fake",
        "@com_github_containerd_cgroups_v3//cgroup1/stats",
        "@com_github_containerd_containerd_api//types",
        "@com_github_containerd_containerd_v2//client",
        "@com_github_containerd_containerd_v2//core/containers",
        "@com_github_containerd_containerd_v2//pkg/cio",
        "@com_github_containerd_containerd_v2//pkg/oci",
        "@com_github_containerd_typeurl_v2//:typeurl",
        "@com_github_gogo_protobuf//types",
        "@com_github_opencontainers_runtime_spec//specs-go",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_google_protobuf//types/known/anypb",
    ],
)
