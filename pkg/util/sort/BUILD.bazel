load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "sort",
    srcs = [
        "sort.go",
        "sort_uniq.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/sort",
    tags_closure_independent = True,
    tags_independent = True,
    visibility = ["//visibility:public"],
)

dd_agent_go_test(
    name = "sort_test",
    srcs = [
        "sort_test.go",
        "sort_uniq_test.go",
    ],
    embed = [":sort"],
    deps = ["@com_github_stretchr_testify//assert"],
)
