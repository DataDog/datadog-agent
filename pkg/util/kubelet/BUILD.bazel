load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "kubelet",
    srcs = [
        "docs.go",
        "host_alias.go",
        "hostname.go",
        "hostname_stub.go",
        "no_host_alias.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/kubelet",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/env",
        "//pkg/util/hostname/validate",
        "//pkg/util/kubernetes/clustername",
        "//pkg/util/kubernetes/kubelet",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "kubelet_test",
    srcs = ["hostname_test.go"],
    embed = [":kubelet"],
    include_default = False,
    tag_sets = ["cel+clusterchecks+kubeapiserver+kubelet+orchestrator"],
    deps = [
        "//pkg/config/env",
        "//pkg/config/mock",
        "//pkg/util/kubernetes/clustername",
        "//pkg/util/kubernetes/kubelet",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//mock",
    ],
)
