    importpath = "github.com/DataDog/datadog-agent/pkg/util/cache",
    visibility = ["//visibility:public"],
    deps = ["@com_github_patrickmn_go_cache//:go-cache"],
)

dd_agent_go_test(
    name = "cache_test",
    srcs = ["basic_cache_test.go"],
    embed = [":cache"],
    deps = ["@com_github_stretchr_testify//assert"],
)
