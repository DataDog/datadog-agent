load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "gpu",
    srcs = [
        "common.go",
        "doc.go",
        "nvml.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/gpu",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/NVIDIA/go-nvml/pkg/nvml",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/NVIDIA/go-nvml/pkg/nvml",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "gpu_test",
    srcs = [
        "common_test.go",
        "nvml_test.go",
    ],
    embed = [":gpu"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/stretchr/testify/assert",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/NVIDIA/go-nvml/pkg/nvml",
            "//vendor/github.com/stretchr/testify/require",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/NVIDIA/go-nvml/pkg/nvml",
            "//vendor/github.com/stretchr/testify/require",
        ],
        "//conditions:default": [],
    }),
)
