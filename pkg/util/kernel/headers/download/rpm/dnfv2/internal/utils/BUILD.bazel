load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "utils",
    srcs = [
        "client.go",
        "hostify.go",
        "url.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/kernel/headers/download/rpm/dnfv2/internal/utils",
    visibility = ["//pkg/util/kernel/headers/download/rpm/dnfv2:__subpackages__"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/util/kernel/headers/download/rpm/dnfv2/types",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/util/kernel/headers/download/rpm/dnfv2/types",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "utils_test",
    srcs = ["hostify_test.go"],
    embed = [":utils"],
    deps = select({
        "@rules_go//go/platform:android": [
            "@com_github_stretchr_testify//assert",
        ],
        "@rules_go//go/platform:linux": [
            "@com_github_stretchr_testify//assert",
        ],
        "//conditions:default": [],
    }),
)
