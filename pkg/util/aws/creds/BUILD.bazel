load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "creds",
    srcs = [
        "credentials.go",
        "credentials_noec2.go",
        "detection.go",
        "detection_noec2.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/aws/creds",
    visibility = ["//visibility:public"],
    deps = ["//pkg/util/aws/creds/internal"],
)

dd_agent_go_test(
    name = "creds_test",
    srcs = [
        "credentials_test.go",
        "detection_test.go",
    ],
    data = ["tags/payloads/security_cred.json"],
    embed = [":creds"],
    flavors = [
        "base",
        "fips",
    ],
    deps = [
        "//pkg/util/aws/creds/internal",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
