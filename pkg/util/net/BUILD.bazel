load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "net",
    srcs = [
        "docs.go",
        "endpoint_check_nix.go",
        "endpoint_check_windows.go",
        "host.go",
        "host_serverless.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/net",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:windows": [],
