load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "otel",
    srcs = ["gatewayusage.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/otel",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["//pkg/opentelemetry-mapping-go/otlp/attributes"],
)

dd_agent_go_test(
    name = "otel_test",
    srcs = ["gatewayusage_test.go"],
    embed = [":otel"],
    deps = ["@com_github_stretchr_testify//require"],
)
