load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "metadata",
    srcs = [
        "client.go",
        "client_nodocker.go",
        "types.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/ecs/metadata/v2",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/util/ecs/common",
        "//pkg/util/ecs/telemetry",
    ],
)

dd_agent_go_test(
    name = "metadata_test",
    srcs = ["client_test.go"],
    data = glob(["testdata/**"]),
    embed = [":metadata"],
    flavors = [
        "base",
        "dogstatsd",
        "fips",
    ],
    deps = [
        "//pkg/util/ecs/metadata/testutil",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
