load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "aggregatingqueue",
    srcs = ["queue.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/aggregatingqueue",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["@com_github_benbjohnson_clock//:clock"],
)

dd_agent_go_test(
    name = "aggregatingqueue_test",
    srcs = ["queue_test.go"],
    embed = [":aggregatingqueue"],
    deps = [
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_stretchr_testify//assert",
    ],
)
