load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

# This library requires the go tag "trivy" to have any impact, and
# trivy is only used in linux builds. But we still do not want to mark
# it as linux only because the top level binaries depend on this and
# expect go tag inclusion to save them.
go_library(
    name = "trivy",
    srcs = [
        "cache.go",
        "containerd.go",
        "crio.go",
        "db.go",
        "docker.go",
        "image.go",
        "init.go",
        "overlayfs.go",
        "report.go",
        "scan_image.go",
        "sqlite.go",
        "trivy.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/trivy",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/workloadmeta/def",
        "//pkg/config/env",
        "//pkg/config/setup",
        "//pkg/sbom",
        "//pkg/sbom/bomconvert",
        "//pkg/sbom/telemetry",
        "//pkg/util/containerd",
        "//pkg/util/containers/image",
        "//pkg/util/crio",
        "//pkg/util/log",
        "//pkg/util/option",
        "@com_github_aquasecurity_trivy//pkg/cache",
        "@com_github_aquasecurity_trivy//pkg/fanal/analyzer",
        "@com_github_aquasecurity_trivy//pkg/fanal/applier",
        "@com_github_aquasecurity_trivy//pkg/fanal/artifact",
        "@com_github_aquasecurity_trivy//pkg/fanal/artifact/image",
        "@com_github_aquasecurity_trivy//pkg/fanal/types",
        "@com_github_aquasecurity_trivy//pkg/log",
        "@com_github_aquasecurity_trivy//pkg/sbom/cyclonedx",
        "@com_github_aquasecurity_trivy//pkg/scan",
        "@com_github_aquasecurity_trivy//pkg/scan/langpkg",
        "@com_github_aquasecurity_trivy//pkg/scan/local",
        "@com_github_aquasecurity_trivy//pkg/scan/ospkg",
        "@com_github_aquasecurity_trivy//pkg/types",
        "@com_github_aquasecurity_trivy//pkg/vulnerability",
        "@com_github_aquasecurity_trivy_db//pkg/db",
        "@com_github_containerd_containerd_v2//client",
        "@com_github_containerd_containerd_v2//core/content",
        "@com_github_containerd_containerd_v2//core/images",
        "@com_github_containerd_containerd_v2//core/images/archive",
        "@com_github_containerd_containerd_v2//core/mount",
        "@com_github_containerd_containerd_v2//core/snapshots",
        "@com_github_containerd_containerd_v2//pkg/namespaces",
        "@com_github_datadog_agent_payload_v5//cyclonedx_v1_4",
        "@com_github_datadog_ddtrivy//:ddtrivy",
        "@com_github_distribution_reference//:reference",
        "@com_github_google_go_containerregistry//pkg/v1:pkg",
        "@com_github_google_go_containerregistry//pkg/v1/tarball",
        "@com_github_hashicorp_golang_lru_v2//simplelru",
        "@com_github_mattn_go_sqlite3//:go-sqlite3",
        "@com_github_moby_docker_image_spec//specs-go/v1:specs-go",
        "@com_github_moby_moby_api//types/image",
        "@com_github_moby_moby_client//:client",
        "@com_github_opencontainers_go_digest//:go-digest",
        "@com_github_opencontainers_image_spec//identity",
        "@com_github_opencontainers_image_spec//specs-go/v1:specs-go",
        "@com_github_samber_lo//:lo",
        "@io_etcd_go_bbolt//:bbolt",
    ],
)

dd_agent_go_test(
    name = "trivy_test",
    srcs = [
        "cache_test.go",
        "db_test.go",
        "layers_containerd_test.go",
        "layers_crio_test.go",
        "layers_docker_test.go",
        "overlayfs_test.go",
        "trivy_test.go",
    ],
    embed = [":trivy"],
    flavors = [
        "base",
        "fips",
    ],
    # These tests are meaningless except on linux.
    # - the library is only functional with the gotag 'trivy'
    # - test rule strips 'trivy' because it is a LINUX_ONLY_FLAG
    target_compatible_with = ["@platforms//os:linux"],  # keep
    deps = [
        "//comp/core",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/workloadmeta/def",
        "//comp/core/workloadmeta/fx-mock",
        "//comp/core/workloadmeta/mock",
        "//pkg/util/fxutil",
        "//pkg/util/option",
        "@com_github_aquasecurity_trivy//pkg/fanal/types",
        "@com_github_containerd_containerd_v2//core/mount",
        "@com_github_containerd_containerd_v2//core/snapshots",
        "@com_github_containerd_errdefs//:errdefs",
        "@com_github_moby_moby_api//types/image",
        "@com_github_moby_moby_api//types/storage",
        "@com_github_opencontainers_go_digest//:go-digest",
        "@com_github_opencontainers_image_spec//specs-go/v1:specs-go",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_fx//:fx",
    ],
)
