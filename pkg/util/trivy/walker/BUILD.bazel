load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "walker",
    srcs = ["walker.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/trivy/walker",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/aquasecurity/trivy/pkg/fanal/utils",
        "//vendor/github.com/aquasecurity/trivy/pkg/fanal/walker",
        "//vendor/github.com/aquasecurity/trivy/pkg/x/io",
        "//vendor/github.com/samber/lo",
        "//vendor/golang.org/x/xerrors",
    ],
)

go_test(
    name = "walker_test",
    srcs = [
        "testmain_test.go",
        "walker_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":walker"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/aquasecurity/trivy/pkg/fanal/analyzer",
        "//vendor/github.com/aquasecurity/trivy/pkg/fanal/walker",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
    ],
)
