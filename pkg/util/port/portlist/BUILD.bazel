load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "portlist",
    srcs = [
        "netstat.go",
        "netstat_darwin.go",
        "netstat_noimpl.go",
        "netstat_windows.go",
        "poller.go",
        "poller_aix.go",
        "poller_darwin.go",
        "poller_linux.go",
        "poller_windows.go",
        "portlist.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/port/portlist",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/go4.org/mem",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:darwin": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/go.uber.org/atomic",
            "//vendor/go4.org/mem",
        ],
        "@rules_go//go/platform:ios": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/go.uber.org/atomic",
            "//vendor/go4.org/mem",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/go4.org/mem",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:windows": [
            "//vendor/golang.org/x/sys/cpu",
            "//vendor/golang.org/x/sys/windows",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "portlist_test",
    srcs = [
        "netstat_test.go",
        "poller_darwin_test.go",
        "poller_linux_test.go",
        "poller_test.go",
    ],
    embed = [":portlist"],
    # macOS tests need to inherit the parent PATH in order to be able to
    # execute the netstat tool which the tests need
    env_inherit = ["PATH"],
    gotags = ["test"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/google/go-cmp/cmp",
            "//vendor/go4.org/mem",
        ],
        "@rules_go//go/platform:darwin": [
            "//vendor/go4.org/mem",
        ],
        "@rules_go//go/platform:ios": [
            "//vendor/go4.org/mem",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/google/go-cmp/cmp",
            "//vendor/go4.org/mem",
        ],
        "//conditions:default": [],
    }),
)
