load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "lsof",
    srcs = [
        "errors.go",
        "lsof.go",
        "lsof_aix.go",
        "lsof_darwin.go",
        "lsof_linux.go",
        "lsof_windows.go",
        "modules_other.go",
        "modules_windows.go",
        "test_utils.go",
        "types.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/lsof",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/prometheus/procfs",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/github.com/prometheus/procfs",
        ],
        "@rules_go//go/platform:windows": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/winutil",
            "//vendor/golang.org/x/sys/windows",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "lsof_test",
    srcs = [
        "lsof_linux_test.go",
        "lsof_windows_test.go",
        "types_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":lsof"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/stretchr/testify/require",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/prometheus/procfs",
            "//vendor/github.com/stretchr/testify/assert",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/prometheus/procfs",
            "//vendor/github.com/stretchr/testify/assert",
        ],
        "@rules_go//go/platform:windows": [
            "//vendor/github.com/stretchr/testify/assert",
            "//vendor/golang.org/x/sys/windows",
        ],
        "//conditions:default": [],
    }),
)
