load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "errortracking",
    srcs = [
        "bouncer.go",
        "doc.go",
        "handler.go",
        "types.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/log/errortracking",
    tags_closure_independent = True,
