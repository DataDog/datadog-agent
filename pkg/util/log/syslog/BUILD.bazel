load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "syslog",
    srcs = ["syslog.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/log/syslog",
    visibility = ["//visibility:public"],
    deps = ["//pkg/util/log/types"],
)

go_test(
    name = "syslog_test",
    srcs = ["syslog_test.go"],
    embed = [":syslog"],
    gotags = ["test"],
    deps = select({
        "@rules_go//go/platform:windows": [],
        "//conditions:default": [
            "//pkg/util/log/types",
            "@com_github_stretchr_testify//assert",
            "@com_github_stretchr_testify//require",
        ],
    }),
)
