load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "scrubber",
    srcs = [
        "default.go",
        "json_scrubber.go",
        "scrubber.go",
        "yaml_scrubber.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/util/scrubber",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/version",
        "//vendor/go.yaml.in/yaml/v3:yaml",
    ],
)

go_test(
    name = "scrubber_test",
    srcs = [
        "default_test.go",
        "json_scrubber_test.go",
        "scrubber_test.go",
        "yaml_scrubber_test.go",
    ],
    data = glob(["test/**"]),
    embed = [":scrubber"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
        "//vendor/go.yaml.in/yaml/v3:yaml",
    ],
)
