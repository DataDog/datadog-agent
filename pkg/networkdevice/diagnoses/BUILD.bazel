)

dd_agent_go_test(
    name = "diagnoses_test",
    srcs = ["diagnoses_test.go"],
    embed = [":diagnoses"],
    deps = [
        "//comp/core/diagnose/def",
        "//pkg/networkdevice/metadata",
        "@com_github_stretchr_testify//assert",
    ],
)
