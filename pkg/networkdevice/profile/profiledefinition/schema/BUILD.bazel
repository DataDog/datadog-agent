load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "schema",
    srcs = [
        "doc.go",
        "generate.go",
        "schema.go",
    ],
    embedsrcs = ["profile_rc_schema.json"],
    importpath = "github.com/DataDog/datadog-agent/pkg/networkdevice/profile/profiledefinition/schema",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/networkdevice/profile/profiledefinition",
        "//vendor/github.com/invopop/jsonschema",
    ],
)

go_test(
    name = "schema_test",
    srcs = [
        "generate_test.go",
        "profile_rc_schema_test.go",
    ],
    data = [":testcases"],
    embed = [":schema"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/santhosh-tekuri/jsonschema/v5:jsonschema",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
    ],
)

filegroup(
    name = "testcases",
    srcs = glob(["testcases/**"]),
)
