load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "aptconfig",
    srcs = ["aptconfig.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/compliance/aptconfig",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/compliance/types",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "aptconfig_test",
    srcs = ["aptconfig_test.go"],
    data = glob(["testdata/**"]),
    embed = [":aptconfig"],
    deps = ["@com_github_stretchr_testify//assert"],
)
