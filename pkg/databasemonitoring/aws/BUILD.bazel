load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "aws",
    srcs = [
        "aurora.go",
        "aws.go",
        "client.go",
        "config.go",
        "rds.go",
        "rdsclient_mockgen.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/databasemonitoring/aws",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/setup",
        "//pkg/util/ec2",
        "//pkg/util/log",
        "@com_github_aws_aws_sdk_go_v2//aws",
        "@com_github_aws_aws_sdk_go_v2_config//:config",
