        "common_test.go",
        "rds_test.go",
    ],
    embed = [":aws"],
    gotags = ["test"],
    deps = [
        "@com_github_aws_aws_sdk_go_v2//aws",
        "@com_github_aws_aws_sdk_go_v2_service_rds//:rds",
        "@com_github_aws_aws_sdk_go_v2_service_rds//types",
        "@com_github_stretchr_testify//assert",
        "@org_uber_go_mock//gomock",
    ],
