load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "platform",
    srcs = [
        "platform.go",
        "platform_aix.go",
        "platform_darwin.go",
        "platform_linux.go",
        "platform_windows.go",
        "platform_windows_386.go",
        "platform_windows_amd64.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/gohai/platform",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/gohai/utils",
    ] + select({
        "@rules_go//go/platform:aix": [
            "//vendor/github.com/shirou/gopsutil/v4/host",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:android": [
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:darwin": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:ios": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:windows": [
            "//vendor/golang.org/x/sys/windows",
            "//vendor/golang.org/x/sys/windows/registry",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "platform_test",
    srcs = [
        "platform_darwin_test.go",
        "platform_linux_test.go",
        "platform_test.go",
    ],
    embed = [":platform"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/gohai/utils",
        "//vendor/github.com/stretchr/testify/assert",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/stretchr/testify/require",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:darwin": [
            "//vendor/github.com/stretchr/testify/require",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:ios": [
            "//vendor/github.com/stretchr/testify/require",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/stretchr/testify/require",
            "//vendor/golang.org/x/sys/unix",
        ],
        "//conditions:default": [],
    }),
)
