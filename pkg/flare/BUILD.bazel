load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "flare",
    srcs = [
        "archive.go",
        "archive_docker.go",
        "archive_k8s.go",
        "archive_linux.go",
        "archive_nix.go",
        "archive_nodocker.go",
        "archive_nok8s.go",
        "archive_nolinux.go",
        "archive_win.go",
        "config_check.go",
        "flare.go",
        "runtime_debug.go",
        "service_windows.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/flare",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/flare/helpers",
        "//comp/core/flare/types",
        "//comp/core/ipc/def",
        "//comp/core/ipc/httphelpers",
        "//comp/core/workloadmeta/def",
        "//pkg/api/security",
        "//pkg/collector/check/id",
        "//pkg/config/env",
        "//pkg/config/model",
        "//pkg/config/remote/flare",
        "//pkg/config/setup",
        "//pkg/config/utils",
        "//pkg/flare/common",
        "//pkg/flare/priviledged",
        "//pkg/process/util/coreagent",
        "//pkg/redact",
        "//pkg/status/systemprobe",
        "//pkg/system-probe/api/client",
        "//pkg/util/cloudproviders/network",
        "//pkg/util/containers/metrics",
        "//pkg/util/docker",
        "//pkg/util/ecs",
        "//pkg/util/installinfo",
        "//pkg/util/kubernetes/kubelet",
        "//pkg/util/log",
        "//pkg/util/option",
        "@com_github_fatih_color//:color",
        "@com_github_moby_moby_client//:client",
        "@in_yaml_go_yaml_v2//:yaml",
        "@io_k8s_api//core/v1:core",
        "@io_k8s_apimachinery//pkg/apis/meta/v1:meta",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/system-probe/config",
            "//pkg/util/defaultpaths",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/system-probe/config",
            "//pkg/util/defaultpaths",
        ],
        "@rules_go//go/platform:windows": [
            "//pkg/util/winutil",
            "@org_golang_x_sys//windows",
            "@org_golang_x_sys//windows/svc",
            "@org_golang_x_sys//windows/svc/mgr",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "flare_test",
    srcs = [
        "archive_docker_test.go",
        "archive_test.go",
        "config_check_test.go",
        "runtime_debug_test.go",
        "service_windows_test.go",
    ],
    embed = [":flare"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/config",
        "//comp/core/flare/helpers",
        "//comp/core/ipc/def",
        "//comp/core/ipc/mock",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/secrets/def",
        "//comp/core/secrets/mock",
        "//comp/core/settings/mock",
        "//comp/core/status",
        "//comp/core/status/statusimpl",
        "//comp/core/tagger/fx",
        "//comp/core/telemetry/mock",
        "//comp/core/workloadmeta/def",
        "//comp/core/workloadmeta/fx",
        "//comp/process/apiserver/def",
        "//comp/process/apiserver/fx",
        "//pkg/config/mock",
        "//pkg/config/model",
        "//pkg/util/fxutil",
        "@com_github_datadog_agent_payload_v5//process",
        "@com_github_fatih_color//:color",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v2//:yaml",
        "@org_uber_go_fx//:fx",
    ] + select({
        "@rules_go//go/platform:windows": [
            "//pkg/util/winutil",
            "@org_golang_x_sys//windows",
        ],
        "//conditions:default": [],
    }),
)
