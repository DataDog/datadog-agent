load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")
load("//bazel/rules/go_msgp:defs.bzl", "go_msgp")

# Source-level export so the //pkg/security/secl/model:event_deep_copy_*
# Bazel codegens can resolve tracermetadata.TracerMetadata.
exports_files(
    ["tracer_metadata.go"],
    visibility = ["//pkg/security/secl/model:__pkg__"],
)

go_msgp(
    name = "tracer_metadata_gen",
    src = "tracer_metadata.go",
    out = "tracer_metadata_gen.go",
    out_test = "tracer_metadata_gen_test.go",
)

go_library(
    name = "model",
    srcs = [
        "tracer_metadata.go",
        "tracer_metadata_gen.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/discovery/tracermetadata/model",
    visibility = ["//visibility:public"],
    deps = ["@com_github_tinylib_msgp//msgp"],
)

dd_agent_go_test(
    name = "model_test",
    srcs = [
        "tracer_metadata_gen_test.go",
        "tracer_metadata_test.go",
    ],
    embed = [":model"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_tinylib_msgp//msgp",
    ],
)
