load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("@rules_cc//cc:cc_test.bzl", "cc_test")
load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_files")
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_static_library", "rust_test")

# ============================================================================
# Library Targets (rlib + cdylib)
# ============================================================================

# Rust library (rlib) for internal use
rust_library(
    name = "dd_discovery",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = [
            "src/main.rs",
            "src/bin/**",
        ],
    ),
    crate_features = [
        "java-archives",
        "spring",
        "jee",
    ],
    crate_name = "dd_discovery",
    edition = "2024",
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "@crates//:anyhow",
        "@crates//:cap-std",
        "@crates//:clap",
        "@crates//:elf",
        "@crates//:flate2",
        "@crates//:glob-match",
        "@crates//:http-body-util",
        "@crates//:hyper",
        "@crates//:hyper-util",
        "@crates//:log",
        "@crates//:lru",
        "@crates//:memchr",
        "@crates//:nom",
        "@crates//:normalize-path",
        "@crates//:phf",
        "@crates//:quick-xml",
        "@crates//:rawzip",
        "@crates//:rmp-serde",
        "@crates//:saphyr-parser",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:uzers",
        "@crates//:walkdir",
    ],
)

# Static library (staticlib) for FFI integration
rust_static_library(
    name = "libdd_discovery",
    srcs = glob(
        ["src/**/*.rs"],
        exclude = [
            "src/main.rs",
            "src/bin/**",
        ],
    ),
    crate_features = [
        "java-archives",
        "spring",
        "jee",
    ],
    crate_name = "dd_discovery",
    crate_root = "src/lib.rs",
    edition = "2024",
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "@crates//:anyhow",
        "@crates//:cap-std",
        "@crates//:clap",
        "@crates//:elf",
        "@crates//:flate2",
        "@crates//:glob-match",
        "@crates//:http-body-util",
        "@crates//:hyper",
        "@crates//:hyper-util",
        "@crates//:log",
        "@crates//:lru",
        "@crates//:memchr",
        "@crates//:nom",
        "@crates//:normalize-path",
        "@crates//:phf",
        "@crates//:quick-xml",
        "@crates//:rawzip",
        "@crates//:rmp-serde",
        "@crates//:saphyr-parser",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:uzers",
        "@crates//:walkdir",
    ],
)

# ============================================================================
# Headers
# ============================================================================

filegroup(
    name = "dd_discovery_headers",
    srcs = ["include/dd_discovery.h"],
    visibility = ["//visibility:public"],
)

# ============================================================================
# Binary Targets
# ============================================================================

# Main system-probe-lite service binary
rust_binary(
    name = "system-probe-lite",
    srcs = [
        "src/cli.rs",
        "src/main.rs",
    ],
    edition = "2024",
    target_compatible_with = ["@platforms//os:linux"],
    visibility = ["//visibility:public"],
    deps = [
        ":dd_discovery",
        "//comp/core/log/rust:dd-agent-log",
        "@crates//:anyhow",
        "@crates//:caps",
        "@crates//:http-body-util",
        "@crates//:hyper",
        "@crates//:hyper-util",
        "@crates//:log",
        "@crates//:serde_json",
        "@crates//:tokio",
        "@crates//:uzers",
    ],
)

pkg_files(
    name = "all_files",
    srcs = [":system-probe-lite"],
    attributes = pkg_attributes(
        mode = "0755",
    ),
    prefix = "embedded/bin",
    visibility = ["//packages:__subpackages__"],
)

pkg_install(
    name = "install",
    srcs = [":all_files"],
)

# Disco CLI tool for service discovery
rust_binary(
    name = "disco",
    srcs = ["src/bin/disco.rs"],
    edition = "2024",
    visibility = ["//visibility:public"],
    deps = [
        ":dd_discovery",
        "@crates//:clap",
        "@crates//:serde_json",
    ],
)

# ============================================================================
# Tests
# ============================================================================

# Test data files
filegroup(
    name = "testdata",
    srcs = glob(["testdata/**/*"]),
)

# Unit tests embedded in source files
rust_test(
    name = "dd_discovery_test",
    crate = ":dd_discovery",
    crate_features = [
        "java-archives",
        "spring",
        "jee",
    ],
    # Make test data available to tests
    data = [":testdata"],
    edition = "2024",
    deps = [
        # Dev dependencies from Cargo.toml
        "@crates//:dircpy",
        "@crates//:memmap2",
        "@crates//:scopeguard",
        "@crates//:tempfile",
        "@crates//:temp-env",
        # Optional deps needed when spring/jee features are enabled
        "@crates//:flate2",
        "@crates//:quick-xml",
        "@crates//:rawzip",
        "@crates//:walkdir",
        "@crates//:saphyr-parser",
        "@crates//:zip",
    ],
)

# Unit tests without optional features (tests the production code path)
rust_test(
    name = "dd_discovery_nofeatures_test",
    crate = ":dd_discovery",
    # No crate_features — matches production build
    data = [":testdata"],
    edition = "2024",
    deps = [
        "@crates//:dircpy",
        "@crates//:memmap2",
        "@crates//:scopeguard",
        "@crates//:tempfile",
        "@crates//:temp-env",
        # walkdir is needed by test_utils (dev-dependency)
        "@crates//:walkdir",
    ],
)

# Integration tests
rust_test(
    name = "pid_integration_test",
    srcs = ["tests/pid_integration_test.rs"],
    data = [":system-probe-lite"],
    edition = "2024",
    rustc_env = {
        "CARGO_BIN_EXE_system-probe-lite": "$(rootpath :system-probe-lite)",
    },
    deps = [
        "@crates//:nix",
        "@crates//:tempfile",
    ],
)

rust_test(
    name = "config_integration_test",
    srcs = ["tests/config_integration_test.rs"],
    data = [":system-probe-lite"],
    edition = "2024",
    rustc_env = {
        "CARGO_BIN_EXE_system-probe-lite": "$(rootpath :system-probe-lite)",
    },
    deps = [
        "@crates//:nix",
        "@crates//:serde_json",
        "@crates//:tempfile",
        "@crates//:yaml-rust2",
    ],
)

# Static library built with `force-ffi-panic` for FFI panic-catch testing
rust_static_library(
    name = "libdd_discovery_force_panic",
    testonly = True,
    srcs = glob(
        ["src/**/*.rs"],
        exclude = [
            "src/main.rs",
            "src/bin/**",
        ],
    ),
    crate_features = ["force-ffi-panic"],
    crate_name = "dd_discovery_force_panic",
    crate_root = "src/lib.rs",
    edition = "2024",
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    deps = [
        "@crates//:anyhow",
        "@crates//:cap-std",
        "@crates//:clap",
        "@crates//:elf",
        "@crates//:glob-match",
        "@crates//:http-body-util",
        "@crates//:hyper",
        "@crates//:hyper-util",
        "@crates//:log",
        "@crates//:lru",
        "@crates//:memchr",
        "@crates//:nom",
        "@crates//:normalize-path",
        "@crates//:phf",
        "@crates//:rmp-serde",
        "@crates//:serde",
        "@crates//:serde_json",
        "@crates//:thiserror",
        "@crates//:tokio",
        "@crates//:uzers",
    ],
)

# cc_library wrapper that exposes the forced-panic static library with its header.
cc_library(
    name = "dd_discovery_force_panic_cc",
    testonly = True,
    hdrs = [":dd_discovery_headers"],
    includes = ["include"],
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    deps = [":libdd_discovery_force_panic"],
)

# C test: verifies that a panic inside dd_discovery_get_services is caught and
# NULL is returned rather than unwinding across the C ABI boundary.
cc_test(
    name = "ffi_panic_test",
    srcs = ["tests/ffi_panic_test.c"],
    target_compatible_with = [
        "@platforms//os:linux",
    ],
    deps = [":dd_discovery_force_panic_cc"],
)
