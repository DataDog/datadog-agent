load("@io_bazel_rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "splite",
    srcs = ["args.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/discovery/module/splite",
    visibility = ["//visibility:public"],
)

go_test(
    name = "splite_test",
    srcs = ["args_test.go"],
    embed = [":splite"],
    gotags = ["test"],
    deps = select({
        "@io_bazel_rules_go//go/platform:android": [
            "@com_github_stretchr_testify//assert",
        ],
        "@io_bazel_rules_go//go/platform:linux": [
            "@com_github_stretchr_testify//assert",
        ],
        "//conditions:default": [],
    }),
)
