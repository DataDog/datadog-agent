        "@rules_go//go/platform:linux": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/cgroups/memorymonitor",
            "//vendor/github.com/alecthomas/units",
        ],
        "//conditions:default": [],
    }),
