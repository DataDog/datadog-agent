load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "utils",
    srcs = [
        "limiter.go",
        "memory_monitor_linux.go",
        "memory_monitor_stub.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/system-probe/utils",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
        "//vendor/go.uber.org/atomic",
