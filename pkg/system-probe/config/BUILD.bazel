load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = [
        "adjust.go",
        "adjust_discovery.go",
        "adjust_npm.go",
        "adjust_security.go",
        "adjust_usm.go",
        "config.go",
        "config_darwin.go",
        "config_linux.go",
        "config_linux_bpf.go",
        "config_unix.go",
        "config_unsupported.go",
        "config_windows.go",
        "ns.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/system-probe/config",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/config/model",
        "//pkg/config/setup",
        "//pkg/system-probe/config/types",
        "//pkg/util/defaultpaths",
        "//pkg/util/flavor",
        "//pkg/util/kernel",
        "//pkg/util/log",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/prebuilt",
            "//pkg/security/ebpf/kernel",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/prebuilt",
            "//pkg/security/ebpf/kernel",
        ],
        "@rules_go//go/platform:windows": [
            "//pkg/util/winutil",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "config_test",
    srcs = [
        "adjust_discovery_test.go",
        "adjust_npm_test.go",
        "config_linux_bpf_test.go",
        "config_test.go",
    ],
    embed = [":config"],
    deps = [
        "//pkg/config/mock",
        "//pkg/config/model",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/ebpf/prebuilt",
            "//pkg/util/kernel",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/ebpf/prebuilt",
            "//pkg/util/kernel",
        ],
        "//conditions:default": [],
    }),
)
