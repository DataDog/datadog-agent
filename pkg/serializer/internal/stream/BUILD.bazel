load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "stream",
    srcs = [
        "column.go",
        "compressor.go",
        "json_payload_builder.go",
        "test_helper.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/serializer/internal/stream",
    visibility = [
        "//pkg/serializer:__subpackages__",
        "@com_github_datadog_datadog_agent_pkg_serializer//:__subpackages__",
    ],
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/telemetry/impl",
        "//comp/forwarder/defaultforwarder/transaction",
        "//comp/serializer/metricscompression/def",
        "//pkg/serializer/marshaler",
        "//pkg/util/compression",
        "@com_github_json_iterator_go//:go",
    ],
)

dd_agent_go_test(
    name = "stream_test",
    srcs = [
        "column_test.go",
        "compressor_test.go",
    ],
    embed = [":stream"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/mock",
        "//comp/serializer/metricscompression/impl",
        "//pkg/config/mock",
        "//pkg/serializer/marshaler",
        "//pkg/util/compression",
        "//pkg/util/compression/impl-zlib",
        "@com_github_json_iterator_go//:go",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
