load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = [
        "client.go",
        "config.go",
        "mock_remote_client.go",
        "peer_tags.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/trace/config",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/tagger/origindetection",
        "//pkg/obfuscate",
        "//pkg/opentelemetry-mapping-go/otlp/attributes",
        "//pkg/remoteconfig/state",
        "//pkg/trace/log",
        "//pkg/trace/semantics",
        "//pkg/trace/traceutil",
        "@org_uber_go_mock//gomock",
    ],
)

dd_agent_go_test(
    name = "config_test",
    srcs = [
        "client_test.go",
        "config_test.go",
        "peer_tags_test.go",
    ],
    embed = [":config"],
    deps = [
        "//pkg/obfuscate",
        "//pkg/trace/semantics",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
