load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "info",
    srcs = [
        "endpoint.go",
        "info.go",
        "stats.go",
        "writer.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/trace/info",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/template/text",
        "//vendor/github.com/DataDog/datadog-agent/pkg/trace/config",
        "//vendor/github.com/DataDog/datadog-agent/pkg/trace/log",
        "//vendor/github.com/DataDog/datadog-agent/pkg/trace/sampler",
        "//vendor/github.com/DataDog/datadog-agent/pkg/trace/watchdog",
