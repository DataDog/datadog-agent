load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "log",
    srcs = [
        "buflogger.go",
        "logger.go",
        "throttled.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/trace/log",
    visibility = ["//visibility:public"],
    deps = ["//vendor/go.uber.org/atomic"],
)

go_test(
    name = "log_test",
    srcs = ["throttled_test.go"],
    embed = [":log"],
    gotags = ["test"],
    deps = ["//vendor/github.com/stretchr/testify/assert"],
)
