load("@rules_go//go:def.bzl", "go_library", "go_test")

# Here's whats broken.
# Test code in other packages on buflogger.go. But it should not
# be part of the public API because we don't use it in the product.

go_library(
    name = "log",
    srcs = [
        "logger.go",
        "throttled.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/trace/log",
    visibility = ["//visibility:public"],
    deps = ["@org_uber_go_atomic//:atomic"],
)

# Claude decided this was the solution. It doesn't work.
# testutil provides the full package including buflogger.go (//go:build test) for
# use by external test packages that need NewBufferLogger.
go_library(
    name = "testutil",
    testonly = True,
    srcs = [
        "buflogger.go",
        "logger.go",
        "throttled.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/trace/log",
    visibility = ["//visibility:public"],
    deps = ["@org_uber_go_atomic//:atomic"],
)

go_test(
    name = "log_test",
    srcs = [
        "throttled_test.go",
    ],
    embed = [":testutil"],
    deps = ["@com_github_stretchr_testify//assert"],
)
