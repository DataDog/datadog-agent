load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")
load("//bazel/rules/go_msgp:defs.bzl", "go_msgp")

go_msgp(
    name = "key_gen",
    src = "key.go",
    out = "key_gen.go",
    out_test = "key_gen_test.go",
)

go_library(
    name = "msgpgo",
    srcs = [
        "key.go",
        "key_gen.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/msgpgo",
    visibility = ["//visibility:public"],
    deps = ["@com_github_tinylib_msgp//msgp"],
)

dd_agent_go_test(
    name = "msgpgo_test",
    srcs = ["key_gen_test.go"],
    embed = [":msgpgo"],
    deps = ["@com_github_tinylib_msgp//msgp"],
)
