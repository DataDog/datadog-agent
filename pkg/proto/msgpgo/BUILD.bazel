load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/go_msgp:defs.bzl", "go_msgp")

go_msgp(
    name = "key_gen",
    src = "key.go",
    out = "key_gen.go",
    out_test = "key_gen_test.go",
)

go_library(
    name = "msgpgo",
    srcs = [
        "key.go",
        "key_gen.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/msgpgo",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["@com_github_tinylib_msgp//msgp"],
)

go_test(
    name = "msgpgo_test",
    srcs = ["key_gen_test.go"],
    embed = [":msgpgo"],
    gotags = ["test"],
    deps = ["@com_github_tinylib_msgp//msgp"],
)
