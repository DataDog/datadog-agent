load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

write_pb_go(
    name = "write_pb_go",
    srcs = {
        "//pkg/proto/datadog/trace/idx:idx_go_proto": [
            "span.pb.go",
            "tracer_payload.pb.go",
        ],
    },
)

go_library(
    name = "idx",
    srcs = [
        "internal_span.go",
        "span.go",
        "span.pb.go",
        "span_v05.go",
        "tracer_payload.go",
        "tracer_payload.pb.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/pbgo/trace/idx",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_tinylib_msgp//msgp",
        "@org_golang_google_protobuf//reflect/protoreflect",
        "@org_golang_google_protobuf//runtime/protoimpl",
    ],
)

dd_agent_go_test(
    name = "idx_test",
    srcs = [
        "internal_span_test.go",
        "span_marshal_test.go",
        "span_test.go",
        "span_v05_test.go",
        "string_table_guard_test.go",
        "tracer_payload_test.go",
    ],
    embed = [":idx"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@com_github_tinylib_msgp//msgp",
        "@com_github_vmihailenco_msgpack_v5//:msgpack",
        "@org_golang_google_protobuf//reflect/protoreflect",
    ],
)
