load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

write_pb_go(
    name = "write_pb_go",
    srcs = {
        "//pkg/proto/datadog/trace/idx:idx_go_proto": [
            "span.pb.go",
            "tracer_payload.pb.go",
        ],
    },
)

go_library(
    name = "idx",
    srcs = [
        "internal_span.go",
        "span.go",
        "span.pb.go",
        "span_v05.go",
        "tracer_payload.go",
        "tracer_payload.pb.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/pbgo/trace/idx",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/tinylib/msgp/msgp",
        "//vendor/google.golang.org/protobuf/reflect/protoreflect",
        "//vendor/google.golang.org/protobuf/runtime/protoimpl",
    ],
)

go_test(
    name = "idx_test",
    srcs = [
        "internal_span_test.go",
        "span_marshal_test.go",
        "span_test.go",
        "span_v05_test.go",
        "tracer_payload_test.go",
    ],
    embed = [":idx"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
        "//vendor/github.com/tinylib/msgp/msgp",
        "//vendor/github.com/vmihailenco/msgpack/v4:msgpack",
    ],
)
