# gazelle:write_pb_go //pkg/proto/datadog/trace:trace_go_proto //pkg/proto/datadog/trace:trace_go_proto_tagged
load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/go_msgp:defs.bzl", "go_msgp")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

filegroup(
    name = "trace_go_proto_tagged_srcs",
    srcs = ["//pkg/proto/datadog/trace:trace_go_proto_tagged"],
    output_group = "go_generated_srcs",
)

go_msgp(
    name = "agent_payload_gen",
    src = ":trace_go_proto_tagged_srcs",
    out = "agent_payload_gen.go",
    directives = ["limit arrays:500000 maps:500000"],
    out_test = "agent_payload_gen_test.go",
    src_file = "agent_payload.pb.go",
)

go_msgp(
    name = "span_gen",
    src = ":trace_go_proto_tagged_srcs",
    out = "span_gen.go",
    directives = ["limit arrays:500000 maps:500000"],
    out_test = "span_gen_test.go",
    patch_strip = 4,
    patches = ["//pkg/proto/patches:Customize-msgpack-parsing.patch"],
    src_file = "span.pb.go",
)

go_msgp(
    name = "stats_gen",
    src = ":trace_go_proto_tagged_srcs",
    out = "stats_gen.go",
    directives = ["limit arrays:500000 maps:500000"],
    io = True,
    out_test = "stats_gen_test.go",
    src_file = "stats.pb.go",
)

go_msgp(
    name = "trace_gen",
    src = "trace.go",
    out = "trace_gen.go",
    out_test = "trace_gen_test.go",
)

go_msgp(
    name = "tracer_payload_gen",
    src = ":trace_go_proto_tagged_srcs",
    out = "tracer_payload_gen.go",
    directives = ["limit arrays:500000 maps:500000"],
    out_test = "tracer_payload_gen_test.go",
    src_file = "tracer_payload.pb.go",
)

write_pb_go(
    name = "write_pb_go",
    srcs = {
        "//pkg/proto/datadog/trace:trace_go_proto_tagged": [
            "agent_payload.pb.go",
            "agent_payload_vtproto.pb.go",
            "span.pb.go",
            "span_vtproto.pb.go",
            "stats.pb.go",
            "stats_vtproto.pb.go",
            "tracer_payload.pb.go",
            "tracer_payload_vtproto.pb.go",
        ],
    },
)

go_library(
    name = "trace",
    srcs = [
        "agent_payload.pb.go",
        "agent_payload_gen.go",
        "agent_payload_marshal.go",
        "agent_payload_vtproto.pb.go",
        "decoder_bytes.go",
        "decoder_v05.go",
        "span.pb.go",
        "span_gen.go",
        "span_utils.go",
        "span_vtproto.pb.go",
        "stats.pb.go",
        "stats_gen.go",
        "stats_vtproto.pb.go",
        "trace.go",
        "trace_gen.go",
        "tracer_payload.pb.go",
        "tracer_payload_gen.go",
        "tracer_payload_utils.go",
        "tracer_payload_vtproto.pb.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/pbgo/trace",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/proto/pbgo/trace/idx",
        "@com_github_planetscale_vtprotobuf//protohelpers",
        "@com_github_tinylib_msgp//msgp",
        "@org_golang_google_protobuf//proto",
        "@org_golang_google_protobuf//reflect/protoreflect",
        "@org_golang_google_protobuf//runtime/protoimpl",
    ],
)

go_test(
    name = "trace_test",
    srcs = [
        "agent_payload_gen_test.go",
        "agent_payload_marshal_test.go",
        "convert_test.go",
        "decoder_bytes_test.go",
        "decoder_v05_test.go",
        "limit_test.go",
        "span_gen_modifs_test.go",
        "span_gen_test.go",
        "stats_gen_test.go",
        "trace_gen_safe_test.go",
        "trace_gen_test.go",
        "trace_test.go",
        "tracer_payload_gen_test.go",
        "utils_test.go",
    ],
    embed = [":trace"],
    gotags = ["test"],
    deps = [
        "//pkg/proto/pbgo/trace/idx",
        "@com_github_google_gofuzz//:gofuzz",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@com_github_tinylib_msgp//msgp",
        "@com_github_vmihailenco_msgpack_v5//:msgpack",
        "@org_golang_google_protobuf//proto",
    ],
)
