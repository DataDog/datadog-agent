load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

write_pb_go(
    name = "write_pb_go",
    srcs = {
        "//pkg/proto/datadog/sds:sds_go_proto": [
            "sds_result_payload.pb.go",
            "sds_result_payload_vtproto.pb.go",
        ],
    },
)

go_library(
    name = "sds",
    srcs = [
        "sds_result_payload.pb.go",
        "sds_result_payload_vtproto.pb.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/pbgo/sds",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_planetscale_vtprotobuf//protohelpers",
        "@org_golang_google_protobuf//proto",
        "@org_golang_google_protobuf//reflect/protoreflect",
        "@org_golang_google_protobuf//runtime/protoimpl",
    ],
)
