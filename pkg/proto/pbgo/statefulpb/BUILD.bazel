load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

go_library(
    name = "statefulpb",
    srcs = [
        "stateful_encoding.pb.go",
        "stateful_encoding_grpc.pb.go",
        "stateful_encoding_vtproto.pb.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/proto/pbgo/statefulpb",
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_planetscale_vtprotobuf//protohelpers",
        "@org_golang_google_grpc//:grpc",
        "@org_golang_google_grpc//codes",
        "@org_golang_google_grpc//status",
        "@org_golang_google_protobuf//reflect/protoreflect",
        "@org_golang_google_protobuf//runtime/protoimpl",
    ],
)

write_pb_go(
    name = "write_pb_go",
    srcs = {
        "//pkg/proto/datadog/stateful:stateful_go_proto": [
            "stateful_encoding.pb.go",
            "stateful_encoding_grpc.pb.go",
        ],
    },
)
