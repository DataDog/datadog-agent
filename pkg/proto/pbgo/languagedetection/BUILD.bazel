load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

write_pb_go(
    name = "write_pb_go",
    srcs = {
        "//pkg/proto/datadog/languagedetection:languagedetection_go_proto": [
            "api.pb.go",
        ],
    },
