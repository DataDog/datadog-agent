# gazelle:go_proto_compilers @rules_go//proto:go_proto,//bazel/rules/go_proto_compiler:go_vtproto_full
load("@protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_go//proto:def.bzl", "go_proto_library")

proto_library(
    name = "sds_proto",
    srcs = ["sds_result_payload.proto"],
    strip_import_prefix = "/pkg/proto",
    visibility = ["//visibility:public"],
)

go_proto_library(
    name = "sds_go_proto",
    compilers = [
        "@rules_go//proto:go_proto",
        "//bazel/rules/go_proto_compiler:go_vtproto_full",
    ],
    importpath = "pkg/proto/pbgo/sds",
    proto = ":sds_proto",
    visibility = ["//visibility:public"],
)
