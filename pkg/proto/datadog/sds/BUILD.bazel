load("@protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_rust_prost//:defs.bzl", "rust_prost_library")

# No Go consumer for this proto: forwarder relays raw bytes. Prevent gazelle
# (inherited `# gazelle:proto package` from ../BUILD.bazel) from generating a
# go_proto_library here.
# gazelle:proto disable

exports_files(["sds_result.proto"])

proto_library(
    name = "sds_proto",
    srcs = ["sds_result.proto"],
    strip_import_prefix = "/pkg/proto",
    visibility = ["//visibility:public"],
)

_LINUX_OR_WINDOWS = select({
    "@platforms//os:linux": [],
    "@platforms//os:windows": [],
    "//conditions:default": ["@platforms//:incompatible"],
})

rust_prost_library(
    name = "sds_rust_proto",
    proto = ":sds_proto",
    target_compatible_with = _LINUX_OR_WINDOWS,
    visibility = ["//visibility:public"],
)
