load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "devicededuper",
    srcs = ["device_deduper.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/snmp/devicededuper",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/snmp",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "devicededuper_test",
    srcs = ["device_deduper_test.go"],
    embed = [":devicededuper"],
    deps = [
        "//pkg/snmp",
        "@com_github_stretchr_testify//assert",
    ],
)
