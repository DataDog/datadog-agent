load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "analyzer",
    srcs = ["analyzer.go"],
    importpath = "github.com/DataDog/datadog-agent/pkg/snmp/analyzer",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/collector/corechecks/snmp",
        "//pkg/networkdevice/profile/profiledefinition",
        "//pkg/snmp/gosnmplib",
        "@com_github_gosnmp_gosnmp//:gosnmp",
    ],
)

dd_agent_go_test(
    name = "analyzer_test",
    srcs = ["analyzer_test.go"],
    embed = [":analyzer"],
    deps = [
        "//pkg/collector/corechecks/snmp",
        "@com_github_gosnmp_gosnmp//:gosnmp",
    ],
)
