load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "runtime",
    srcs = [
        "gomemlimit.go",
        "gomemlimit_linux.go",
        "runtime.go",
        "thp_linux.go",
        "thp_unsupported.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/runtime",
    visibility = ["//visibility:public"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/util/log",
        "//vendor/go.uber.org/automaxprocs/maxprocs",
    ] + select({
        "@rules_go//go/platform:android": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/cgroups",
            "//vendor/golang.org/x/sys/unix",
        ],
        "@rules_go//go/platform:linux": [
            "//vendor/github.com/DataDog/datadog-agent/pkg/util/cgroups",
            "//vendor/golang.org/x/sys/unix",
        ],
        "//conditions:default": [],
    }),
)

go_test(
    name = "runtime_test",
    srcs = ["runtime_test.go"],
    embed = [":runtime"],
    gotags = ["test"],
    deps = ["//vendor/github.com/stretchr/testify/assert"],
)
