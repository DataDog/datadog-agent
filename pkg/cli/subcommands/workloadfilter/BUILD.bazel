load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "workloadfilter",
    srcs = [
        "command.go",
        "verify_config_cel.go",
        "verify_config_nocel.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/cli/subcommands/workloadfilter",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadfilter/fx",
        "//comp/core/workloadfilter/impl/parse",
        "//comp/core/workloadfilter/util/celprogram",
        "//pkg/util/fxutil",
        "@com_github_fatih_color//:color",
        "@com_github_spf13_cobra//:cobra",
        "@in_yaml_go_yaml_v2//:yaml",
        "@org_uber_go_fx//:fx",
    ],
)

dd_agent_go_test(
    name = "workloadfilter_test",
    srcs = [
        "command_test.go",
        "verify_config_cel_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":workloadfilter"],
    deps = [
        "//comp/core",
        "//pkg/util/fxutil",
        "@com_github_spf13_cobra//:cobra",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
