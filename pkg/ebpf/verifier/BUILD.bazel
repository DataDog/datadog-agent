load("@rules_go//go:def.bzl", "go_library", "go_test")
load("//bazel/rules/ebpf:ebpf_object_dir.bzl", "ebpf_object_dir")
load("//tasks:ebpf_targets.bzl", "CORE_TARGETS", "PREBUILT_TARGETS")

# keep
ebpf_object_dir(
    name = "verifier_bpf_dir",
    core = CORE_TARGETS,
    prebuilt = PREBUILT_TARGETS,
    visibility = ["//pkg/ebpf/verifier:__subpackages__"],
)

#gazelle:dd_linux_bpf on

go_library(
    name = "verifier",
    srcs = [
        "elf.go",
        "stats.go",
        "stats_no_linux.go",
        "types.go",
        "verifier_log_parser.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/ebpf/verifier",
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/impl/noops",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/names",
        "//pkg/ebpf/telemetry",
        "//pkg/util/kernel",
        "//pkg/util/safeelf",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_datadog_ebpf_manager//:ebpf-manager",
    ],
)

go_test(
    name = "verifier_test",
    srcs = [
        "elf_test.go",
        "stats_test.go",
        "verifier_log_parser_test.go",
    ],
    data = [":verifier_bpf_dir"],
    embed = [":verifier"],
    env = {
        "DD_SYSTEM_PROBE_BPF_DIR": "$(rootpath :verifier_bpf_dir)",
    },
    gotags = [
        "test",
        "linux_bpf",
    ],
    rundir = ".",
    tags = ["manual"],  # keep
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//pkg/ebpf",
        "//pkg/util/filesystem",
        "//pkg/util/kernel",
        "//pkg/util/log",
        "@com_github_cilium_ebpf//:ebpf",
        "@com_github_cilium_ebpf//rlimit",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
