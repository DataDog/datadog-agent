        ],
        "//conditions:default": [],
    }) + select({
        "@platforms//cpu:x86_64": ["//pkg/ebpf/kernelbugs/c:detect-seccomp-bug"],
        "//conditions:default": [],
    }),
    visibility = ["//visibility:public"],
)

