# gazelle:ignore
# gazelle:exclude _obj
# gazelle:exclude bytecode
# gazelle:exclude compiler
# gazelle:exclude ebpftest
# gazelle:exclude features
# gazelle:exclude kernelbugs
# gazelle:exclude maps
# gazelle:exclude names
# gazelle:exclude perf
# gazelle:exclude prebuilt
# gazelle:exclude uprobes
# gazelle:exclude verifier

load("@rules_go//go:def.bzl", "go_binary")
load("//bazel/rules/ebpf:cgo_godefs.bzl", "cgo_godefs")

exports_files([
    "types_linux.go",
    "types_linux_test.go",
])

cgo_godefs(
    name = "types_godefs",
    src = "types.go",
    visibility = ["//visibility:public"],
    deps = ["//pkg/network/ebpf/c:ebpf_c_network"],
)

# Hand-written: rules_go respects //go:build ignore, so strip it before compiling.
genrule(
    name = "include_headers_src",
    srcs = ["include_headers.go"],
    outs = ["include_headers_gen.go"],
    cmd = "grep -v '^//go:build ignore' $< > $@",
)

go_binary(
    name = "include_headers",
    srcs = [":include_headers_src"],
    visibility = ["//visibility:public"],
)

# Convenience: verify all committed generated files (cgo godefs) in one shot.
# Incompatible targets are skipped via target_compatible_with.
# Runtime hash _verify_test targets are excluded (files are .gitignored).
#   bazel test //pkg/ebpf:verify_generated_files
test_suite(
    name = "verify_generated_files",
    tests = [
        # ── Linux cgo_godefs ───────────────────────────────────────────
        ":types_godefs_test",
        ":types_godefs_test_file_test",
        "//pkg/ebpf/telemetry:types_godefs_test",
        "//pkg/ebpf/telemetry:types_godefs_test_file_test",
        "//pkg/network/ebpf:conntrack_types_godefs_test",
        "//pkg/network/ebpf:conntrack_types_godefs_test_file_test",
        "//pkg/network/ebpf:tuple_types_godefs_test",
        "//pkg/network/ebpf:tuple_types_godefs_test_file_test",
        "//pkg/network/ebpf:kprobe_types_godefs_test",
        "//pkg/network/ebpf:kprobe_types_godefs_test_file_test",
        "//pkg/network/protocols:ebpf_types_godefs_test",
        "//pkg/network/protocols:ebpf_types_godefs_test_file_test",
        "//pkg/network/protocols/events:types_godefs_test",
        "//pkg/network/protocols/events:types_godefs_test_file_test",
        "//pkg/network/protocols/http:types_godefs_test",
        "//pkg/network/protocols/http:types_godefs_test_file_test",
        "//pkg/network/protocols/http/gotls:go_tls_types_godefs_test",
        "//pkg/network/protocols/http/gotls:go_tls_types_godefs_test_file_test",
        "//pkg/network/protocols/http2:types_godefs_test",
        "//pkg/network/protocols/http2:types_godefs_test_file_test",
        "//pkg/network/protocols/kafka:types_godefs_test",
        "//pkg/network/protocols/kafka:types_godefs_test_file_test",
        "//pkg/network/protocols/postgres/ebpf:types_godefs_test",
        "//pkg/network/protocols/postgres/ebpf:types_godefs_test_file_test",
        "//pkg/network/protocols/redis:types_godefs_test",
        "//pkg/network/protocols/redis:types_godefs_test_file_test",
        "//pkg/network/protocols/tls:types_godefs_test",
        "//pkg/network/protocols/tls:types_godefs_test_file_test",
        "//pkg/network/tracer/offsetguess:offsetguess_types_godefs_test",
        "//pkg/network/tracer/offsetguess:offsetguess_types_godefs_test_file_test",
        "//pkg/network/usm/sharedlibraries:types_godefs_test",
        "//pkg/network/usm/sharedlibraries:types_godefs_test_file_test",
        "//pkg/collector/corechecks/ebpf/probe/ebpfcheck:c_types_godefs_test",
        "//pkg/collector/corechecks/ebpf/probe/ebpfcheck:c_types_godefs_test_file_test",
        "//pkg/collector/corechecks/ebpf/probe/noisyneighbor:ebpf_types_godefs_test",
        "//pkg/collector/corechecks/ebpf/probe/noisyneighbor:ebpf_types_godefs_test_file_test",
        "//pkg/collector/corechecks/ebpf/probe/oomkill:c_types_godefs_test",
        "//pkg/collector/corechecks/ebpf/probe/oomkill:c_types_godefs_test_file_test",
        "//pkg/collector/corechecks/ebpf/probe/tcpqueuelength:tcp_queue_length_kern_types_godefs_test",
        "//pkg/collector/corechecks/ebpf/probe/tcpqueuelength:tcp_queue_length_kern_types_godefs_test_file_test",
        "//pkg/gpu/ebpf:kprobe_types_godefs_test",
        "//pkg/gpu/ebpf:kprobe_types_godefs_test_file_test",
        "//pkg/dyninst/loader:types_godefs_test",
        "//pkg/dyninst/loader:types_godefs_test_file_test",
        "//pkg/dyninst/output:framing_godefs_test",
        "//pkg/dyninst/output:framing_godefs_test_file_test",
        # ── Windows cgo_godefs ─────────────────────────────────────────
        "//pkg/network/driver:types_godefs_test",
        "//pkg/windowsdriver/procmon:types_godefs_test",
        # Runtime compilation hash _verify_test targets are excluded:
        # their out_files are .gitignored so tests only pass after a local build.
        # Use  bazel run //pkg/ebpf/bytecode:<name>_verify  to update locally.
    ],
)

