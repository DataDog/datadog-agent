load("@rules_cc//cc:cc_library.bzl", "cc_library")
load("//bazel/rules/ebpf:ebpf.bzl", "ebpf_prog")

_HDRS = glob(["*.h"])

cc_library(
    name = "ebpf_c_headers",
    hdrs = _HDRS,
    includes = ["."],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "ebpf_c_headers_files",
    srcs = _HDRS,
    visibility = ["//visibility:public"],
)

ebpf_prog(
    name = "lock_contention",
    src = "lock_contention.c",
    core = True,
    deps = [":ebpf_c_headers"],
)

ebpf_prog(
    name = "ksyms_iter",
    src = "ksyms_iter.c",
    core = True,
    deps = [":ebpf_c_headers"],
)
