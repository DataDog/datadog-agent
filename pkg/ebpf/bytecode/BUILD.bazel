runtime_compilation_bundle(
    name = "tracer",
    header_deps = _NETWORK_HEADERS,
    include_dirs = [
        "pkg/ebpf/c",
        "pkg/network/ebpf/c/runtime",
        "pkg/network/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:tracer.go",
    out_name = "tracer",
    src_c = "//pkg/network/ebpf/c:tracer.c",
    visibility = ["//visibility:public"],
)

runtime_compilation_bundle(
    name = "offsetguess-test",
    header_deps = _NETWORK_HEADERS,
    include_dirs = [
        "pkg/ebpf/c",
        "pkg/network/ebpf/c/runtime",
        "pkg/network/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:offsetguess-test.go",
    out_name = "offsetguess-test",
    src_c = "//pkg/network/ebpf/c/runtime:offsetguess-test.c",
    visibility = ["//visibility:public"],
