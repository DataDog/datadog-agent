runtime_compilation_bundle(
    name = "runtime-security",
    header_deps = _EBPF_HEADERS + ["//pkg/security/ebpf/c/include:security_ebpf_headers_files"],
    include_dirs = [
        "pkg/security/ebpf/c/include",
        "pkg/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:runtime-security.go",
    out_name = "runtime-security",
    src_c = "//pkg/security/ebpf/c/prebuilt:probe.c",
    visibility = ["//visibility:public"],
)

runtime_compilation_bundle(
    name = "gpu",
    header_deps = _NETWORK_HEADERS + ["//pkg/gpu/ebpf/c:gpu_headers_files"],
    include_dirs = [
        "pkg/ebpf/c",
        "pkg/gpu/ebpf/c/runtime",
        "pkg/gpu/ebpf/c",
        "pkg/network/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:gpu.go",
    out_name = "gpu",
    src_c = "//pkg/gpu/ebpf/c/runtime:gpu.c",
    visibility = ["//visibility:public"],
)

# copy_file targets: copy prebuilt eBPF .o files into this package's directory
# so //go:embed patterns (which resolve relative to the .go file) can find them.
# arm64 variants
copy_file(
    name = "runtime-security-arm64",
    src = "//pkg/security/ebpf/c/prebuilt:runtime-security",
    out = "build/arm64/runtime-security.o",
    target_compatible_with = [
        "@platforms//cpu:aarch64",
        "@platforms//os:linux",
    ],
)

copy_file(
    name = "runtime-security-syscall-wrapper-arm64",
    src = "//pkg/security/ebpf/c/prebuilt:runtime-security-syscall-wrapper",
    out = "build/arm64/runtime-security-syscall-wrapper.o",
    target_compatible_with = [
        "@platforms//cpu:aarch64",
        "@platforms//os:linux",
    ],
)

copy_file(
    name = "runtime-security-fentry-arm64",
