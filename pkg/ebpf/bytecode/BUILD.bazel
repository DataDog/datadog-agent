load("@bazel_lib//lib:copy_file.bzl", "copy_file")
load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/ebpf:runtime_compilation.bzl", "runtime_compilation_bundle")

_EBPF_HEADERS = ["//pkg/ebpf/c:ebpf_c_headers_files"]

_CORECHECK_HEADERS = _EBPF_HEADERS + [
    "//pkg/collector/corechecks/ebpf/c/runtime:corecheck_ebpf_headers_files",
]

_NETWORK_HEADERS = _EBPF_HEADERS + [
    "//pkg/network/ebpf/c:ebpf_c_network_files",
    "//pkg/network/ebpf/c/runtime:runtime_headers_files",
    "//pkg/network/ebpf/c/prebuilt:prebuilt_headers_files",
]

runtime_compilation_bundle(
    name = "oom-kill",
    header_deps = _CORECHECK_HEADERS,
    include_dirs = ["pkg/ebpf/c"],
    out_go_file = "//pkg/ebpf/bytecode/runtime:oom-kill.go",
    out_name = "oom-kill",
    src_c = "//pkg/collector/corechecks/ebpf/c/runtime:oom-kill-kern.c",
    visibility = ["//visibility:public"],
)

runtime_compilation_bundle(
    name = "tcp-queue-length",
    header_deps = _CORECHECK_HEADERS,
    include_dirs = ["pkg/ebpf/c"],
    out_go_file = "//pkg/ebpf/bytecode/runtime:tcp-queue-length.go",
    out_name = "tcp-queue-length",
    src_c = "//pkg/collector/corechecks/ebpf/c/runtime:tcp-queue-length-kern.c",
    visibility = ["//visibility:public"],
)

runtime_compilation_bundle(
    name = "usm",
    header_deps = _NETWORK_HEADERS,
    include_dirs = [
        "pkg/ebpf/c",
        "pkg/network/ebpf/c/runtime",
        "pkg/network/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:usm.go",
    out_name = "usm",
    src_c = "//pkg/network/ebpf/c/runtime:usm.c",
    visibility = ["//visibility:public"],
)

runtime_compilation_bundle(
    name = "shared-libraries",
    header_deps = _NETWORK_HEADERS,
    include_dirs = [
        "pkg/ebpf/c",
        "pkg/network/ebpf/c/runtime",
        "pkg/network/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:shared-libraries.go",
    out_name = "shared-libraries",
    src_c = "//pkg/network/ebpf/c/runtime:shared-libraries.c",
    visibility = ["//visibility:public"],
)

runtime_compilation_bundle(
    name = "conntrack",
    header_deps = _NETWORK_HEADERS,
    include_dirs = [
        "pkg/ebpf/c",
        "pkg/network/ebpf/c/runtime",
        "pkg/network/ebpf/c",
    ],
    out_go_file = "//pkg/ebpf/bytecode/runtime:conntrack.go",
    out_name = "conntrack",
    src_c = "//pkg/network/ebpf/c/runtime:conntrack.c",
    visibility = ["//visibility:public"],
