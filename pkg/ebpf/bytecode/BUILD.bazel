go_library(
    name = "bytecode",
    srcs = [
        "asset_reader.go",
        "asset_reader_nobindata.go",
        "permissions.go",
        "permissions_windows.go",
    ],
    embedsrcs = select({
        "@platforms//cpu:aarch64": [
            ":runtime-security-arm64",
            ":runtime-security-fentry-arm64",
            ":runtime-security-offset-guesser-arm64",
            ":runtime-security-syscall-wrapper-arm64",
        ],
        "@platforms//cpu:x86_64": [
            ":runtime-security-amd64",
            ":runtime-security-fentry-amd64",
            ":runtime-security-offset-guesser-amd64",
            ":runtime-security-syscall-wrapper-amd64",
        ],
        "//conditions:default": [],
    }),
    importpath = "github.com/DataDog/datadog-agent/pkg/ebpf/bytecode",
    visibility = ["//visibility:public"],
)
