load("@rules_go//go:def.bzl", "go_binary", "go_library")

exports_files(
    [
        "oom-kill.go",
        "tcp-queue-length.go",
        "usm.go",
        "shared-libraries.go",
        "conntrack.go",
        "tracer.go",
        "offsetguess-test.go",
        "runtime-security.go",
        "gpu.go",
    ],
    visibility = ["//pkg/ebpf/bytecode:__pkg__"],
)

go_library(
    name = "runtime",
    srcs = [
        "all_helpers.go",
        "asset.go",
        "conntrack.go",
        "gpu.go",
        "helpers.go",
        "offsetguess.go",
        "offsetguess-test.go",
        "oom-kill.go",
        "protected_file.go",
        "runtime-security.go",
        "runtime_compilation_helpers.go",
        "shared-libraries.go",
        "tcp-queue-length.go",
        "telemetry.go",
        "tracer.go",
        "usm.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/ebpf/bytecode/runtime",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//comp/core/telemetry/def",
            "//comp/core/telemetry/impl",
            "//pkg/ebpf",
            "//pkg/ebpf/bytecode",
            "//pkg/ebpf/compiler",
            "//pkg/util/kernel",
            "//pkg/util/kernel/headers",
            "//pkg/util/log",
            "@com_github_datadog_agent_payload_v5//process",
        ],
        "@rules_go//go/platform:linux": [
            "//comp/core/telemetry/def",
            "//comp/core/telemetry/impl",
            "//pkg/ebpf",
            "//pkg/ebpf/bytecode",
            "//pkg/ebpf/compiler",
            "//pkg/util/kernel",
            "//pkg/util/kernel/headers",
            "//pkg/util/log",
            "@com_github_datadog_agent_payload_v5//process",
        ],
        "//conditions:default": [],
    }),
)

# Hand-written: rules_go respects //go:build ignore, so strip it before compiling.
genrule(
    name = "integrity_src",
    srcs = ["integrity.go"],
    outs = ["integrity_gen.go"],
    cmd = "grep -v '^//go:build ignore' $< > $@",
)

go_binary(
    name = "integrity",
    srcs = [":integrity_src"],
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/template/text",
        "@org_golang_x_text//cases",
        "@org_golang_x_text//language",
    ],
)
