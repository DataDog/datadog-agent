load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

exports_files(
    [
        "oom-kill.go",
        "tcp-queue-length.go",
        "usm.go",
        "shared-libraries.go",
        "conntrack.go",
        "tracer.go",
        "offsetguess-test.go",
        "runtime-security.go",
        "gpu.go",
    ],
    visibility = ["//pkg/ebpf/bytecode:__pkg__"],
)

# Hand-written: rules_go respects //go:build ignore, so strip it before compiling.
genrule(
    name = "integrity_src",
    srcs = ["integrity.go"],
    outs = ["integrity_gen.go"],
    cmd = "grep -v '^//go:build ignore' $< > $@",
)

go_binary(
    name = "integrity",
    srcs = [":integrity_src"],  # keep
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/template/text",
        "@org_golang_x_text//cases",
        "@org_golang_x_text//language",
    ],
)

go_library(
    name = "runtime",
    srcs = [
        "all_helpers.go",
        "asset.go",
        "conntrack.go",
        "gpu.go",
        "helpers.go",
        "offsetguess.go",
        "offsetguess-test.go",
        "oom-kill.go",
        "protected_file.go",
        "runtime-security.go",
        "runtime_compilation_helpers.go",
        "shared-libraries.go",
        "tcp-queue-length.go",
        "telemetry.go",
        "tracer.go",
        "usm.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/ebpf/bytecode/runtime",
    target_compatible_with = ["@platforms//os:linux"],  # keep
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/compiler",
        "//pkg/template/text",
        "//pkg/util/kernel",
        "//pkg/util/kernel/headers",
        "//pkg/util/log",
        "@com_github_datadog_agent_payload_v5//process",
        "@com_github_justincormack_go_memfd//:go-memfd",
    ],
)

go_test(
    name = "runtime_test",
    srcs = ["helpers_test.go"],
    embed = [":runtime"],
    gotags = ["test"],
    deps = [
        "//pkg/ebpf",
        "//pkg/util/kernel",
        "//pkg/util/kernel/headers",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
