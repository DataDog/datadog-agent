load("@rules_go//go:def.bzl", "go_binary", "go_library", "go_test")

# gazelle:dd_linux_bpf on

# These files are generated by runtime_compilation_bundle and gitignored;
# exclude them so Gazelle does not try to manage them as static sources.
# gazelle:exclude conntrack.go
# gazelle:exclude gpu.go
# gazelle:exclude offsetguess-test.go
# gazelle:exclude oom-kill.go
# gazelle:exclude runtime-security.go
# gazelle:exclude shared-libraries.go
# gazelle:exclude tcp-queue-length.go
# gazelle:exclude tracer.go
# gazelle:exclude usm.go

exports_files(
    [
        "oom-kill.go",
        "tcp-queue-length.go",
        "usm.go",
        "shared-libraries.go",
        "conntrack.go",
        "tracer.go",
        "offsetguess-test.go",
        "runtime-security.go",
        "gpu.go",
    ],
    visibility = ["//pkg/ebpf/bytecode:__pkg__"],
)

# gazelle:exclude integrity_gen.go

# Hand-written: rules_go respects //go:build ignore, so strip it before compiling.
genrule(
    name = "integrity_src",
    srcs = ["integrity.go"],
    outs = ["integrity_gen.go"],
    cmd = "grep -v '^//go:build ignore' $< > $@",
)

go_binary(
    name = "integrity",
    srcs = [":integrity_src"],  # keep
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/template/text",
        "@org_golang_x_text//cases",
        "@org_golang_x_text//language",
    ],
)

go_library(
    name = "runtime",
    srcs = [
        "all_helpers.go",
        "asset.go",
        "helpers.go",
        "offsetguess.go",
        "protected_file.go",
        "runtime_compilation_helpers.go",
        "telemetry.go",
        "//pkg/ebpf/bytecode:conntrack_gen",  # keep
        "//pkg/ebpf/bytecode:gpu_gen",  # keep
        "//pkg/ebpf/bytecode:offsetguess-test_gen",  # keep
        "//pkg/ebpf/bytecode:oom-kill_gen",  # keep
        "//pkg/ebpf/bytecode:runtime-security_gen",  # keep
        "//pkg/ebpf/bytecode:shared-libraries_gen",  # keep
        "//pkg/ebpf/bytecode:tcp-queue-length_gen",  # keep
        "//pkg/ebpf/bytecode:tracer_gen",  # keep
        "//pkg/ebpf/bytecode:usm_gen",  # keep
    ],
    importpath = "github.com/DataDog/datadog-agent/pkg/ebpf/bytecode/runtime",
    tags = ["manual"],
    target_compatible_with = ["@platforms//os:linux"],  # keep
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//pkg/ebpf",
        "//pkg/ebpf/bytecode",
        "//pkg/ebpf/compiler",
        "//pkg/template/text",
        "//pkg/util/kernel",
        "//pkg/util/kernel/headers",
        "//pkg/util/log",
        "@com_github_datadog_agent_payload_v5//process",
        "@com_github_justincormack_go_memfd//:go-memfd",
    ],
)

# This is an integration test that is supposed to run
# in a target runtime environment. It requires the presence
# of clang-bpf in the agent's installation path.
go_test(
    name = "runtime_test",
    srcs = ["helpers_test.go"],
    embed = [":runtime"],
    gotags = ["linux_bpf"],  # keep
    tags = ["manual"],  # keep
    target_compatible_with = ["@platforms//os:linux"],
    deps = [
        "//pkg/ebpf",
        "//pkg/util/kernel",
        "//pkg/util/kernel/headers",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
