load("@rules_cc//cc:defs.bzl", "cc_binary")

package(default_visibility = ["//visibility:public"])

# Hermetic MSYS2 sh_toolchain lives in @msys2_base//: (see msys2.BUILD.bazel).
# This package also builds the committed Windows launcher used by
# --shell_executable in .bazelrc.
cc_binary(
    name = "bash_shim",
    srcs = ["bash_shim.c"],
    target_compatible_with = [
        "@platforms//os:windows",
        "@platforms//cpu:x86_64",
    ],
)
