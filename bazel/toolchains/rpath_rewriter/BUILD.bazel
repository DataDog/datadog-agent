"""toolchains for rpath-patching"""

load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")
load(":install_name_tool.bzl", "macos_rpath_rewriter", "macos_tree_rpath_rewriter")
load(":patchelf.bzl", "patchelf_rpath_rewriter", "patchelf_tree_rpath_rewriter")
load(":toolchain.bzl", "noop_toolchain", "rpath_rewriter_toolchain")

# Provides rpath rewriting toolchains. Rewriters either expose a `rewriter_tool`
# executable taking <thing-to-patch> <new-rpath> <output-path>, or expose no
# executable to signal that rpath rewriting is not applicable for the target.
toolchain_type(
    name = "rpath_rewriter",
    visibility = ["//visibility:public"],
)

patchelf_rpath_rewriter(
    name = "patchelf_rpath_rewriter",
    patchelf = "@patchelf//:patchelf",
)

patchelf_tree_rpath_rewriter(
    name = "patchelf_tree_rpath_rewriter",
    patchelf = "@patchelf//:patchelf",
)

rpath_rewriter_toolchain(
    name = "patchelf_rpath_rewriter_toolchain",
    rewriter_tool = ":patchelf_rpath_rewriter",
    tree_rewriter_tool = ":patchelf_tree_rpath_rewriter",
)

macos_rpath_rewriter(
    name = "install_name_tool_rpath_rewriter",
    install_name_tool = "//bazel/tools:install_name_tool",
)

macos_tree_rpath_rewriter(
    name = "install_name_tool_tree_rpath_rewriter",
    install_name_tool = "//bazel/tools:install_name_tool",
)

rpath_rewriter_toolchain(
    name = "install_name_tool_rpath_rewriter_toolchain",
    rewriter_tool = ":install_name_tool_rpath_rewriter",
    tree_rewriter_tool = ":install_name_tool_tree_rpath_rewriter",
)

noop_toolchain(
    name = "noop_rpath_rewriter_toolchain",
)

toolchain(
    name = "patchelf_toolchain",
    exec_compatible_with = ["@platforms//os:linux"],
    target_compatible_with = ["@platforms//os:linux"],
    toolchain = ":patchelf_rpath_rewriter_toolchain",
    toolchain_type = ":rpath_rewriter",
)

toolchain(
    name = "install_name_tool_toolchain",
    exec_compatible_with = ["@platforms//os:macos"],
    target_compatible_with = ["@platforms//os:macos"],
    toolchain = ":install_name_tool_rpath_rewriter_toolchain",
    toolchain_type = ":rpath_rewriter",
)

toolchain(
    name = "noop_windows_toolchain",
    target_compatible_with = ["@platforms//os:windows"],
    toolchain = ":noop_rpath_rewriter_toolchain",
    toolchain_type = ":rpath_rewriter",
)

cc_binary(
    name = "foo",
    srcs = ["foo.c"],
    linkshared = True,
    target_compatible_with = ["@platforms//os:macos"],
)

cc_binary(
    name = "bar",
    srcs = [
        "bar.c",
        "foo.c",
    ],
    linkshared = True,
    target_compatible_with = ["@platforms//os:macos"],
)

# Python extension modules on macOS are Mach-O bundles named `.so`. Reuse foo's
# binary content under a `.so` name to exercise that branch of the tree rewriter.
genrule(
    name = "baz_so",
    srcs = [":foo"],
    outs = ["baz.so"],
    cmd = "cp $(location :foo) $@",
    target_compatible_with = ["@platforms//os:macos"],
)

sh_test(
    name = "macos_dir_test",
    srcs = ["macos_dir_test.sh"],
    args = ["$(location @llvm_toolchain_llvm//:install-name-tool)"],
    data = [
        ":bar",
        ":baz_so",
        ":foo",
        ":rewrite_tree_with_install_name_tool.sh",
        ":rewrite_with_install_name_tool.sh",
        ":rpath_helpers.sh",
        "@llvm_toolchain_llvm//:install-name-tool",
    ],
    target_compatible_with = ["@platforms//os:macos"],
)
