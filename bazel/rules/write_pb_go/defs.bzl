load("@bazel_lib//lib:write_source_files.bzl", "write_source_files")
load("@bazel_skylib//rules:select_file.bzl", "select_file")

def write_pb_go(name, srcs):
    """Writes .pb.go files generated by go_proto_library targets back into the source tree.

    Args:
        name: target name
        srcs: dict mapping each go_proto_library label to the list of .pb.go filenames it generates
    """
    files = {}
    for i, (go_proto_library, outs) in enumerate(srcs.items()):
        group = "{}_srcs_{}".format(name, i)
        native.filegroup(name = group, srcs = [go_proto_library], output_group = "go_generated_srcs")
        for j, out in enumerate(outs):
            file = "{}_{}".format(group, j)
            select_file(name = file, srcs = ":{}".format(group), subpath = out)
            files[out] = file
    write_source_files(name = name, files = files)
