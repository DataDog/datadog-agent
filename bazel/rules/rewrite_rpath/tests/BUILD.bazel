load("@rules_cc//cc:defs.bzl", "cc_binary")
load("@rules_shell//shell:sh_test.bzl", "sh_test")

cc_binary(
    name = "foo",
    srcs = ["foo.c"],
    linkshared = True,
    target_compatible_with = ["@platforms//os:macos"],
)

cc_binary(
    name = "bar",
    srcs = [
        "bar.c",
        "foo.c",
    ],
    linkshared = True,
    target_compatible_with = ["@platforms//os:macos"],
)

# Python extension modules on macOS are Mach-O bundles named `.so`. Reuse foo's
# binary content under a `.so` name to exercise that branch of macos_dir.sh.
genrule(
    name = "baz_so",
    srcs = [":foo"],
    outs = ["baz.so"],
    cmd = "cp $(location :foo) $@",
    target_compatible_with = ["@platforms//os:macos"],
)

sh_test(
    name = "macos_dir_test",
    srcs = ["macos_dir_test.sh"],
    data = [
        ":bar",
        ":baz_so",
        ":foo",
        "//bazel/rules/rewrite_rpath:macos.sh",
        "//bazel/rules/rewrite_rpath:macos_dir.sh",
    ],
    target_compatible_with = ["@platforms//os:macos"],
)
