load(":glibc_floor_test.bzl", "glibc_floor_test")

glibc_floor_test(
    name = "cws_instrumentation_x86_64_floor",
    binary = "//cmd/cws-instrumentation",
    max_version = "2.17",
    target_compatible_with = [
        "@platforms//os:linux",
        "@platforms//cpu:x86_64",
    ],
)

glibc_floor_test(
    name = "cws_instrumentation_arm64_floor",
