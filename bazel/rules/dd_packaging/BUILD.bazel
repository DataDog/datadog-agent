load("@bazel_skylib//:bzl_library.bzl", "bzl_library")
load(":dd_packaging_test.bzl", "dd_packaging_test_suite")

bzl_library(
    name = "dd_packaging_info_bzl",
    srcs = ["dd_packaging_info.bzl"],
    visibility = [":__pkg__"],
)

bzl_library(
    name = "dd_collect_dependencies_bzl",
    srcs = ["dd_collect_dependencies.bzl"],
    visibility = ["//visibility:public"],
    deps = [
        ":dd_packaging_info_bzl",
        "@rules_pkg//pkg:providers.bzl",
    ],
)

bzl_library(
    name = "dd_cc_packaged_bzl",
    srcs = ["dd_cc_packaged.bzl"],
    visibility = ["//visibility:public"],
    deps = [
        ":dd_packaging_info_bzl",
        "//bazel/rules:so_symlink_bzl",
        "//bazel/rules/rewrite_rpath:rewrite_rpath_bzl",
        "@rules_pkg//pkg:mappings.bzl",
        "@rules_pkg//pkg:providers.bzl",
    ],
)

bzl_library(
    name = "dd_packaging_test_bzl",
    srcs = ["dd_packaging_test.bzl"],
    deps = [
        ":dd_cc_packaged_bzl",
        ":dd_collect_dependencies_bzl",
        "@rules_pkg//pkg:mappings.bzl",
        "@rules_testing//lib:analysis_test_bzl",
        "@rules_testing//lib:truth_bzl",
        "@rules_testing//lib:util_bzl",
    ],
)

dd_packaging_test_suite(name = "_dd_packaging_tests")
