// FlatBuffers schema for the flight recorder signal types.
//
// Generate Go:   flatc --go -o comp/flightrecorder/impl signals.fbs
// Generate Rust: flatc --rust -o tools/flightrecorder/src/generated signals.fbs

namespace signals;

table MetricSample {
  name:string;
  value:double;
  tags:[string];
  timestamp_ns:long;
  sample_rate:double;
  source:string;
  // context_key is a 64-bit FNV-1a hash of (name, sorted tags). When non-zero,
  // the sidecar uses it to deduplicate context definitions: the first sample
  // with a given key carries full name+tags (context definition), subsequent
  // samples with the same key omit name+tags (context reference).
  context_key:ulong;
}

table LogEntry {
  content:[ubyte];
  status:string;
  tags:[string];
  hostname:string;
  timestamp_ns:long;
  source:string;
}

table MetricBatch {
  samples:[MetricSample];
}

table LogBatch {
  entries:[LogEntry];
}

table TraceStatEntry {
  service:string;
  name:string;
  resource:string;
  type:string;
  span_kind:string;
  http_status_code:uint;
  hits:ulong;
  errors:ulong;
  duration_ns:ulong;
  top_level_hits:ulong;
  ok_summary:[ubyte];
  error_summary:[ubyte];
  hostname:string;
  env:string;
  version:string;
  bucket_start_ns:long;
  bucket_duration_ns:long;
  timestamp_ns:long;
}

table TraceStatsBatch {
  entries:[TraceStatEntry];
}

table ConnectionEntry {
  pid:int;
  local_ip:string;
  local_port:int;
  local_container_id:string;
  remote_ip:string;
  remote_port:int;
  remote_container_id:string;
  family:uint;           // ConnectionFamily: 0=AF_INET, 1=AF_INET6
  conn_type:uint;        // ConnectionType: 0=TCP, 1=UDP
  direction:uint;        // ConnectionDirection: 0=unspecified, 1=incoming, 2=outgoing, 3=local
  net_ns:uint;
  bytes_sent:ulong;
  bytes_received:ulong;
  packets_sent:ulong;
  packets_received:ulong;
  retransmits:uint;
  rtt:uint;              // microseconds
  rtt_var:uint;          // microseconds
  intra_host:bool;
  dns_successful_responses:uint;
  dns_failed_responses:uint;
  dns_timeouts:uint;
  dns_success_latency_sum:ulong;
  dns_failure_latency_sum:ulong;
  tcp_established:uint;
  tcp_closed:uint;
  timestamp_ns:long;
}

table ConnectionBatch {
  entries:[ConnectionEntry];
}

union SignalPayload { MetricBatch, LogBatch, TraceStatsBatch, ConnectionBatch }

table SignalEnvelope {
  payload:SignalPayload;
}

root_type SignalEnvelope;
