"""IoT Agent package components specific to linux."""

load("@rules_pkg//pkg:deb.bzl", "pkg_deb")
load(
    "@rules_pkg//pkg:mappings.bzl",
    "pkg_filegroup",
)
load("@rules_pkg//pkg:rpm.bzl", "pkg_rpm")
load("@rules_pkg//pkg:tar.bzl", "pkg_tar")
load("//compliance:package_licenses.bzl", "package_licenses")

package(default_visibility = ["//packages:__subpackages__"])

# TODO: Add the iot-agent binary and component targets here, analogous to
# //packages/agent/dependencies:all_files and //packages/install_dir:embedded.
# The main build dependency from iot-agent.rb is 'datadog-iot-agent'.
pkg_filegroup(
    name = "iot_components",
    srcs = [
        # TODO: //packages/iot/dependencies:all_files
        # TODO: //packages/install_dir:embedded (iot-specific variant)
    ],
    prefix = "/opt/datadog-agent",
)

# This is an intermediate node to collect all dependencies so we can walk
# the aspect to gather OSS licenses.
pkg_filegroup(
    name = "everything",
    srcs = [
        ":iot_components",
    ],
)

# Gather licenses for all pieces of the distribution.
package_licenses(
    name = "license_files",
    src = ":everything",
)

pkg_filegroup(
    name = "whole_distro",
    srcs = [
        ":everything",
        ":license_files",
    ],
)

pkg_tar(
    name = "whole_distro_tar",
    srcs = [":whole_distro"],
    extension = "tar.xz",
    owner = "0.0",
)

pkg_deb(
    name = "debian",
    conflicts = ["datadog-agent"],
    data = ":whole_distro_tar",
    description = """Datadog IoT Agent
The Datadog IoT Agent is a lightweight process that monitors system
processes and services, and sends information back to your Datadog account.
.
This package installs and runs the advanced Agent daemon, which queues and
forwards metrics from your applications as well as system services.
.
See http://www.datadoghq.com/ for more information
""",
    homepage = "http://www.datadoghq.com",
    # epoch 1
    license = "Apache License Version 2.0",
    maintainer = "Datadog Packages <package@datadoghq.com>",
    package = "datadog-iot-agent",
    # Lifecycle scripts from omnibus/package-scripts/iot-agent-deb/
    postinst = "//omnibus/package-scripts/iot-agent-deb:postinst",
    postrm = "//omnibus/package-scripts/iot-agent-deb:postrm",
    preinst = "//omnibus/package-scripts/iot-agent-deb:preinst",
    prerm = "//omnibus/package-scripts/iot-agent-deb:prerm",
    priority = "extra",
    recommends = ["datadog-signing-keys (>= 1:1.4.0)"],
    section = "utils",
    # TODO: Stamp in pipeline: 1:7.77.0~devel.git.394.fe0d0bb.pipeline.95313893-1
    version = "7",
)

pkg_rpm(
    name = "rpm",
    package_name = "datadog-iot-agent",
    srcs = [":whole_distro"],
    conflicts = ["datadog-agent"],
    description = """Datadog IoT Agent
The Datadog IoT Agent is a lightweight process that monitors system
processes and services, and sends information back to your Datadog account.

This package installs and runs the advanced Agent daemon, which queues and
forwards metrics from your applications as well as system services.

See http://www.datadoghq.com/ for more information
""",
    epoch = "1",
    group = "System Environment/Daemons",
    license = "Apache License Version 2.0",
    # Lifecycle scripts from omnibus/package-scripts/iot-agent-rpm/
    post_scriptlet_file = "//omnibus/package-scripts/iot-agent-rpm:postinst",
    posttrans_scriptlet_file = "//omnibus/package-scripts/iot-agent-rpm:posttrans",
    postun_scriptlet_file = "//omnibus/package-scripts/iot-agent-rpm:postrm",
    pre_scriptlet_file = "//omnibus/package-scripts/iot-agent-rpm:preinst",
    preun_scriptlet_file = "//omnibus/package-scripts/iot-agent-rpm:prerm",
    # TODO: Stamp in pipeline: 7.77.0~devel.git.394.fe0d0bb.pipeline.95313893
    release = "1",
    # Packages needed during %pre scriptlet execution (from iot-agent.rb runtime_script_dependency).
    # coreutils and grep are common to RHEL and SUSE.
    # glibc-common and shadow-utils are RHEL-specific; SUSE uses glibc and shadow.
    # TODO: use select() when a RHEL vs SUSE constraint is defined.
    requires_contextual = {
        "pre": [
            "coreutils",
            "glibc-common",
            "grep",
            "shadow-utils",
        ],
    },
    summary = "Datadog IoT Agent",
    url = "http://www.datadoghq.com",
    version = "7",
)
