"""The dependencies of the agent.

Gathering spot for all the various dependencies which are shipped as part of the product.
This replaces datadog-agent-dependencies.rb.
"""

load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "pkg_filegroup")
load("//bazel/rules/dd_packaging:dd_collect_dependencies.bzl", "dd_collect_dependencies")

package(default_visibility = ["//packages:__subpackages__"])

pkg_filegroup(
    name = "all_files",
    srcs = [
        "//deps/cacerts:all_files",
        "//deps/jmxfetch:all_files",
        # Used for memory profiling with the `status py` agent subcommand
        # dependency 'pympler'
        "//deps/snmp_traps:all_files",
        # dependency 'datadog-agent-integrations-py3'
    ] + select({
        "@platforms//os:linux": [
            # dependency curl
            "@systemd//:all_files",
            ":collected_libs",
        ],
        "//conditions:default": [],
    }) + select({
        # if linux_target? and !heroku_target?
        "//packages/agent:linux_default": [
            "//deps/compile_policy:all_files",
            "//deps/security_agent_policies:all_files",
            # dependency datadog_agent_data_plane
            # This is really part of system-probe
            "@libpcap//:all_files",
        ],
        "//packages/agent:linux_fips": [
            "//deps/compile_policy:all_files",
            "//deps/security_agent_policies:all_files",
            "@libpcap//:all_files",
        ],
        "//packages/agent:linux_heroku": [],
        "//conditions:default": [],
    }) + select({
        "@platforms//os:windows": [
            "//deps/compile_policy:all_files",
            "//deps/security_agent_policies:all_files",
            "//packages/windows:all_files",
        ],
        "//conditions:default": [],
    }),
)

# _collected_libs serves as the main entry point for automatic collection of dependencies
# When a leaf depencency needs to be added to the agent package, adding it here
# will cause dd_collect_dependencies to also package all of its dependencies, and the
# files that were provided as to be packaged alongside.
# If the dependency is transitive, it does *not* need to be added here
dd_collect_dependencies(
    name = "_collected_libs",
    srcs = select({
        "@platforms//os:linux": ["@freetds//:tdsodbc_pkg"],
        "//conditions:default": [],
    }),
)

pkg_filegroup(
    name = "collected_libs",
    srcs = [":_collected_libs"],
    prefix = "embedded",
)

# Temporary during migration, to call from omnibus build.
pkg_install(
    name = "install",
    srcs = [
        ":all_files",
    ],
    destdir_flag = "//:install_dir",
)
