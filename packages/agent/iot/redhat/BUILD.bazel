"""Init scripts for the IoT agent on RedHat/SUSE-based distributions."""

load("@rules_pkg//pkg:install.bzl", "pkg_install")
load("@rules_pkg//pkg:mappings.bzl", "pkg_attributes", "pkg_filegroup")
load("//bazel/rules:dd_agent_expand_template.bzl", "dd_agent_expand_template")

package(default_visibility = ["//packages:__subpackages__"])

dd_agent_expand_template(
    name = "upstart_redhat_conf_gen",
    out = "etc/init/datadog-agent.conf",
    attributes = pkg_attributes(mode = "0644"),
    template = "upstart_redhat.conf.in",
)

# RedHat/SUSE place the systemd unit under usr/lib/ rather than lib/.
dd_agent_expand_template(
    name = "systemd_gen",
    out = "usr/lib/systemd/system/datadog-agent.service",
    attributes = pkg_attributes(mode = "0644"),
    template = "//packages/agent/iot:systemd.service.in",
)

pkg_filegroup(
    name = "all_files",
    srcs = [
        ":systemd_gen",
        ":upstart_redhat_conf_gen",
    ],
)

pkg_install(
    name = "install",
    srcs = [":all_files"],
)

# SUSE uses the same systemd unit path as RedHat but does not ship upstart.
pkg_install(
    name = "systemd_install",
    srcs = [":systemd_gen"],
)
