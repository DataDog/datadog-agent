"""Package to export dda built binaries into bazel build.

This package will only continue to exist for the duration of the migration.
It allows us to refer to binaries that are not yet built with bazel,
and import them into a build graph so we can include them in packages.

Most targets must be tagged manual to avoid ... expansion. The build
file is invalid unti the agent is built.
"""

package(default_visibility = ["//packages:__subpackages__"])

filegroup(
    name = "bin_files",
    srcs = glob(
        ["agent/**"],
        exclude = [
            "agent/dist/datadog.yaml",
            "agent/dist/conf.d/**",
        ],
    ),
    tags = ["manual"],
)

filegroup(
    name = "conf_d",
    srcs = glob(["agent/dist/conf.d/**"]),
    tags = ["manual"],
)

filegroup(
    name = "datadog_yaml",
    srcs = ["agent/dist/datadog.yaml"],
    tags = ["manual"],
)
