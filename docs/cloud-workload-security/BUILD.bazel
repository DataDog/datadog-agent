load("@bazel_lib//lib:run_binary.bzl", "run_binary")
load("@bazel_lib//lib:write_source_files.bzl", "write_source_file", "write_source_files")

package(default_visibility = ["//visibility:private"])

# These JSON files are co-generated by //pkg/security/generators/accessors when
# producing accessors_<platform>.go (see //pkg/security/secl/model:BUILD.bazel
# `accessors(...)` calls). The diff_test produced by write_source_file checks
# that the checked-in JSON matches what the Bazel action produces.
[
    write_source_file(
        name = "secl_{}".format(variant),
        in_file = "//pkg/security/secl/model:accessors_{}/secl_{}.json".format(
            "unix" if variant == "linux" else "windows",
            variant,
        ),
        out_file = "secl_{}.json".format(variant),
    )
    for variant in [
        "linux",
        "windows",
    ]
]

# Markdown doc generation: renders Jinja2 templates using the committed JSON
# schemas as inputs. Platform-neutral — reads committed source files so it runs
# on any OS without needing the Linux-only Go generator.
run_binary(
    name = "backend_linux_doc_gen",
    srcs = ["backend_linux.schema.json"],
    outs = ["backend_linux_doc_gen/backend_linux.md"],
    args = [
        "$(execpath backend_linux.schema.json)",
        "$(execpath backend_linux_doc_gen/backend_linux.md)",
        "backend_linux.md",
    ],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    tool = "//tasks/libs/cws:backend_doc_gen",
)

run_binary(
    name = "backend_windows_doc_gen",
    srcs = ["backend_windows.schema.json"],
    outs = ["backend_windows_doc_gen/backend_windows.md"],
    args = [
        "$(execpath backend_windows.schema.json)",
        "$(execpath backend_windows_doc_gen/backend_windows.md)",
        "backend_windows.md",
    ],
    tool = "//tasks/libs/cws:backend_doc_gen",
)

run_binary(
    name = "secl_linux_doc_gen",
    srcs = ["secl_linux.json"],
    outs = ["secl_linux_doc_gen/linux_expressions.md"],
    args = [
        "$(execpath secl_linux.json)",
        "$(execpath secl_linux_doc_gen/linux_expressions.md)",
        "linux_expressions.md",
    ],
    target_compatible_with = select({
        "@platforms//os:windows": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    tool = "//tasks/libs/cws:secl_doc_gen",
)

run_binary(
    name = "secl_windows_doc_gen",
    srcs = ["secl_windows.json"],
    outs = ["secl_windows_doc_gen/windows_expressions.md"],
    args = [
        "$(execpath secl_windows.json)",
        "$(execpath secl_windows_doc_gen/windows_expressions.md)",
        "windows_expressions.md",
    ],
    tool = "//tasks/libs/cws:secl_doc_gen",
)

# Umbrella target: updates all four CWS markdown docs in one shot using the
# committed JSON schemas as inputs. Platform-neutral — can run on any OS.
# The JSON schemas themselves are updated by backend_linux_schema /
# backend_windows_schema (Linux-only), called from cws_go_generate.
write_source_files(
    name = "cws_docs",
    files = {
        "backend_linux.md": ":backend_linux_doc_gen/backend_linux.md",
        "backend_windows.md": ":backend_windows_doc_gen/backend_windows.md",
        "linux_expressions.md": ":secl_linux_doc_gen/linux_expressions.md",
        "windows_expressions.md": ":secl_windows_doc_gen/windows_expressions.md",
    },
    visibility = ["//visibility:public"],
)
