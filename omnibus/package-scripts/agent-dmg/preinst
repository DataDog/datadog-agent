#!/bin/sh
#
# Perform necessary datadog-agent setup steps before package is installed.
#

INSTALL_DIR=/opt/datadog-agent

# macOS deletes /var/log on OS upgrades, so the real log folder is
# /opt/datadog-agent/logs with a symlink from /var/log/datadog.
LOG_DIR=/opt/datadog-agent/logs
SYSTEM_LOG_DIR=/var/log/datadog
SYSTEM_LOG_BASE_DIR=/var/log

CONF_DIR="$INSTALL_DIR/etc"

mkdir -p $LOG_DIR
chmod 750 $LOG_DIR

LOG_FILE="$LOG_DIR/preinstall.log"
exec > $LOG_FILE 2>&1

DDAGENT_USER="_dd-agent"

harden_ddagent_user() {
    # Enforce least-privilege properties regardless of how the account was
    # originally created (previous install, MDM pre-provisioning, manual
    # creation). This runs on every install/upgrade — every upgrade is a
    # hardening pass.

    # Core identity: no shell, no home, hidden, daemon group
    dscl . -create /Users/$DDAGENT_USER UserShell /usr/bin/false
    dscl . -create /Users/$DDAGENT_USER NFSHomeDirectory /var/empty
    dscl . -create /Users/$DDAGENT_USER IsHidden 1
    dscl . -create /Users/$DDAGENT_USER PrimaryGroupID 1

    # Lock the account password. The '*' marker is the standard Unix convention
    # for "no valid password" (same as /etc/shadow on Linux). This prevents
    # authentication via PAM-based services that might not check the login shell
    # (e.g., screen sharing, VPN agents, custom PAM modules).
    dscl . -create /Users/$DDAGENT_USER Password '*'

    # Remove all authentication mechanisms (password hashes, Kerberos
    # principals, smart card bindings). This is what Apple does for its own
    # daemon accounts (_www, _sshd, _spotlight). It means there is no
    # credential to brute-force or extract from Directory Services.
    dscl . -delete /Users/$DDAGENT_USER AuthenticationAuthority 2>/dev/null || true

    # Strip privileged supplementary group memberships. PrimaryGroupID=1
    # (daemon) only sets the primary group — it does not remove supplementary
    # memberships. If someone pre-created _dd-agent in the admin group (which
    # grants sudo on macOS), that's a privilege escalation path.
    for group in admin wheel staff; do
        if dseditgroup -o checkmember -m "$DDAGENT_USER" "$group" >/dev/null 2>&1; then
            echo "Removing $DDAGENT_USER from group $group"
            dseditgroup -o edit -d "$DDAGENT_USER" "$group"
        fi
    done

    # UID sanity check: warn if outside the system range but don't change it
    # (changing UID would orphan all files owned by the old UID).
    local existing_uid
    existing_uid=$(id -u "$DDAGENT_USER")
    if [ "$existing_uid" -ge 500 ]; then
        echo "WARNING: $DDAGENT_USER has UID $existing_uid (interactive range >=500). UID is preserved to avoid breaking file ownership, but this is non-standard for a daemon account."
    fi

    # Secure Token check: daemon accounts should never have Secure Token
    # (affects FileVault recovery and bootstrap token flows). We can't revoke
    # it programmatically without MDM, but we log a warning so admins can
    # investigate.
    if sysadminctl -secureTokenStatus "$DDAGENT_USER" 2>&1 | grep -q "ENABLED"; then
        echo "WARNING: $DDAGENT_USER has Secure Token enabled. Daemon accounts should not hold Secure Token. This may have been granted by MDM bootstrap token flows. Contact your MDM administrator to revoke it."
    fi
}

create_ddagent_user() {
    if id -u "$DDAGENT_USER" >/dev/null 2>&1; then
        echo "User $DDAGENT_USER already exists, enforcing security properties"
        harden_ddagent_user
        return 0
    fi
    echo "Creating $DDAGENT_USER system user..."
    local uid=450
    while dscl . -list /Users UniqueID | awk '{print $2}' | grep -qx "$uid"; do
        uid=$((uid + 1))
    done
    if [ "$uid" -ge 500 ]; then
        echo "No free UID available in range 450-499 for $DDAGENT_USER"
        exit 1
    fi
    dscl . -create /Users/$DDAGENT_USER
    dscl . -create /Users/$DDAGENT_USER RealName "Datadog Agent"
    dscl . -create /Users/$DDAGENT_USER UniqueID "$uid"
    harden_ddagent_user
    echo "Created $DDAGENT_USER (UID $uid)"
}

create_ddagent_user

# Log folder migration
if [ -d $SYSTEM_LOG_DIR ]; then
    if [ -L $SYSTEM_LOG_DIR ]; then
        echo "Log symlink already in place."
    else
        echo "Migrating old log folder to new location."
        cp -Rf $SYSTEM_LOG_DIR/* $LOG_DIR
        rm -rf $SYSTEM_LOG_DIR
        ln -s $LOG_DIR $SYSTEM_LOG_DIR
    fi
else
    mkdir -p $SYSTEM_LOG_BASE_DIR
    ln -s $LOG_DIR $SYSTEM_LOG_DIR
fi

# Stop running services and save config if an existing installation is present
if [ -e "$CONF_DIR/datadog.yaml" ]; then
    echo "# Existing installation detected"
    datadog-agent version || true

    echo '# Stopping running services'
    launchctl bootout system/com.datadoghq.agent 2>/dev/null || true
    launchctl bootout system/com.datadoghq.sysprobe 2>/dev/null || true
    rm -f /Library/LaunchDaemons/com.datadoghq.sysprobe.plist

    # Stop GUI for all logged-in users
    for logged_user in $(who | awk '{print $1}' | sort -u); do
        logged_uid=$(id -u "$logged_user" 2>/dev/null) || continue
        launchctl bootout "gui/$logged_uid/com.datadoghq.gui" 2>/dev/null || true
    done
    kill $(pgrep -f 'Datadog Agent.app') 2>/dev/null || true

    # Save existing config for restoration in postinst.
    # All install-time staging data lives under a single root-only directory.
    INSTALL_STAGING_DIR="/private/var/root/datadog-install"
    SAVED_CONF_DIR="$INSTALL_STAGING_DIR/saved-conf"
    rm -rvf "$SAVED_CONF_DIR"
    mkdir -vp "$SAVED_CONF_DIR/conf.d"
    mkdir -vp "$SAVED_CONF_DIR/checks.d"
    chmod 700 "$INSTALL_STAGING_DIR"
    cp -vf $CONF_DIR/datadog.yaml "$SAVED_CONF_DIR/"
    cp -vfR $CONF_DIR/conf.d/* "$SAVED_CONF_DIR/conf.d" 2>/dev/null || true
    find "$SAVED_CONF_DIR/conf.d" '(' -name '*.yaml.example' -o -name '*.yaml.default' ')' -delete
    cp -vfR $CONF_DIR/checks.d/* "$SAVED_CONF_DIR/checks.d" 2>/dev/null || true
fi

echo '# Deleting old datadog-agent link'
rm -vf /usr/local/bin/datadog-agent

echo '# Deleting old datadog-agent files'
rm -rf $INSTALL_DIR/agent || true
rm -rf $INSTALL_DIR/checks.d || true

exit 0
