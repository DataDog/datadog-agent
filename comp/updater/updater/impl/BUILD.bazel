load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = ["updater.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/updater/updater/impl",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname",
        "//comp/core/log/def",
        "//comp/def",
        "//comp/remote-config/rcservice/def",
        "//comp/updater/updater/def",
        "//pkg/fleet/daemon",
        "//pkg/util/option",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = ["updater_test.go"],
    embed = [":impl"],
    deps = [
        "//comp/def",
        "//comp/remote-config/rcservice/def",
        "//pkg/util/option",
        "@com_github_stretchr_testify//assert",
    ],
)
