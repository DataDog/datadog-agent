load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "pclntab",
    srcs = ["pclntab.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/host-profiler/symboluploader/pclntab",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//pkg/util/safeelf",
            "//vendor/go.opentelemetry.io/ebpf-profiler/libpf",
            "//vendor/go.opentelemetry.io/ebpf-profiler/libpf/pfelf",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/util/safeelf",
            "//vendor/go.opentelemetry.io/ebpf-profiler/libpf",
            "//vendor/go.opentelemetry.io/ebpf-profiler/libpf/pfelf",
        ],
        "//conditions:default": [],
