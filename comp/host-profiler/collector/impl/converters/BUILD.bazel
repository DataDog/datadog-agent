        "converter_table_test.go",
        "converters_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":converters"],
    gotags = ["test"],
    deps = [
        "//comp/host-profiler/version",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
        "//vendor/go.opentelemetry.io/collector/confmap",
        "//vendor/go.opentelemetry.io/collector/confmap/xconfmap",
        "//vendor/go.uber.org/zap",
        "//vendor/go.uber.org/zap/zapcore",
        "//vendor/go.uber.org/zap/zaptest/observer",
        "//vendor/go.yaml.in/yaml/v3:yaml",
    ],
