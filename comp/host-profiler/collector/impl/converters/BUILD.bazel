load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "converters",
    srcs = [
        "converter_without_agent.go",
        "converters.go",
        "prometheus.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/host-profiler/collector/impl/converters",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/host-profiler/symboluploader/cgroup",
        "//comp/host-profiler/version",
        "//pkg/config/utils",
        "//pkg/util/confmaputils",
        "//pkg/util/hostport",
        "@io_opentelemetry_go_collector_confmap//:confmap",
        "@io_opentelemetry_go_collector_confmap_xconfmap//:xconfmap",
        "@org_uber_go_zap_exp//zapslog",
    ],
)

dd_agent_go_test(
    name = "converters_test",
    srcs = [
        "converter_table_test.go",
        "converters_test.go",
        "prometheus_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":converters"],
    deps = [
        "//comp/host-profiler/version",
        "//pkg/util/confmaputils",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@in_yaml_go_yaml_v3//:yaml",
        "@io_opentelemetry_go_collector_confmap//:confmap",
        "@io_opentelemetry_go_collector_confmap_xconfmap//:xconfmap",
        "@org_uber_go_zap//:zap",
        "@org_uber_go_zap//zapcore",
        "@org_uber_go_zap//zaptest/observer",
    ],
)
