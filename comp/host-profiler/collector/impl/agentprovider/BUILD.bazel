    importpath = "github.com/DataDog/datadog-agent/comp/host-profiler/collector/impl/agentprovider",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/host-profiler/collector/impl/extensions/hpflareextension",
