load("@protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_go//go:def.bzl", "go_library", "go_test")
load("@rules_go//proto:def.bzl", "go_proto_library")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

# gazelle:proto_strip_import_prefix /comp/forwarder/defaultforwarder/internal/retry
proto_library(
    name = "retry_proto",
    srcs = ["HttpTransactionProto.proto"],
    strip_import_prefix = "/comp/forwarder/defaultforwarder/internal/retry",
    visibility = ["//comp/forwarder/defaultforwarder:__subpackages__"],
)

go_proto_library(
    name = "retry_go_proto",
    importpath = "github.com/DataDog/datadog-agent/comp/forwarder/defaultforwarder/internal/retry",
    proto = ":retry_proto",
    visibility = [
        "//comp/forwarder/defaultforwarder:__subpackages__",
        "@com_github_datadog_datadog_agent_comp_forwarder_defaultforwarder//:__subpackages__",
    ],
)

write_pb_go(
    name = "write_pb_go",
    srcs = {
        ":retry_go_proto": [
            "HttpTransactionProto.pb.go",
        ],
    },
)

go_library(
    name = "retry",
    srcs = [
        "disk_usage_limit.go",
        "docs.go",
        "file_removal_policy.go",
        "http_transactions_serializer.go",
        "on_disk_retry_queue.go",
        "point_count_telemetry.go",
        "queue_duration_capacity.go",
        "telemetry.go",
        "test_common.go",
        "time_interval_accumulator.go",
        "transaction_retry_queue.go",
    ],
    embed = [":retry_go_proto"],
    importpath = "github.com/DataDog/datadog-agent/comp/forwarder/defaultforwarder/internal/retry",
    visibility = [
        "//comp/forwarder/defaultforwarder:__subpackages__",
        "@com_github_datadog_datadog_agent_comp_forwarder_defaultforwarder//:__subpackages__",
    ],
    deps = [
        "//comp/core/log/def",
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/impl",
        "//comp/forwarder/defaultforwarder/resolver",
        "//comp/forwarder/defaultforwarder/transaction",
        "//pkg/config/utils",
        "//pkg/util/filesystem",
        "@com_github_hashicorp_go_multierror//:go-multierror",
        "@org_golang_google_protobuf//proto",
    ],
)

go_test(
    name = "retry_test",
    srcs = [
        "disk_usage_limit_test.go",
        "file_removal_policy_test.go",
        "http_transactions_serializer_test.go",
        "on_disk_retry_queue_test.go",
        "queue_duration_capacity_test.go",
        "time_interval_accumulator_test.go",
        "transaction_retry_queue_test.go",
    ],
    embed = [":retry"],
    gotags = ["test"],
    deps = [
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/forwarder/defaultforwarder/resolver",
        "//comp/forwarder/defaultforwarder/transaction",
        "//pkg/config/utils",
        "//pkg/util/filesystem",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_golang_google_protobuf//proto",
    ],
)
