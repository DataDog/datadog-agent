load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "transaction",
    srcs = [
        "bytes_payload.go",
        "endpoint.go",
        "intake_offset.go",
        "sort_by_created_time_and_priority.go",
        "transaction.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/forwarder/defaultforwarder/transaction",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/secrets/def",
        "//comp/core/telemetry/impl",
        "//pkg/util/scrubber",
        "@com_github_benbjohnson_clock//:clock",
    ],
)

dd_agent_go_test(
    name = "transaction_test",
    srcs = [
        "intake_offset_test.go",
        "transaction_test.go",
    ],
    embed = [":transaction"],
    deps = [
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/secrets/mock",
        "//pkg/config/mock",
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
