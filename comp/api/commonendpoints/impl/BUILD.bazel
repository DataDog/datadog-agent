load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "impl",
    srcs = ["common_endpoints.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/api/commonendpoints/impl",
    visibility = ["//visibility:public"],
    deps = [
        "//cmd/agent/common/signals",
        "//comp/api/api/def",
        "//comp/core/hostname/hostnameinterface/def",
        "//pkg/api/version",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = ["common_endpoints_test.go"],
    embed = [":impl"],
    deps = [
        "//cmd/agent/common/signals",
        "//comp/core/hostname/hostnameimpl",
        "@com_github_stretchr_testify//require",
    ],
)
