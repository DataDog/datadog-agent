load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "observability",
    srcs = [
        "logging.go",
        "telemetry.go",
        "utils.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/api/api/apiimpl/observability",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/telemetry/def",
        "//pkg/util/log",
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_urfave_negroni_v3//:negroni",
    ],
)

dd_agent_go_test(
    name = "observability_test",
    srcs = [
        "logging_test.go",
        "telemetry_test.go",
        "utils_test.go",
    ],
    embed = [":observability"],
    deps = [
        "//comp/core/telemetry/def",
        "//comp/core/telemetry/mock",
        "//pkg/util/fxutil",
        "@com_github_benbjohnson_clock//:clock",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
