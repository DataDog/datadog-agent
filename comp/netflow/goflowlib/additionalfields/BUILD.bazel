load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "additionalfields",
    srcs = ["netflow.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/netflow/goflowlib/additionalfields",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/netflow/common",
        "//comp/netflow/config/def",
        "@com_github_netsampler_goflow2//decoders/netflow",
        "@com_github_netsampler_goflow2//producer",
    ],
)

dd_agent_go_test(
    name = "additionalfields_test",
    srcs = ["netflow_test.go"],
    embed = [":additionalfields"],
    deps = [
        "//comp/netflow/common",
        "//comp/netflow/config/def",
        "@com_github_netsampler_goflow2//decoders/netflow",
        "@com_github_stretchr_testify//assert",
    ],
)
