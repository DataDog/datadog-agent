load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "portrollup",
    srcs = ["portrollup.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/netflow/portrollup",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["//comp/netflow/common"],
)

dd_agent_go_test(
    name = "portrollup_test",
    srcs = ["portrollup_test.go"],
    embed = [":portrollup"],
    deps = ["@com_github_stretchr_testify//assert"],
)
