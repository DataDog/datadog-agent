load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "def",
    srcs = [
        "component.go",
        "config.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/netflow/config/def",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/netflow/common",
        "//pkg/config/structure",
        "//pkg/snmp/utils",
    ],
)

dd_agent_go_test(
    name = "def_test",
    srcs = ["config_test.go"],
    embed = [":def"],
    deps = [
        "//comp/core/log/mock",
        "//comp/netflow/common",
        "//pkg/config/mock",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
