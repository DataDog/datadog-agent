load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "healthplatform",
    srcs = [
        "bundle.go",
        "diagnose.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/healthplatform",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/diagnose/def",
        "//comp/core/log/def",
        "//comp/healthplatform/egress/def",
        "//comp/healthplatform/egress/fx",
        "//comp/healthplatform/forwarder/fx",
        "//comp/healthplatform/issueregistry/def",
        "//comp/healthplatform/issueregistry/fx",
        "//comp/healthplatform/issues/admissionprobe",
        "//comp/healthplatform/issues/dockerpermissions",
        "//comp/healthplatform/issues/invalidconfig",
        "//comp/healthplatform/issues/invalidsysprobeconfig",
        "//comp/healthplatform/issues/rofspermissions",
        "//comp/healthplatform/runner/def",
        "//comp/healthplatform/runner/fx",
        "//comp/healthplatform/scheduler/def",
        "//comp/healthplatform/scheduler/fx",
        "//comp/healthplatform/store/def",
        "//comp/healthplatform/store/fx",
        "//pkg/util/fxutil",
        "@com_github_datadog_agent_payload_v5//healthplatform",
        "@org_uber_go_fx//:fx",
    ],
)

dd_agent_go_test(
    name = "healthplatform_test",
    srcs = [
        "bundle_test.go",
        "invalidconfig_integration_test.go",
    ],
    embed = [":healthplatform"],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname/hostnameinterface/mock",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/telemetry/mock",
        "//comp/healthplatform/issues",
        "//comp/healthplatform/issues/invalidconfig",
        "//comp/healthplatform/runner/def",
        "//comp/healthplatform/scheduler/def",
        "//comp/healthplatform/store/def",
        "//pkg/config/schema",
        "//pkg/util/fxutil",
        "//test/fakeintake/client",
        "//test/fakeintake/server",
        "@com_github_datadog_agent_payload_v5//healthplatform",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_fx//:fx",
    ],
)
