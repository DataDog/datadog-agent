go_test(
    name = "impl_test",
    srcs = ["forwarder_test.go"],
    embed = [":impl"],
    gotags = ["test"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/mock",
        "//pkg/proto/datadog/healthplatform:healthplatform_go_proto",
        "//pkg/version",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
