load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "impl",
    srcs = ["forwarder.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/healthplatform/forwarder/impl",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
