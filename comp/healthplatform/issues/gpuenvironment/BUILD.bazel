load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "gpuenvironment",
    srcs = ["gpu_environment_issue.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/healthplatform/issues/gpuenvironment",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "@com_github_datadog_agent_payload_v5//healthplatform",
        "@org_golang_google_protobuf//types/known/structpb",
    ],
)

dd_agent_go_test(
    name = "gpuenvironment_test",
    srcs = ["gpu_environment_issue_test.go"],
    embed = [":gpuenvironment"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
