load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = ["registry.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/healthplatform/issueregistry/impl",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname/hostnameinterface/def",
        "//comp/core/sysprobeconfig/def",
        "//comp/core/workloadmeta/def",
        "//comp/healthplatform/issueregistry/def",
        "//comp/healthplatform/issues",
        "//comp/healthplatform/runner/def",
        "//comp/healthplatform/selfident",
        "//pkg/util/option",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = ["registry_test.go"],
    embed = [":impl"],
    deps = [
        "//comp/core/config",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
