load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "impl",
    srcs = [
        "autoconfigure.go",
        "converter.go",
        "coreconfig.go",
        "extensions.go",
        "infraattributes.go",
        "opamp.go",
        "prometheus.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/otelcol/converter/impl",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname/hostnameinterface",
        "//comp/core/log/def",
        "//comp/otelcol/converter/def",
        "//pkg/util/log/zap",
        "@io_opentelemetry_go_collector_confmap//:confmap",
        "@org_uber_go_zap//:zap",
    ],
)

go_test(
    name = "impl_test",
    srcs = [
        "converter_test.go",
        "opamp_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":impl"],
    gotags = ["test"],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname/hostnameinterface",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_opentelemetry_go_collector_confmap//:confmap",
        "@io_opentelemetry_go_collector_confmap_provider_envprovider//:envprovider",
        "@io_opentelemetry_go_collector_confmap_provider_fileprovider//:fileprovider",
        "@io_opentelemetry_go_collector_confmap_provider_httpprovider//:httpprovider",
        "@io_opentelemetry_go_collector_confmap_provider_httpsprovider//:httpsprovider",
        "@io_opentelemetry_go_collector_confmap_provider_yamlprovider//:yamlprovider",
        "@org_uber_go_zap//:zap",
        "@org_uber_go_zap//zapcore",
        "@org_uber_go_zap//zaptest/observer",
    ],
)
