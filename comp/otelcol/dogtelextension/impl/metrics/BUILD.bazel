load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "metrics",
    srcs = ["metrics.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/otelcol/dogtelextension/impl/metrics",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/metrics",
        "//pkg/tagset",
        "@io_opentelemetry_go_collector_component//:component",
    ],
)

go_test(
    name = "metrics_test",
    srcs = ["metrics_test.go"],
    embed = [":metrics"],
    gotags = ["test"],
    deps = [
        "//pkg/metrics",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@io_opentelemetry_go_collector_component//:component",
    ],
)
