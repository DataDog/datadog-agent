load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "remote-config",
    srcs = ["bundle.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/remote-config",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/remote-config/rcclient/fx",
        "//comp/remote-config/rcstatus/fx",
        "//pkg/util/fxutil",
    ],
)

dd_agent_go_test(
    name = "remote-config_test",
    srcs = ["bundle_test.go"],
    embed = [":remote-config"],
    deps = [
        "//comp/core",
        "//comp/core/ipc/def",
        "//comp/core/ipc/mock",
        "//comp/core/settings/mock",
        "//pkg/util/fxutil",
        "@org_uber_go_fx//:fx",
    ],
