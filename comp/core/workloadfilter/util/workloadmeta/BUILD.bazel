load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "workloadmeta",
    srcs = ["create.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/core/workloadfilter/util/workloadmeta",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadmeta/def",
        "//pkg/proto/pbgo/core",
        "//pkg/util/kubernetes",
    ],
)

dd_agent_go_test(
    name = "workloadmeta_test",
    srcs = ["create_test.go"],
    embed = [":workloadmeta"],
    deps = [
        "//comp/core/workloadmeta/def",
        "//pkg/proto/pbgo/core",
        "@com_github_stretchr_testify//assert",
    ],
)
