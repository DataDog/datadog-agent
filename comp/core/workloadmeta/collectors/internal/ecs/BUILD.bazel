        "daemon_parser.go",
        "ecs.go",
        "ecs_nop.go",
        "sidecar_parser.go",
        "stub.go",
        "v1parser.go",
        "v2parser.go",
        "v4parser.go",
        "worker.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/core/workloadmeta/collectors/internal/ecs",
    visibility = ["//comp/core/workloadmeta/collectors:__subpackages__"],
    deps = [
        "//comp/core/config",
        "//comp/core/workloadmeta/collectors/util",
        "//comp/core/workloadmeta/def",
        "//pkg/config/env",
        "//pkg/errors",
        "//pkg/util/ecs",
