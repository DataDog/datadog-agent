load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "containerd",
    srcs = [
        "container_builder.go",
        "containerd.go",
        "containerd_nop.go",
        "event_builder.go",
        "image.go",
        "image_sbom_stub.go",
        "image_sbom_trivy.go",
        "network_linux.go",
        "network_stub.go",
        "stub.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/core/workloadmeta/collectors/internal/containerd",
    visibility = ["//comp/core/workloadmeta/collectors:__subpackages__"],
    deps = [
        "//comp/core/config",
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadmeta/collectors/sbomutil",
        "//comp/core/workloadmeta/collectors/util",
        "//comp/core/workloadmeta/def",
        "//pkg/config/env",
        "//pkg/errors",
        "//pkg/sbom",
        "//pkg/sbom/collectors",
        "//pkg/sbom/collectors/containerd",
        "//pkg/sbom/scanner",
        "//pkg/status/health",
        "//pkg/util/containerd",
        "//pkg/util/containers",
        "//pkg/util/log",
        "//pkg/util/pointer",
        "@com_github_containerd_containerd_api//events",
        "@com_github_containerd_containerd_v2//client",
        "@com_github_containerd_containerd_v2//core/content",
        "@com_github_containerd_containerd_v2//core/events",
        "@com_github_containerd_containerd_v2//core/images",
        "@com_github_containerd_containerd_v2//core/runtime/restart",
        "@com_github_containerd_containerd_v2//pkg/namespaces",
        "@com_github_containerd_errdefs//:errdefs",
        "@com_github_opencontainers_image_spec//specs-go/v1:specs-go",
        "@org_golang_google_protobuf//proto",
        "@org_uber_go_fx//:fx",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/config/setup",
            "//pkg/util/system",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/config/setup",
            "//pkg/util/system",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "containerd_test",
    srcs = [
        "container_builder_test.go",
        "containerd_test.go",
        "event_builder_test.go",
        "image_test.go",
    ],
    embed = [":containerd"],
    include_default = False,
    tag_sets = ["containerd"],
    target_compatible_with = ["@platforms//os:linux"],  # keep
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/workloadfilter/fx-mock",
        "//comp/core/workloadmeta/def",
        "//comp/core/workloadmeta/fx-mock",
        "//comp/core/workloadmeta/mock",
        "//pkg/config/mock",
        "//pkg/util/containerd/fake",
        "//pkg/util/fxutil",
        "@com_github_containerd_containerd_api//events",
        "@com_github_containerd_containerd_v2//client",
        "@com_github_containerd_containerd_v2//core/containers",
        "@com_github_containerd_containerd_v2//core/events",
        "@com_github_containerd_containerd_v2//pkg/cio",
        "@com_github_containerd_containerd_v2//pkg/oci",
        "@com_github_gogo_protobuf//types",
        "@com_github_opencontainers_go_digest//:go-digest",
        "@com_github_opencontainers_image_spec//specs-go/v1:specs-go",
        "@com_github_opencontainers_runtime_spec//specs-go",
        "@com_github_stretchr_testify//assert",
        "@org_golang_google_protobuf//proto",
        "@org_uber_go_fx//:fx",
    ],
)
