load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "discoverer",
    srcs = [
        "discovery_json.go",
        "types.go",
        "worker.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/core/autodiscovery/discoverer",
    tags = ["manual"],  # keep — listeners is not Bazel-built (see autodiscovery/impl)
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//pkg/util/log",
        "//pkg/util/tmplvar",
        "@//comp/core/autodiscovery/listeners",
        "@io_k8s_apimachinery//pkg/util/wait",
        "@io_k8s_client_go//util/workqueue",
    ],
)

go_test(
    name = "discoverer_test",
    srcs = [
        "discovery_json_test.go",
        "fake_service_test.go",
        "worker_test.go",
    ],
    embed = [":discoverer"],
    gotags = ["test"],
    tags = ["manual"],  # keep — same reason as the library
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/workloadfilter/def",
        "//comp/core/workloadmeta/def",
        "@//comp/core/autodiscovery/listeners",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
        "@org_uber_go_atomic//:atomic",
    ],
)
