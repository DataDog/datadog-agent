load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "networkpath",
    srcs = ["provider.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/core/autodiscovery/providers/networkpath",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/integration",
        "//comp/core/autodiscovery/providers/names",
        "//comp/core/autodiscovery/providers/types",
