load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "types",
    srcs = [
        "consts.go",
        "prometheus.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/core/autodiscovery/common/types",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["//pkg/util/log"],
)

dd_agent_go_test(
    name = "types_test",
    srcs = ["prometheus_test.go"],
    embed = [":types"],
    deps = ["@com_github_stretchr_testify//assert"],
)
