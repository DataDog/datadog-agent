load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = ["configstream.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/core/configstream/impl",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/configstream/def",
        "//comp/core/log/def",
        "//comp/core/telemetry/def",
        "//comp/def",
        "//pkg/config/model",
        "//pkg/proto/pbgo/core",
        "@com_github_google_uuid//:uuid",
        "@org_golang_google_protobuf//types/known/structpb",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = ["configstream_test.go"],
    embed = [":impl"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/telemetry/impl/noops",
        "//comp/def",
        "//pkg/config/mock",
        "//pkg/config/model",
        "//pkg/proto/pbgo/core",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
