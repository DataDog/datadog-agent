# See root BUILD.bazel: gazelle:exclude comp/anomalydetection/logssource/impl
go_library(
    name = "fx",
    srcs = ["fx_noop.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/anomalydetection/logssource/fx",
    visibility = ["//visibility:public"],
    deps = [
        "@org_uber_go_fx//:fx",
        "//pkg/util/fxutil",
    ],
)
