    name = "fx",
    srcs = ["fx_noop.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/anomalydetection/logssource/fx",
    visibility = ["//visibility:public"],
    deps = [
        "//pkg/util/fxutil",
        "@org_uber_go_fx//:fx",
    ],
)
