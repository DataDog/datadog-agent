load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "config",
    srcs = ["config.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/anomalydetection/config",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["//pkg/config/model"],
)

dd_agent_go_test(
    name = "config_test",
    srcs = ["config_test.go"],
    embed = [":config"],
    deps = [
        "//comp/core/config",
        "@com_github_stretchr_testify//assert",
    ],
)
