load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = [
        "aptsigning.go",
        "packagesigning.go",
        "readgpg.go",
        "rpmsigning.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/metadata/packagesigning/impl",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/api/api/def",
        "//comp/core/config",
        "//comp/core/flare/types",
        "//comp/core/hostname/hostnameinterface/def",
        "//comp/core/log/def",
        "//comp/metadata/internal/util",
        "//comp/metadata/packagesigning/def",
        "//comp/metadata/packagesigning/utils",
        "//comp/metadata/runner/def",
        "//pkg/serializer",
        "//pkg/serializer/marshaler",
        "//pkg/util/http",
        "//pkg/util/installinfo",
        "//pkg/util/uuid",
        "@com_github_protonmail_go_crypto//openpgp",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = [
        "atpsigning_test.go",
        "packagesigning_test.go",
        "readgpg_test.go",
        "rpmsigning_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":impl"],
    deps = select({
        "@rules_go//go/platform:android": [
            "//comp/core/config",
            "//comp/core/hostname/hostnameimpl",
            "//comp/core/hostname/hostnameinterface/def",
            "//comp/core/log/def",
            "//comp/core/log/mock",
            "//comp/metadata/packagesigning/utils",
            "//pkg/serializer",
            "//pkg/serializer/mocks",
            "//pkg/util/fxutil",
            "@com_github_stretchr_testify//assert",
            "@org_uber_go_fx//:fx",
        ],
        "@rules_go//go/platform:linux": [
            "//comp/core/config",
            "//comp/core/hostname/hostnameimpl",
            "//comp/core/hostname/hostnameinterface/def",
            "//comp/core/log/def",
            "//comp/core/log/mock",
            "//comp/metadata/packagesigning/utils",
            "//pkg/serializer",
            "//pkg/serializer/mocks",
            "//pkg/util/fxutil",
            "@com_github_stretchr_testify//assert",
            "@org_uber_go_fx//:fx",
        ],
        "//conditions:default": [],
    }),
)
