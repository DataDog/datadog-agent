load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "util",
    srcs = [
        "inventory_enabled.go",
        "inventory_payload.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/metadata/internal/util",
    tags_independent = True,
    visibility = ["//comp/metadata:__subpackages__"],
    deps = [
        "//comp/core/config",
        "//comp/core/flare/types",
        "//comp/core/log/def",
        "//comp/metadata/runner/def",
        "//pkg/config/model",
        "//pkg/serializer",
        "//pkg/serializer/marshaler",
        "//pkg/util/log",
        "//pkg/util/scrubber",
        "@org_uber_go_atomic//:atomic",
    ],
)

dd_agent_go_test(
    name = "util_test",
    srcs = [
        "inventory_enabled_test.go",
        "inventory_payload_test.go",
    ],
    embed = [":util"],
    deps = [
        "//comp/core/config",
        "//comp/core/flare/helpers",
        "//comp/core/log/mock",
        "//pkg/config/mock",
        "//pkg/serializer/marshaler",
        "//pkg/serializer/mocks",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//mock",
    ],
)
