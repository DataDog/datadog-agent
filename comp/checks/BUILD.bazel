load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

# gazelle:dd_agent_go_test on

go_library(
    name = "checks",
    srcs = ["bundle.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/checks",
    visibility = ["//visibility:public"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "//comp/checks/agentcrashdetect/fx",
            "//pkg/util/fxutil",
        ],
        "//conditions:default": [],
    }),
)

dd_agent_go_test(
    name = "checks_test",
    srcs = ["bundle_test.go"],
    embed = [":checks"],
    deps = select({
        "@rules_go//go/platform:windows": [
            "//comp/core",
            "//comp/core/agenttelemetry/fx",
            "//comp/core/tagger/def",
            "//comp/core/tagger/fx-mock",
            "//pkg/util/crashreport",
            "//pkg/util/fxutil",
            "@org_uber_go_fx//:fx",
        ],
        "//conditions:default": [],
    }),
)
