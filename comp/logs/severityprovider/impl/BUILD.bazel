load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = [
        "severityprovider.go",
        "severityprovider_noop.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/logs/severityprovider/impl",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/anomalydetection/config",
        "//comp/anomalydetection/observer/def",
        "//comp/anomalydetection/severityevents/def",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/def",
        "//comp/logs/severityprovider/def",
        "//pkg/util/option",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = ["severityprovider_test.go"],
    embed = [":impl"],
    include_default = False,
    tag_sets = ["python"],
    deps = [
        "//comp/anomalydetection/config",
        "//comp/anomalydetection/observer/def",
        "//comp/anomalydetection/severityevents/def",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/def",
        "//pkg/util/option",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
