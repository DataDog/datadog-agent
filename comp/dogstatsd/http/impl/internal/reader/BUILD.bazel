go_test(
    name = "reader_test",
    srcs = ["reader_test.go"],
    data = glob(["testdata/**"]),
    embed = [":reader"],
    gotags = ["test"],
    deps = [
        "//vendor/github.com/DataDog/datadog-agent/pkg/proto/pbgo/dogstatsdhttp",
        "//vendor/github.com/stretchr/testify/assert",
        "//vendor/github.com/stretchr/testify/require",
    ],
