        "//comp/core",
        "//comp/core/hostname/hostnameimpl",
        "//comp/core/secrets/def",
        "//comp/core/secrets/mock",
        "//comp/core/tagger/fx-noop",
        "//comp/filterlist/fx-mock",
        "//comp/forwarder/defaultforwarder/mock",
        "//comp/forwarder/eventplatform/mock",
        "//comp/forwarder/orchestrator/mock",
        "//comp/haagent/mock",
        "//comp/serializer/logscompression/fx-mock",
        "//comp/serializer/metricscompression/fx-mock",
        "//pkg/util/fxutil",
        "@org_uber_go_fx//:fx",
    ],
