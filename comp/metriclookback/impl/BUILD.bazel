    srcs = ["metriclookback_test.go"],
    embed = [":impl"],
    deps = [
        "//comp/core/config",
        "//comp/core/log/mock",
        "//pkg/aggregator",
        "//pkg/aggregator/ckey",
        "//pkg/collector/check/id",
        "//pkg/collector/metriclookback",
