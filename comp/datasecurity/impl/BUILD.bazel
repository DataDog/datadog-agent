load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "impl",
    srcs = [
        "backend_postgres.go",
        "backends.go",
        "datasecurity.go",
        "handler.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/datasecurity/impl",
    # Depends on sharedlibraryimpl, which requires sharedlibrarycheck gotags.
    # Mark manual so //... expansion skips this target; invoke agent.build
    # supplies the tag via go build -tags.
    tags = ["manual"],
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/autodiscovery/def",
        "//comp/core/autodiscovery/integration",
        "//comp/core/autodiscovery/providers/names",
        "//comp/core/autodiscovery/providers/types",
        "//comp/core/config",
        "//comp/core/log/def",
        "//comp/core/tagger/def",
        "//comp/core/workloadfilter/def",
        "//comp/datasecurity/def",
        "//comp/def",
        "//comp/logs/integrations/def",
        "//comp/remote-config/rcclient/def",
        "//pkg/aggregator/sender",
        "//pkg/config/remote/data",
        "//pkg/remoteconfig/state",
        "//pkg/util/option",
        "@//pkg/collector/aggregator",
        "@in_gopkg_yaml_v3//:yaml_v3",
    ],
)

go_test(
    name = "impl_test",
    srcs = ["backends_test.go"],
    embed = [":impl"],
    gotags = ["test"],
    deps = [
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
