load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "http",
    srcs = ["http_sender.go"],
    importpath = "github.com/DataDog/datadog-agent/comp/logs-library/sender/http",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/secrets/def",
        "//comp/logs-library/client",
        "//comp/logs-library/client/http",
        "//comp/logs-library/metrics",
        "//comp/logs-library/sender",
        "//comp/logs/agent/config",
        "//pkg/config/model",
        "//pkg/util/log",
    ],
)

dd_agent_go_test(
    name = "http_test",
    srcs = ["http_sender_test.go"],
    embed = [":http"],
    deps = [
        "//comp/core/secrets/noop-impl",
        "//comp/logs-library/client",
        "//comp/logs-library/client/http",
        "//comp/logs-library/metrics",
        "//comp/logs-library/sender",
        "//comp/logs/agent/config",
        "//pkg/config/mock",
        "@com_github_stretchr_testify//assert",
    ],
)
