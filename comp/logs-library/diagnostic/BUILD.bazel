)

dd_agent_go_test(
    name = "diagnostic_test",
    srcs = ["message_receiver_test.go"],
    embed = [":diagnostic"],
    deps = [
        "//comp/core/hostname/hostnameinterface/mock",
        "//comp/logs/agent/config",
        "//pkg/config/mock",
        "//pkg/config/model",
        "//pkg/logs/message",
        "//pkg/logs/sources",
        "@com_github_stretchr_testify//assert",
    ],
)
