load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "diagnostic",
    srcs = [
        "format.go",
        "message_receiver.go",
        "noop_message_receiver.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/logs-library/diagnostic",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/hostname/hostnameinterface/def",
        "//pkg/config/model",
        "//pkg/logs/message",
