load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "client",
    srcs = [
        "destination.go",
        "destination_metadata.go",
        "destinations.go",
        "destinations_context.go",
        "errors.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/logs-library/client",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = ["//pkg/logs/message"],
)

dd_agent_go_test(
    name = "client_test",
    srcs = ["destinations_context_test.go"],
    embed = [":client"],
    deps = ["@com_github_stretchr_testify//assert"],
)
