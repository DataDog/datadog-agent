load("@rules_go//go:def.bzl", "go_library", "go_test")

go_library(
    name = "impl",
    srcs = ["status.go"],
    embedsrcs = [
        "status_templates/traceagent.tmpl",
        "status_templates/traceagentHTML.tmpl",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/trace/status/impl",
