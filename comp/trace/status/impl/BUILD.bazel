    srcs = ["status_test.go"],
    embed = [":impl"],
    gotags = ["test"],
    deps = [
        "//comp/core/remoteagentregistry/def",
        "//comp/core/remoteagentregistry/mock",
        "@com_github_stretchr_testify//assert",
    ],
)
