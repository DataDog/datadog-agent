# config_test fails in CI because it calls a go build.
# For now we make the test manual, so we can detect backsliding on the
# the dependencies.  In the future, we'll have to refactor this, but
# that should involve the trace agent team.
go_test(
    name = "impl_test",
    srcs = [
        "aliases_test.go",
        "config_otlp_test.go",
        "config_test.go",
        "install_signature_test.go",
    ],
    data = glob(["testdata/**"]),
    embed = [":impl"],
    embedsrcs = ["testdata/stringcode.go.tmpl"],
    gotags = sorted(["test"] + list(COMMON_TAGS) + list(TRACE_AGENT_TAGS)),
    tags = ["manual"],
    deps = [
        "//comp/core/config",
        "//comp/core/ipc/def",
        "//comp/core/ipc/mock",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/tagger/def",
        "//comp/core/tagger/fx-mock",
