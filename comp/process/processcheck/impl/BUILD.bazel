load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = [
        "check.go",
        "mock.go",
    ],
    importpath = "github.com/DataDog/datadog-agent/comp/process/processcheck/impl",
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/ipc/def",
        "//comp/core/sysprobeconfig/def",
        "//comp/core/tagger/def",
        "//comp/core/workloadmeta/def",
        "//comp/def",
        "//comp/process/gpusubscriber/def",
        "//comp/process/processcheck/def",
        "//comp/process/types",
        "//pkg/process/checks",
        "//pkg/process/checks/mocks",
        "@com_github_datadog_datadog_go_v5//statsd",
        "@com_github_stretchr_testify//mock",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = [
        "check_linux_test.go",
        "check_test.go",
    ],
    embed = [":impl"],
    deps = [
        "//comp/core/config",
        "//comp/core/ipc/def",
        "//comp/core/ipc/mock",
        "//comp/core/log/def",
        "//comp/core/log/mock",
        "//comp/core/sysprobeconfig/def",
        "//comp/core/sysprobeconfig/mock",
        "//comp/core/tagger/fx-noop",
        "//comp/core/workloadmeta/def",
        "//comp/core/workloadmeta/fx-mock",
        "//comp/process/gpusubscriber/fx-mock",
        "//comp/process/processcheck/def",
        "//pkg/util/fxutil",
        "@com_github_datadog_datadog_go_v5//statsd",
        "@com_github_stretchr_testify//assert",
        "@org_uber_go_fx//:fx",
    ] + select({
        "@rules_go//go/platform:android": [
            "//pkg/util/flavor",
        ],
        "@rules_go//go/platform:linux": [
            "//pkg/util/flavor",
        ],
        "//conditions:default": [],
    }),
)
