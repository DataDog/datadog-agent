load("@rules_go//go:def.bzl", "go_library")
load("//bazel/rules/go:dd_agent_go_test.bzl", "dd_agent_go_test")

go_library(
    name = "impl",
    srcs = ["status.go"],
    embedsrcs = ["status_templates/processagent.tmpl"],
    importpath = "github.com/DataDog/datadog-agent/comp/process/status/impl",
    tags_independent = True,
    visibility = ["//visibility:public"],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname/hostnameinterface/def",
        "//comp/core/status",
        "//comp/def",
        "//pkg/process/util/status",
        "//pkg/util/log",
        "//pkg/util/system",
    ],
)

dd_agent_go_test(
    name = "impl_test",
    srcs = ["status_test.go"],
    embed = [":impl"],
    embedsrcs = [
        "fixtures/expvar_response.tmpl",
        "fixtures/text_error_response.tmpl",
    ],
    deps = [
        "//comp/core/config",
        "//comp/core/hostname/hostnameimpl",
        "@com_github_stretchr_testify//assert",
        "@com_github_stretchr_testify//require",
    ],
)
