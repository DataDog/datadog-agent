# Environment variables for the Lustre Agent E2E scenario.
#
# This lab needs NO integration-specific secrets: auth_mode: none,
# secret_env_map: {}. The check shells out to local CLI binaries
# (/usr/sbin/lctl, /usr/sbin/lnetctl, /usr/bin/lfs) and has no protocol auth.
#
# The only secret in play is the Datadog API key, which the E2E framework
# injects into the Agent automatically (env.AgentAPIKey()). It is NOT referenced
# in any generated scenario/component/task file. Set it through your normal
# framework / ddinfra secret configuration, not as a literal here.

# Datadog API key used by the Agent to ship lustre.* payloads.
# Managed by the E2E framework; placeholder only.
DD_API_KEY=${DD_API_KEY}
