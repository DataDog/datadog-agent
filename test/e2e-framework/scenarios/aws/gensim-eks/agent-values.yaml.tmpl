fullnameOverride: datadog-agent

datadog:
  apiKeyExistingSecret: gensim-secrets
  appKeyExistingSecret: gensim-secrets
  apm:
    portEnabled: true
    instrumentation:
      enabled: true
  logs:
    enabled: true
    containerCollectAll: true
  processAgent:
    enabled: true
    processCollection: true
  dogstatsd:
    useHostPort: true
  kubelet:
    tlsVerify: false
  clusterName: gensim
  clusterChecks:
    enabled: true
  env:
{{- if eq .Mode "record-parquet"}}
    - name: DD_ANOMALY_DETECTION_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_RECORDING_ENABLED
      value: "true"
{{- end}}
{{- if eq .Mode "live-anomaly-detection"}}
    - name: DD_ANOMALY_DETECTION_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_LOGS_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_LOGS_AGENT_TAP_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_REPORTING_STDOUT_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_REPORTING_STDOUT_VERBOSE
      value: "true"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_ENABLED
      value: "true"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_RATE_LIMIT
      value: "0.2"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_BURST_SIZE
      value: "2"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_TAG_PATTERN_HASH
      value: "true"
{{- end}}
{{- if eq .Mode "live-and-record"}}
    - name: DD_ANOMALY_DETECTION_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_RECORDING_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_LOGS_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_LOGS_AGENT_TAP_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_REPORTING_STDOUT_ENABLED
      value: "true"
    - name: DD_ANOMALY_DETECTION_REPORTING_STDOUT_VERBOSE
      value: "true"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_ENABLED
      value: "true"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_RATE_LIMIT
      value: "0.2"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_BURST_SIZE
      value: "2"
    - name: DD_LOGS_CONFIG_EXPERIMENTAL_ADAPTIVE_SAMPLING_TAG_PATTERN_HASH
      value: "true"
{{- end}}

agents:
  enabled: true
  image:
    repository: {{.ImageRepo}}
    tag: {{.ImageTag}}
    doNotCheckTag: true
    pullPolicy: Always
  useConfigMap: true
  customAgentConfig:
    anomaly_detection:
      enabled: true
      detectors:
        anomaly_scorer:
          enabled: true
          alpha: 0.5
          low_threshold: 0.001
          high_threshold: 0.002
          window_secs: 60
{{- if eq .Mode "record-parquet"}}
      recording:
        enabled: true
        output_dir: /tmp/observer-parquet
        flush_interval: 30
{{- end}}
{{- if eq .Mode "live-anomaly-detection"}}
      logs:
        enabled: true
        agent_tap:
          enabled: true
      reporting:
        stdout:
          enabled: true
          verbose: true
{{- end}}
{{- if eq .Mode "live-and-record"}}
      recording:
        enabled: true
        output_dir: /tmp/observer-parquet
        flush_interval: 30
      logs:
        enabled: true
        agent_tap:
          enabled: true
      reporting:
        stdout:
          enabled: true
          verbose: true
{{- end}}
    logs_config:
      experimental_adaptive_sampling:
        enabled: true
        rate_limit: 0.2
        burst_size: 2.0
        tag_pattern_hash: true
  containers:
    agent:
      resources:
        requests:
          memory: 1500Mi
          cpu: 500m
        limits:
          memory: 3000Mi

clusterAgent:
  enabled: true
  admissionController:
    enabled: true
    mutateUnlabelled: true

clusterChecksRunner:
  enabled: false
