load("@protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_go//go:def.bzl", "go_library")
load("@rules_go//proto:def.bzl", "go_proto_library")
load("//bazel/rules/write_pb_go:defs.bzl", "write_pb_go")

go_library(
    name = "apiv3",
    srcs = ["reader.go"],
    embed = [":apiv3_go_proto"],
    importpath = "github.com/DataDog/datadog-agent/test/fakeintake/aggregator/internal/apiv3",
    visibility = ["//visibility:public"],
)

proto_library(
    name = "apiv3_proto",
    srcs = ["payload.proto"],
    visibility = ["//test/fakeintake/aggregator:__subpackages__"],
)

go_proto_library(
    name = "apiv3_go_proto",
    importpath = "github.com/DataDog/datadog-agent/test/fakeintake/aggregator/internal/apiv3",
    proto = ":apiv3_proto",
    visibility = ["//test/fakeintake/aggregator:__subpackages__"],
)

write_pb_go(
    name = "write_pb_go",
    srcs = {
        ":apiv3_go_proto": [
            "payload.pb.go",
        ],
    },
)
