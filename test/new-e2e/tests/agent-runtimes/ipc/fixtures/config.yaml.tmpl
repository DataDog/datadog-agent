log_level: debug
ipc_cert_file_path: {{.IPCCertFilePath}}

cmd_port: {{.AgentCMDPort}}
agent_ipc:
  port: {{.AgentIpcPort}}

apm_config:
  enabled: true
  debug:
    port: {{.ApmCmdPort}}

security_agent:
  cmd_port: {{.SecurityCmdPort}}

process_config:
  process_collection:
    enabled: true
  cmd_port: {{.ProcessCmdPort}}

# NPM is needed to keep process-agent running on Linux since process checks
# now always run in the core agent.
network_config:
  enabled: true
system_probe_config:
  enabled: true
