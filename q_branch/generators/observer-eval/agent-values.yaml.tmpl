fullnameOverride: datadog-agent

datadog:
  apiKeyExistingSecret: gensim-secrets
  appKeyExistingSecret: gensim-secrets
  apm:
    portEnabled: true
    instrumentation:
      enabled: true
  logs:
    enabled: ${LOGS_ENABLED}
    containerCollectAll: ${LOGS_ENABLED}
  processAgent:
    enabled: true
    processCollection: true
  dogstatsd:
    useHostPort: true
  kubelet:
    tlsVerify: false
  clusterName: gensim
  clusterChecks:
    enabled: true
  env:
    - name: DD_OBSERVER_RECORDING_ENABLED
      value: "true"
    - name: DD_OBSERVER_HIGH_FREQUENCY_INTERVAL
      value: "1s"

agents:
  enabled: true
  image:
    repository: ${AGENT_IMAGE_REPO}
    tag: ${AGENT_IMAGE_TAG}
    doNotCheckTag: true
    pullPolicy: Always
    pullSecrets:
      - name: gar-pull-secret
  useConfigMap: true
  customAgentConfig:
    anomaly_detection:
      recording:
        enabled: true
        output_dir: /tmp/observer-parquet
        flush_interval: 30
      reporting:
        enabled: ${SCRAPPY_EVENTS_ENABLED}
      detectors:
        scrappy_collector:
          enabled: ${SCRAPPY_ENABLED}
          output_path: /tmp/scrappy-collect.jsonl
        scrappy_detector:
          enabled: ${SCRAPPY_DETECT_ENABLED}
          model_path: /opt/scrappy/model.scrappy
          vocab_path: /opt/scrappy/vocab.json
          context_window: 4096
          threshold: 0.5
          scores_output: /tmp/scrappy-scores.csv
        bocpd:
          enabled: ${DETECTORS_ENABLED}
        rrcf:
          enabled: ${DETECTORS_ENABLED}
        cusum:
          enabled: false
        scanmw:
          enabled: false
        scanwelch:
          enabled: false
        cross_signal:
          enabled: false
        time_cluster:
          enabled: ${DETECTORS_ENABLED}
        passthrough:
          enabled: false
  containers:
    agent:
      resources:
        requests:
          memory: 1500Mi
          cpu: 500m
        limits:
          memory: 3000Mi

clusterAgent:
  enabled: true
  image:
    pullSecrets:
      - name: gar-pull-secret
  admissionController:
    enabled: true
    mutateUnlabelled: true

clusterChecksRunner:
  enabled: false

datadog-operator:
  enabled: false
