genrule(
    name = "libdatadog_interop",
    srcs = [
        "DatadogInterop/msstoreapps.cpp",
        "DatadogInterop/msstoreapps.h",
        "DatadogInterop/DatadogInterop.vcxproj",
    ],
    outs = ["libdatadog-interop.dll"],
    cmd_bat = """
        set MSBUILD=$(location @visual_studio//:msbuild)
        set VCXPROJ=$(location DatadogInterop/DatadogInterop.vcxproj)
        for %%F in (%MSBUILD%) do set MSBUILD=%%~fF
        for %%F in (%VCXPROJ%) do set VCXPROJ=%%~fF
        for %%F in ($@) do set OUTDIR=%%~dpF
        set INTDIR=%OUTDIR%obj\\

        echo === DEBUG: MSBUILD=%MSBUILD%
        echo === DEBUG: VCXPROJ=%VCXPROJ%
        echo === DEBUG: OUTDIR=%OUTDIR%
        echo === DEBUG: INTDIR=%INTDIR%
        echo === DEBUG: expected output=$@
        echo === DEBUG: CWD=%CD%

        "%MSBUILD%" "%VCXPROJ%" /p:Configuration=Release /p:Platform="x64" /p:OutDir="%OUTDIR%" /p:IntDir="%INTDIR%" /verbosity:detailed
        set MSBUILD_EXIT=%errorlevel%
        echo === DEBUG: MSBuild exit code=%MSBUILD_EXIT%

        echo === DEBUG: looking for dll...
        dir /s /b "%OUTDIR%*.dll" 2>nul
        if not exist "$@" (
            echo === DEBUG: expected output NOT found at $@
            dir /s /b "%CD%\\*.dll" 2>nul
        )

        if %MSBUILD_EXIT% neq 0 exit /b %MSBUILD_EXIT%
    """,
    target_compatible_with = ["@platforms//os:windows"],
    tools = ["@visual_studio//:msbuild"],
    visibility = ["//visibility:public"],
)
