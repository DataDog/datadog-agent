genrule(
    name = "libdatadog_interop",
    srcs = [
        "DatadogInterop/msstoreapps.cpp",
        "DatadogInterop/msstoreapps.h",
        "DatadogInterop/DatadogInterop.vcxproj",
        "build_interop.bat",
    ],
    outs = ["libdatadog-interop.dll"],
    cmd_bat = "$(location build_interop.bat) $(location @visual_studio//:msbuild) $(location DatadogInterop/DatadogInterop.vcxproj) $@",
    target_compatible_with = ["@platforms//os:windows"],
    tools = ["@visual_studio//:msbuild"],
    visibility = ["//visibility:public"],
)
